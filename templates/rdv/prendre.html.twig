{% extends 'base.html.twig' %}

{% block title %}MEDINOVA - Prendre un Rendez-vous{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        /* ============ PALETTE DE COULEURS MÉDICALE PROFESSIONNELLE ============ */
        :root {
            --mughal-green: #304D30;
            --prussian-blue: #163A5F;
            --teal-blue: #1D5D9B;
            --pastel-blue: #75C2F6;
            --light-silver: #F4F6FF;
            
            --primary: #1D5D9B;
            --primary-light: #E8F4F8;
            --primary-dark: #163A5F;
            
            --secondary: #304D30;
            --secondary-light: #4A7C59;
            --secondary-dark: #1E3A1E;
            
            --accent: #75C2F6;
            --accent-light: #B4E4FF;
            
            --light: #F4F6FF;
            --light-alt: #E8EAF6;
            
            --dark: #1A2332;
            --dark-light: #2C3E50;
            
            --success: #4A7C59;
            --success-light: #D4E9DA;
            --danger: #C1666B;
            --danger-light: #F8E8E9;
            --warning: #D4A574;
            --warning-light: #F9F0E7;
            --info: #75C2F6;
            --info-light: #E8F4F8;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, var(--light) 0%, var(--light-alt) 100%);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated Geometric Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 15% 20%, rgba(29, 93, 155, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 85% 80%, rgba(48, 77, 48, 0.08) 0%, transparent 40%),
                linear-gradient(135deg, transparent 0%, rgba(117, 194, 246, 0.05) 50%, transparent 100%);
            pointer-events: none;
            z-index: 0;
            animation: backgroundPulse 20s ease-in-out infinite;
        }

        @keyframes backgroundPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        body::after {
            content: '';
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            background-image: 
                radial-gradient(2px 2px at 20% 30%, rgba(29, 93, 155, 0.2), transparent),
                radial-gradient(2px 2px at 60% 70%, rgba(48, 77, 48, 0.2), transparent),
                radial-gradient(1px 1px at 50% 50%, rgba(117, 194, 246, 0.15), transparent);
            background-size: 200px 200px, 300px 300px, 150px 150px;
            background-position: 0 0, 40px 60px, 130px 270px;
            animation: particlesFloat 40s linear infinite;
            pointer-events: none;
            z-index: 0;
        }

        @keyframes particlesFloat {
            to {
                background-position: 200px 200px, 240px 260px, 330px 470px;
            }
        }

        .appointment-section {
            padding: 40px 20px;
            position: relative;
            z-index: 1;
        }

        .appointment-wrapper {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ============ HEADER SECTION ============ */
        .page-header {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(30px) saturate(180%);
            border-radius: 30px;
            padding: 50px 40px;
            margin-bottom: 35px;
            box-shadow: 
                0 8px 32px rgba(29, 93, 155, 0.15),
                inset 0 1px 0 rgba(255, 255, 255, 0.5);
            border: 2px solid rgba(117, 194, 246, 0.3);
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: fadeInDown 0.6s ease;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(29, 93, 155, 0.08) 0%, transparent 70%);
            animation: headerGlow 8s ease-in-out infinite;
        }

        @keyframes headerGlow {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(10%, 10%) scale(1.1); }
        }

        .page-header h1 {
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
            letter-spacing: -1px;
        }

        .page-header h1 i {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-right: 15px;
            filter: drop-shadow(0 0 20px rgba(29, 93, 155, 0.3));
        }

        .page-header p {
            color: var(--dark-light);
            font-size: 1.2rem;
            font-weight: 500;
            position: relative;
            z-index: 1;
        }

        /* ============ PROGRESS TIMELINE ============ */
        .progress-timeline {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 25px;
            padding: 35px 40px;
            margin-bottom: 35px;
            box-shadow: 
                0 15px 45px rgba(29, 93, 155, 0.12),
                inset 0 1px 0 rgba(255, 255, 255, 0.8);
            border: 2px solid rgba(117, 194, 246, 0.2);
            animation: slideInUp 0.6s ease 0.2s both;
        }

        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .timeline-steps {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            position: relative;
        }

        .timeline-steps::before {
            content: '';
            position: absolute;
            top: 28px;
            left: 12%;
            right: 12%;
            height: 4px;
            background: linear-gradient(90deg, var(--light-alt) 0%, var(--light-alt) 100%);
            z-index: 0;
            border-radius: 2px;
        }

        .timeline-step {
            position: relative;
            text-align: center;
            z-index: 1;
        }

        .step-circle {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: white;
            border: 3px solid var(--light-alt);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--dark-light);
            margin: 0 auto 12px;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55);
            position: relative;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }

        .timeline-step.active .step-circle {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border-color: var(--primary);
            color: white;
            transform: scale(1.15);
            box-shadow: 
                0 8px 25px rgba(29, 93, 155, 0.3),
                0 0 0 8px rgba(29, 93, 155, 0.15);
        }

        .timeline-step.completed .step-circle {
            background: linear-gradient(135deg, var(--success) 0%, var(--secondary-light) 100%);
            border-color: var(--success);
            color: white;
            box-shadow: 0 8px 25px rgba(74, 124, 89, 0.3);
        }

        .timeline-step.completed .step-circle::after {
            content: '✓';
            position: absolute;
            font-size: 24px;
            font-weight: 900;
        }

        .step-label {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--dark-light);
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .timeline-step.active .step-label {
            color: var(--primary);
        }

        .timeline-step.completed .step-label {
            color: var(--success);
        }

        /* ============ FORM CONTAINER ============ */
        .form-container {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            box-shadow: 
                0 15px 50px rgba(29, 93, 155, 0.12),
                inset 0 1px 0 rgba(255, 255, 255, 0.9);
            overflow: hidden;
            animation: slideInUp 0.6s ease 0.4s both;
            border: 2px solid rgba(117, 194, 246, 0.2);
            position: relative;
        }

        .form-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 6px;
            height: 100%;
            background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
        }

        .form-inner {
            padding: 50px;
        }

        .section-block {
            margin-bottom: 50px;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ============ SECTION HEADER ============ */
        .section-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 3px solid var(--light-alt);
        }

        .section-icon {
            width: 70px;
            height: 70px;
            border-radius: 20px;
            background: linear-gradient(135deg, rgba(117, 194, 246, 0.15) 0%, var(--light) 100%);
            border: 2px solid rgba(117, 194, 246, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            flex-shrink: 0;
            box-shadow: 0 8px 25px rgba(29, 93, 155, 0.12);
        }

        .section-title-wrap h2 {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--dark);
            margin-bottom: 6px;
        }

        .section-title-wrap p {
            font-size: 0.95rem;
            color: var(--dark-light);
            font-weight: 500;
        }

        /* ============ DOCTOR SELECTION AREA ============ */
        .doctor-selection-area {
            background: linear-gradient(135deg, rgba(117, 194, 246, 0.08) 0%, var(--light) 100%);
            border-radius: 20px;
            padding: 35px;
            border: 2px solid rgba(117, 194, 246, 0.2);
        }

        .recommendation-panel {
            background: #fff;
            border: 2px solid rgba(117, 194, 246, 0.35);
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 20px;
        }

        .recommendation-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 12px;
        }

        .recommendation-title {
            color: var(--primary-dark);
            font-weight: 800;
            font-size: 0.95rem;
        }

        .recommendation-subtitle {
            color: var(--dark-light);
            font-size: 0.82rem;
            font-weight: 600;
        }

        .recommendation-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 10px;
        }

        .recommendation-card {
            border: 1px solid rgba(117, 194, 246, 0.4);
            border-radius: 12px;
            background: linear-gradient(135deg, #fff 0%, var(--primary-light) 100%);
            padding: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .recommendation-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(29, 93, 155, 0.15);
            border-color: var(--primary);
        }

        .recommendation-name {
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 4px;
        }

        .recommendation-specialty {
            font-size: 0.82rem;
            color: var(--dark-light);
            margin-bottom: 6px;
            font-weight: 600;
        }

        .recommendation-distance {
            font-size: 0.8rem;
            color: var(--primary);
            font-weight: 800;
        }

        .recommendation-status {
            font-size: 0.85rem;
            color: var(--dark-light);
            font-weight: 600;
        }

        /* ============ CUSTOM DROPDOWN POUR RECHERCHE ============ */
        .custom-dropdown {
            position: relative;
        }

        .search-wrapper {
            position: relative;
            margin-bottom: 0;
        }

        .search-input {
            width: 100%;
            padding: 18px 55px 18px 22px;
            border: 2px solid rgba(117, 194, 246, 0.3);
            border-radius: 16px;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            background: white;
            transition: all 0.3s ease;
            font-weight: 500;
            box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.05);
        }

        .search-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 
                0 0 0 4px rgba(29, 93, 155, 0.15),
                inset 0 2px 5px rgba(0, 0, 0, 0.05);
            transform: translateY(-2px);
        }

        .search-input.active {
            border-radius: 16px 16px 0 0;
            border-bottom-color: transparent;
        }

        .search-icon {
            position: absolute;
            right: 22px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            font-size: 1.2rem;
            pointer-events: none;
        }

        .dropdown-list {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid var(--primary);
            border-top: none;
            border-radius: 0 0 16px 16px;
            max-height: 350px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 8px 30px rgba(29, 93, 155, 0.25);
            margin-top: -2px;
        }

        .dropdown-list.show {
            display: block;
            animation: slideDownDropdown 0.3s ease;
        }

        @keyframes slideDownDropdown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dropdown-item {
            padding: 16px 20px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 1px solid var(--light-alt);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .dropdown-item:last-child {
            border-bottom: none;
        }

        .dropdown-item:hover {
            background: linear-gradient(135deg, rgba(117, 194, 246, 0.12) 0%, var(--light) 100%);
            padding-left: 25px;
        }

        .dropdown-item.selected {
            background: linear-gradient(135deg, var(--primary-light) 0%, rgba(117, 194, 246, 0.25) 100%);
            font-weight: 700;
            color: var(--primary);
            border-left: 5px solid var(--primary);
        }

        .dropdown-item-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 800;
            flex-shrink: 0;
            box-shadow: 0 4px 15px rgba(29, 93, 155, 0.25);
            text-transform: uppercase;
        }

        .dropdown-item-content {
            flex: 1;
        }

        .dropdown-item-name {
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 4px;
            font-size: 1rem;
        }

        .dropdown-item-specialty {
            font-size: 0.85rem;
            color: var(--dark-light);
            font-weight: 600;
        }

        /* Scrollbar pour dropdown */
        .dropdown-list::-webkit-scrollbar {
            width: 8px;
        }

        .dropdown-list::-webkit-scrollbar-track {
            background: var(--light);
            border-radius: 0 0 10px 0;
        }

        .dropdown-list::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            border-radius: 10px;
        }

        /* Masquer le select natif */
        #medecinSelect {
            display: none !important;
        }

        .custom-select-wrapper {
            position: relative;
        }

        .custom-select-wrapper::after {
            display: none;
        }

        /* ============ DOCTOR DETAILS CARD ============ */
        .doctor-details-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            margin-top: 25px;
            border: 2px solid rgba(117, 194, 246, 0.3);
            display: none;
            animation: slideInUp 0.4s ease;
            box-shadow: 0 8px 25px rgba(29, 93, 155, 0.12);
        }

        .doctor-details-card.show {
            display: block;
        }

        .doctor-profile {
            display: flex;
            align-items: flex-start;
            gap: 22px;
            margin-bottom: 25px;
        }

        .doctor-avatar {
            width: 85px;
            height: 85px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 800;
            color: white;
            flex-shrink: 0;
            box-shadow: 0 8px 25px rgba(29, 93, 155, 0.3);
            text-transform: uppercase;
        }

        .doctor-info h3 {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--dark);
            margin-bottom: 10px;
        }

        .doctor-specialty {
            display: inline-block;
            background: linear-gradient(135deg, var(--primary-light) 0%, rgba(117, 194, 246, 0.2) 100%);
            color: var(--primary);
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 15px rgba(29, 93, 155, 0.15);
        }

        .doctor-meta {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 18px;
            padding: 25px;
            background: linear-gradient(135deg, rgba(117, 194, 246, 0.08) 0%, var(--light) 100%);
            border-radius: 16px;
            border: 2px solid rgba(117, 194, 246, 0.2);
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .meta-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 1.1rem;
            flex-shrink: 0;
            box-shadow: 0 4px 15px rgba(29, 93, 155, 0.12);
        }

        .meta-content {
            flex: 1;
        }

        .meta-label {
            font-size: 0.75rem;
            color: var(--dark-light);
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 700;
        }

        .meta-value {
            font-size: 0.95rem;
            font-weight: 800;
            color: var(--dark);
        }

        /* ============ FORM FIELDS ============ */
        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-bottom: 25px;
        }

        .form-field {
            display: flex;
            flex-direction: column;
        }

        .form-field label {
            font-weight: 800;
            font-size: 0.95rem;
            color: var(--dark);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-field label::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--primary);
            border-radius: 50%;
        }

        .form-control {
            padding: 18px 22px;
            border: 2px solid rgba(117, 194, 246, 0.3);
            border-radius: 16px;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            background: white;
            transition: all 0.3s ease;
            font-weight: 500;
            box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.05);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 
                0 0 0 4px rgba(29, 93, 155, 0.15),
                inset 0 2px 5px rgba(0, 0, 0, 0.05);
            transform: translateY(-2px);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 150px;
            line-height: 1.6;
        }

        .field-hint {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-top: 10px;
            font-size: 0.85rem;
            color: var(--dark-light);
            padding: 12px 16px;
            background: linear-gradient(135deg, rgba(117, 194, 246, 0.08) 0%, var(--light) 100%);
            border-radius: 12px;
            border-left: 4px solid var(--primary);
            font-weight: 500;
        }

        .field-hint::before {
            content: '💡';
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        /* ============ INVALID FEEDBACK ============ */
        .invalid-feedback {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            background: var(--danger-light);
            border-radius: 10px;
            border-left: 4px solid var(--danger);
            font-weight: 600;
            animation: shake 0.5s ease;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .invalid-feedback::before {
            content: '⚠️';
            font-size: 1.1rem;
        }

        /* ============ NO RESULTS ============ */
        .no-results {
            text-align: center;
            padding: 25px;
            color: var(--dark-light);
            font-size: 0.95rem;
            display: none;
            font-weight: 600;
            background: linear-gradient(135deg, var(--warning-light) 0%, #FFF5E6 100%);
            border-radius: 12px;
            border: 2px solid var(--warning);
            margin-top: 15px;
        }

        .no-results.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        .no-results::before {
            content: '🔍';
            display: block;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        /* ============ BUTTONS ============ */
        .form-footer {
            display: flex;
            gap: 20px;
            margin-top: 50px;
            padding-top: 40px;
            border-top: 3px solid var(--light-alt);
        }

        .btn {
            flex: 1;
            padding: 18px 40px;
            border-radius: 16px;
            font-size: 1.05rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            position: relative;
            overflow: hidden;
            text-decoration: none;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s ease, height 0.6s ease;
        }

        .btn:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn i {
            position: relative;
            z-index: 1;
            transition: transform 0.3s ease;
        }

        .btn:hover i {
            transform: scale(1.2) rotate(5deg);
        }

        .btn span {
            position: relative;
            z-index: 1;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            box-shadow: 
                0 10px 30px rgba(29, 93, 155, 0.35),
                inset 0 1px 0 rgba(255, 255, 255, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 
                0 15px 40px rgba(29, 93, 155, 0.45),
                inset 0 1px 0 rgba(255, 255, 255, 0.4);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-secondary {
            background: white;
            color: var(--dark);
            border: 2px solid var(--light-alt);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }

        .btn-secondary:hover {
            background: var(--light);
            border-color: var(--primary);
            color: var(--primary);
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none !important;
        }

        /* Responsive Design */
        @media (max-width: 968px) {
            .timeline-steps {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }

            .timeline-steps::before {
                display: none;
            }

            .form-inner {
                padding: 35px 25px;
            }

            .section-icon {
                width: 60px;
                height: 60px;
                font-size: 1.6rem;
            }

            .section-title-wrap h2 {
                font-size: 1.4rem;
            }

            .doctor-profile {
                flex-direction: column;
                align-items: center;
                text-align: center;
            }

            .doctor-meta {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .appointment-section {
                padding: 20px 10px;
            }

            .page-header {
                padding: 35px 25px;
            }

            .page-header h1 {
                font-size: 2rem;
            }

            .form-footer {
                flex-direction: column-reverse;
            }

            .btn {
                width: 100%;
            }
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 12px;
            height: 12px;
        }

        ::-webkit-scrollbar-track {
            background: var(--light);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            border-radius: 10px;
            border: 2px solid var(--light);
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--secondary-dark) 100%);
        }
    </style>
{% endblock %}

{% block body %}
<div class="appointment-section">
    <div class="appointment-wrapper">
        <!-- Page Header -->
        <div class="page-header">
            <h1><i class="fas fa-calendar-plus"></i> Prendre un Rendez-vous</h1>
            <p>Réservez votre consultation en quelques clics</p>
        </div>

        <!-- Progress Timeline -->
        <div class="progress-timeline">
            <div class="timeline-steps">
                <div class="timeline-step active" data-step="1">
                    <div class="step-circle">1</div>
                    <div class="step-label">Médecin</div>
                </div>
                <div class="timeline-step" data-step="2">
                    <div class="step-circle">2</div>
                    <div class="step-label">Date & Heure</div>
                </div>
                <div class="timeline-step" data-step="3">
                    <div class="step-circle">3</div>
                    <div class="step-label">Détails</div>
                </div>
                <div class="timeline-step" data-step="4">
                    <div class="step-circle">4</div>
                    <div class="step-label">Confirmation</div>
                </div>
            </div>
        </div>

        <!-- Form Container -->
        <div class="form-container">
            <div class="form-inner">
                {{ form_start(form, {attr: {id: 'rdvForm'}}) }}

                <!-- Section médecin -->
                <div class="section-block">
                    <div class="section-header">
                        <div class="section-icon">👨‍⚕️</div>
                        <div class="section-title-wrap">
                            <h2>Choisissez votre médecin</h2>
                            <p>Sélectionnez le spécialiste adapté à vos besoins</p>
                        </div>
                    </div>

                    <div class="doctor-selection-area">
                        <div class="form-field">
                            <label for="searchDoctor"><i class="fas fa-user-md"></i> Sélectionner un médecin</label>
                            
                            <div class="recommendation-panel">
                                <div class="recommendation-header">
                                    <div>
                                        <div class="recommendation-title">
                                            <i class="fas fa-location-dot"></i> Médecins les plus proches
                                        </div>
                                        <div class="recommendation-subtitle">Basé sur votre position actuelle</div>
                                    </div>
                                    <div style="display:flex; gap:8px;">
                                        <button type="button" class="btn btn-secondary btn-sm" id="askGeoBtn" title="Activer la position">
                                            <i class="fas fa-location-crosshairs"></i>
                                        </button>
                                        <button type="button" class="btn btn-secondary btn-sm" id="refreshRecommendationsBtn" title="Rafraîchir">
                                            <i class="fas fa-rotate-right"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="recommendation-status" id="recommendationStatus">Chargement des recommandations...</div>
                                <div class="recommendation-list" id="recommendationList"></div>
                            </div>

                            <div class="custom-dropdown">
                                <div class="search-wrapper">
                                    <input
                                        type="text"
                                        class="search-input"
                                        id="searchDoctor"
                                        placeholder="Rechercher un médecin par nom ou spécialité..."
                                        autocomplete="off"
                                    >
                                    <i class="fas fa-search search-icon"></i>
                                </div>
                                <div class="dropdown-list" id="dropdownList"></div>
                            </div>

                            <!-- Select caché pour le formulaire -->
                            <div class="custom-select-wrapper">
                                {{ form_widget(form.medecin, {attr: {class: 'form-control', id: 'medecinSelect'}}) }}
                            </div>
                            
                            {{ form_errors(form.medecin) }}
                            <div class="no-results" id="noResults">Aucun médecin trouvé pour cette recherche</div>
                        </div>

                        <div class="doctor-details-card" id="doctorDetailsCard">
                            <div class="doctor-profile">
                                <div class="doctor-avatar" id="doctorAvatar">
                                    <i class="fas fa-user-md"></i>
                                </div>
                                <div class="doctor-info">
                                    <h3 id="doctorName">Dr. Nom Prénom</h3>
                                    <span class="doctor-specialty" id="doctorSpecialty">Spécialité</span>
                                </div>
                            </div>
                            <div class="doctor-meta">
                                <div class="meta-item">
                                    <div class="meta-icon"><i class="fas fa-briefcase-medical"></i></div>
                                    <div class="meta-content">
                                        <div class="meta-label">Expérience</div>
                                        <div class="meta-value" id="doctorExperience">-</div>
                                    </div>
                                </div>
                                <div class="meta-item">
                                    <div class="meta-icon"><i class="fas fa-award"></i></div>
                                    <div class="meta-content">
                                        <div class="meta-label">Grade</div>
                                        <div class="meta-value" id="doctorGrade">-</div>
                                    </div>
                                </div>
                                <div class="meta-item">
                                    <div class="meta-icon"><i class="fas fa-hospital"></i></div>
                                    <div class="meta-content">
                                        <div class="meta-label">Établissement</div>
                                        <div class="meta-value" id="doctorEstablishment">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section date & heure -->
                <div class="section-block">
                    <div class="section-header">
                        <div class="section-icon">📅</div>
                        <div class="section-title-wrap">
                            <h2>Date et heure du rendez-vous</h2>
                            <p>Sélectionnez le créneau qui vous convient</p>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            {{ form_label(form.dateRdv, 'Date du rendez-vous') }}
                            {{ form_widget(form.dateRdv, {attr: {class: 'form-control', id: 'dateInput'}}) }}
                            {{ form_errors(form.dateRdv) }}
                            <div class="invalid-feedback" id="dateError" style="display:none"></div>
                        </div>

                        <div class="form-field">
                            {{ form_label(form.heureRdv, 'Heure du rendez-vous') }}
                            {{ form_widget(form.heureRdv, {attr: {class: 'form-control', id: 'timeInput'}}) }}
                            {{ form_errors(form.heureRdv) }}
                            <div class="invalid-feedback" id="timeError" style="display:none"></div>
                        </div>
                    </div>
                </div>

                <!-- Section type de consultation -->
                <div class="section-block">
                    <div class="section-header">
                        <div class="section-icon"><i class="fas fa-laptop-medical"></i></div>
                        <div class="section-title-wrap">
                            <h2>Type de consultation</h2>
                            <p>Choisissez entre présentiel et consultation en ligne</p>
                        </div>
                    </div>

                    <div class="form-field">
                        {{ form_label(form.typeConsultation, 'Mode de consultation') }}
                        {{ form_widget(form.typeConsultation, {attr: {class: 'form-control'}}) }}
                        {{ form_errors(form.typeConsultation) }}
                    </div>
                </div>

                <!-- Section motif -->
                <div class="section-block">
                    <div class="section-header">
                        <div class="section-icon">📝</div>
                        <div class="section-title-wrap">
                            <h2>Motif de consultation</h2>
                            <p>Aidez le médecin à mieux préparer votre rendez-vous</p>
                        </div>
                    </div>

                    <div class="form-field">
                        {{ form_label(form.raison, 'Décrivez votre motif') }}
                        {{ form_widget(form.raison, {attr: {class: 'form-control', id: 'reasonInput', placeholder: 'Exemple: Consultation générale, suivi médical, symptômes spécifiques...'}}) }}
                        <div class="field-hint">Soyez précis pour permettre au médecin de mieux vous accompagner</div>
                        {{ form_errors(form.raison) }}
                    </div>
                </div>

                <!-- Boutons -->
                <div class="form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.history.back()">
                        <i class="fas fa-arrow-left"></i> <span>Annuler</span>
                    </button>
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <span>Confirmer le rendez-vous</span> <i class="fas fa-check-circle"></i>
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const ENDPOINT_LOCATION_LATEST = '{{ path('api_patient_location_latest') }}';
    const ENDPOINT_LOCATION_SAVE = '{{ path('api_patient_location_save') }}';
    const ENDPOINT_RECOMMENDATION = '{{ path('api_rdv_recommendation_nearest') }}';

    const medecinsData = {{ medecins_json|default([])|json_encode|raw }};
    const medecinsById = {};
    medecinsData.forEach(m => medecinsById[m.id] = m);

    const searchInput = document.getElementById('searchDoctor');
    const medecinSelect = document.getElementById('medecinSelect') || document.querySelector('select[name$="[medecin]"]');
    const dropdownList = document.getElementById('dropdownList');
    const doctorDetailsCard = document.getElementById('doctorDetailsCard');
    const noResults = document.getElementById('noResults');
    const dateInput = document.getElementById('dateInput') || document.querySelector('input[name$="[dateRdv]"]');
    const timeInput = document.getElementById('timeInput') || document.querySelector('input[name$="[heureRdv]"]');
    const reasonInput = document.getElementById('reasonInput');
    const form = document.getElementById('rdvForm');
    const submitBtn = document.getElementById('submitBtn');
    const dateError = document.getElementById('dateError');
    const timeError = document.getElementById('timeError');
    const recommendationStatus = document.getElementById('recommendationStatus');
    const recommendationList = document.getElementById('recommendationList');
    const refreshRecommendationsBtn = document.getElementById('refreshRecommendationsBtn');
    const askGeoBtn = document.getElementById('askGeoBtn');

    let selectedMedecinId = null;

    function setRecommendationStatus(message) {
        if (recommendationStatus) {
            recommendationStatus.textContent = message;
        }
    }

    function appendRecommendationDebug(message) {
        setRecommendationStatus(message);
    }

    /* === Fonction pour afficher la liste déroulante === */
    function renderDropdown(filteredMedecins) {
        dropdownList.innerHTML = '';
        
        if (filteredMedecins.length === 0) {
            noResults.classList.add('show');
            dropdownList.classList.remove('show');
            searchInput.classList.remove('active');
            return;
        }
        
        noResults.classList.remove('show');
        
        filteredMedecins.forEach(med => {
            const item = document.createElement('div');
            item.className = 'dropdown-item';
            if (selectedMedecinId == med.id) {
                item.classList.add('selected');
            }
            
            const initials = ((med.prenom||'').charAt(0) + (med.nom||'').charAt(0)).toUpperCase();
            
            item.innerHTML = `
                <div class="dropdown-item-icon">${initials || '👨‍⚕️'}</div>
                <div class="dropdown-item-content">
                    <div class="dropdown-item-name">Dr. ${med.prenom || ''} ${med.nom || ''}</div>
                    <div class="dropdown-item-specialty">${med.specialite || 'Généraliste'}</div>
                </div>
            `;
            
            item.addEventListener('click', () => selectMedecin(med));
            dropdownList.appendChild(item);
        });
        
        dropdownList.classList.add('show');
        searchInput.classList.add('active');
    }

    function renderRecommendations(items) {
        recommendationList.innerHTML = '';

        if (!Array.isArray(items) || items.length === 0) {
            recommendationStatus.textContent = 'Aucun médecin proche trouvé (vérifiez les adresses cabinet).';
            return;
        }

        recommendationStatus.textContent = `Top ${items.length} médecin(s) proches de vous`;

        items.forEach(item => {
            const med = medecinsById[item.id];
            if (!med) {
                return;
            }

            const card = document.createElement('div');
            card.className = 'recommendation-card';
            card.innerHTML = `
                <div class="recommendation-name">Dr. ${med.prenom || ''} ${med.nom || ''}</div>
                <div class="recommendation-specialty">${med.specialite || 'Généraliste'}</div>
                <div class="recommendation-distance"><i class="fas fa-route"></i> ${Number(item.distance_km).toFixed(2)} km</div>
            `;

            card.addEventListener('click', function() {
                selectMedecin(med);
                searchInput.focus();
            });

            recommendationList.appendChild(card);
        });
    }

    async function hasLatestPatientLocation() {
        try {
            const response = await fetch(ENDPOINT_LOCATION_LATEST, {
                method: 'GET',
                headers: { 'Accept': 'application/json' },
                credentials: 'same-origin',
            });
            if (!response.ok) {
                return false;
            }
            const data = await response.json();
            return !!(data && data.success && data.location);
        } catch (e) {
            return false;
        }
    }

    async function requestAndSavePatientLocation() {
        if (!('geolocation' in navigator)) {
            recommendationStatus.textContent = 'Géolocalisation non supportée par ce navigateur.';
            return false;
        }
        if (!window.isSecureContext) {
            recommendationStatus.textContent = 'La géolocalisation nécessite HTTPS (ou localhost).';
            return false;
        }

        recommendationStatus.textContent = 'Demande de permission de localisation...';
        try {
            const position = await new Promise((resolve, reject) => {
                navigator.geolocation.getCurrentPosition(resolve, reject, {
                    enableHighAccuracy: true,
                    timeout: 10000,
                    maximumAge: 0,
                });
            });

            const saveUrl = new URL(ENDPOINT_LOCATION_SAVE, window.location.origin).toString();
            const saveResponse = await fetch(saveUrl, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                },
                body: JSON.stringify({
                    latitude: position.coords.latitude,
                    longitude: position.coords.longitude,
                    accuracy: position.coords.accuracy,
                }),
            });

            if (!saveResponse.ok) {
                recommendationStatus.textContent = 'Position détectée mais non enregistrée.';
                return false;
            }

            return true;
        } catch (error) {
            if (error && error.code === 1) {
                recommendationStatus.textContent = 'Permission refusée. Activez la localisation pour voir les médecins proches.';
                return false;
            }
            recommendationStatus.textContent = 'Impossible de récupérer votre position.';
            return false;
        }
    }

    async function ensurePatientLocation() {
        const hasLocation = await hasLatestPatientLocation();
        if (hasLocation) {
            return true;
        }
        return await requestAndSavePatientLocation();
    }

    async function loadNearbyRecommendations() {
        recommendationStatus.textContent = 'Chargement des recommandations...';
        recommendationList.innerHTML = '';
        let timer = null;

        try {
            const ready = await ensurePatientLocation();
            if (!ready) {
                return;
            }

            recommendationStatus.textContent = 'Recherche des médecins proches...';
            const controller = new AbortController();
            timer = setTimeout(() => controller.abort(), 12000);
            const response = await fetch(`${ENDPOINT_RECOMMENDATION}?limit=3&max_km=25`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' },
                credentials: 'same-origin',
                signal: controller.signal,
            });
            let data = null;
            try {
                data = await response.json();
            } catch (e) {
                recommendationStatus.textContent = 'Réponse API invalide (JSON).';
                return;
            }

            if (!response.ok || !data.success) {
                recommendationStatus.textContent = data.error || 'Recommandation indisponible pour le moment.';
                return;
            }

            renderRecommendations(data.recommendations || []);
            if (data.used_distance_fallback) {
                const fallbackKm = Number(data.fallback_max_km || 60);
                recommendationStatus.textContent = `Top ${(data.recommendations || []).length} médecin(s) proches (rayon étendu à ${fallbackKm} km)`;
            }
        } catch (error) {
            recommendationStatus.textContent = (error && error.name === 'AbortError')
                ? 'Recommandation trop lente (timeout). Vérifiez les adresses cabinet.'
                : 'Impossible de charger les recommandations.';
        } finally {
            if (timer) {
                clearTimeout(timer);
            }
        }
    }

    // Bind immediat des boutons (anti-blocage si une erreur JS survient plus bas).
    if (refreshRecommendationsBtn) {
        refreshRecommendationsBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            setRecommendationStatus('Rafraichissement...');
            loadNearbyRecommendations();
        });
    }
    if (askGeoBtn) {
        askGeoBtn.addEventListener('click', async function(e) {
            e.preventDefault();
            e.stopPropagation();
            setRecommendationStatus('Activation position...');
            const ok = await requestAndSavePatientLocation();
            if (ok) {
                await loadNearbyRecommendations();
            }
        });
    }

    /* === Fonction pour sélectionner un médecin === */
    function selectMedecin(med) {
        selectedMedecinId = med.id;
        if (!medecinSelect) {
            appendRecommendationDebug('Champ medecin introuvable dans le formulaire.');
            return;
        }

        medecinSelect.value = String(med.id);
        if (searchInput) {
            searchInput.value = `Dr. ${med.prenom || ''} ${med.nom || ''} - ${med.specialite || 'Généraliste'}`;
        }
        
        dropdownList.classList.remove('show');
        if (searchInput) {
            searchInput.classList.remove('active');
        }
        
        // Afficher les détails
        const doctorNameEl = document.getElementById('doctorName');
        const doctorSpecialtyEl = document.getElementById('doctorSpecialty');
        const doctorExperienceEl = document.getElementById('doctorExperience');
        const doctorGradeEl = document.getElementById('doctorGrade');
        const doctorEstablishmentEl = document.getElementById('doctorEstablishment');
        const doctorAvatarEl = document.getElementById('doctorAvatar');

        if (doctorNameEl) doctorNameEl.textContent = `Dr. ${med.prenom || ''} ${med.nom || ''}`.trim();
        if (doctorSpecialtyEl) doctorSpecialtyEl.textContent = med.specialite || 'Généraliste';
        if (doctorExperienceEl) doctorExperienceEl.textContent = med.anneeExperience ? `${med.anneeExperience} an${med.anneeExperience>1?'s':''}` : '-';
        if (doctorGradeEl) doctorGradeEl.textContent = med.grade || '-';
        if (doctorEstablishmentEl) doctorEstablishmentEl.textContent = med.nomEtablissement || '-';
        
        const initials = ((med.prenom||'').charAt(0) + (med.nom||'').charAt(0)).toUpperCase();
        if (doctorAvatarEl) doctorAvatarEl.textContent = initials || '👨‍⚕️';
        
        doctorDetailsCard.classList.add('show');
        updateTimeline(1);
    }

    /* === Recherche en temps réel === */
    searchInput.addEventListener('input', function() {
        const term = this.value.toLowerCase().trim();
        
        // Si on efface complètement, réinitialiser
        if (term === '' && selectedMedecinId) {
            selectedMedecinId = null;
            medecinSelect.value = '';
            doctorDetailsCard.classList.remove('show');
        }
        
        const filtered = medecinsData.filter(med => {
            const text = `${med.nom || ''} ${med.prenom || ''} ${med.specialite || ''}`.toLowerCase();
            return text.includes(term);
        });
        
        renderDropdown(filtered);
    });

    /* === Afficher la liste au focus === */
    searchInput.addEventListener('focus', function() {
        const term = this.value.toLowerCase().trim();
        
        // Si déjà sélectionné, ne pas afficher la liste
        if (selectedMedecinId && term !== '') {
            return;
        }
        
        const filtered = medecinsData.filter(med => {
            const text = `${med.nom || ''} ${med.prenom || ''} ${med.specialite || ''}`.toLowerCase();
            return text.includes(term);
        });
        
        renderDropdown(filtered);
    });

    /* === Fermer la liste en cliquant ailleurs === */
    document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !dropdownList.contains(e.target)) {
            dropdownList.classList.remove('show');
            searchInput.classList.remove('active');
        }
    });


    /* === Date ≥ aujourd'hui et week-end bloqués === */
    const today = new Date();
    today.setHours(0,0,0,0);
    if (dateInput) {
        dateInput.min = today.toISOString().split('T')[0];

        dateInput.addEventListener('change', function() {
            const selectedDate = new Date(this.value);
            selectedDate.setHours(0,0,0,0);

            if(selectedDate < today) {
                if (dateError) {
                    dateError.textContent = "La date doit être à partir d'aujourd'hui.";
                    dateError.style.display = 'flex';
                }
                this.value = '';
                return;
            }
            const day = selectedDate.getDay();
            if(day === 0 || day === 6){
                if (dateError) {
                    dateError.textContent = 'Les rendez-vous ne sont pas disponibles le week-end.';
                    dateError.style.display = 'flex';
                }
                this.value = '';
                return;
            }
            if (dateError) {
                dateError.style.display = 'none';
            }
            updateTimeline(2);
        });
    } else {
    }

    /* === Heure 09:00 → 17:00 === */
    if (timeInput) {
        timeInput.addEventListener('change', function() {
            if(!this.value) return;
            const [h,m] = this.value.split(':').map(Number);
            if(h < 9 || h > 17 || (h === 17 && m > 0)){
                if (timeError) {
                    timeError.textContent = "L'heure doit être entre 09:00 et 17:00.";
                    timeError.style.display = 'flex';
                }
                this.value = '';
                return;
            }
            if (timeError) {
                timeError.style.display = 'none';
            }
            updateTimeline(3);
        });
    } else {
    }

    /* === Motif === */
    if (reasonInput) {
        reasonInput.addEventListener('input', function() {
            if(this.value.trim()) {
                updateTimeline(4);
            }
        });
    }

    /* === Mise à jour de la timeline === */
    function updateTimeline(step) {
        const steps = document.querySelectorAll('.timeline-step');
        steps.forEach((s, i) => {
            if(i < step) {
                s.classList.add('completed');
                s.classList.remove('active');
            } else if(i === step) {
                s.classList.add('active');
                s.classList.remove('completed');
            } else {
                s.classList.remove('active', 'completed');
            }
        });
    }

    /* === Validation finale formulaire === */
    if (form) {
        form.addEventListener('submit', function(e){
            let hasError = false;
            
            if(!dateInput || !dateInput.value){ 
                if (dateError) {
                    dateError.textContent='Veuillez choisir une date valide.'; 
                    dateError.style.display='flex'; 
                }
                hasError=true; 
            }
            
            if(!timeInput || !timeInput.value){ 
                if (timeError) {
                    timeError.textContent='Veuillez choisir une heure valide.'; 
                    timeError.style.display='flex'; 
                }
                hasError=true; 
            }
            
            if(!medecinSelect || !medecinSelect.value || medecinSelect.value==='0'){ 
                alert('⚠️ Veuillez sélectionner un médecin'); 
                if (searchInput) {
                    searchInput.focus(); 
                }
                hasError=true; 
            }
            
            if(hasError){ 
                e.preventDefault(); 
                return false; 
            }
            
            if (submitBtn) {
                submitBtn.innerHTML='<i class="fas fa-spinner fa-spin"></i> <span>Traitement en cours...</span>';
                submitBtn.disabled=true;
            }
        });
    } else {
    }

    loadNearbyRecommendations();

    console.log('🏥 MEDINOVA - Formulaire de rendez-vous avec recherche interactive chargé!');
    console.log(`📊 ${medecinsData.length} médecins disponibles`);
});
</script>
{% endblock %}
