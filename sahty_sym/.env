###> recaptcha ###
# Obtenez ces clés depuis https://www.google.com/recaptcha/admin/create
RECAPTCHA_SITE_KEY=change_me
RECAPTCHA_SECRET_KEY=change_me
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ENABLED=1
###< recaptcha ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
 DATABASE_URL="mysql://root@127.0.0.1:3306/sahty?serverVersion=8.0.32"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
#DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
# For development: use sync to send emails immediately
# For production: use doctrine with a background worker (php bin/console messenger:consume async)
MESSENGER_TRANSPORT_DSN=sync://
###< symfony/messenger ###

###> symfony/mailer ###
# Gmail avec app password (2FA)
# 1. Allez: https://myaccount.google.com/apppasswords
# 2. Sélectionnez Mail + Windows
# 3. Copiez le password Google (16 caractères)
# 4. IMPORTANT: Enlever les espaces du password!
# Exemple: "caoc szvo ppxr tnkv" → "caocszovppxrtnkv"
# Format correct : smtps://email:password@smtp.gmail.com:465
# Mot de passe app Google - SI LE COMPTE A LA 2FA CORRECTEMENT ACTIVÉE
# MAILER_DSN="smtps://maramouerghi1234@gmail.com:APP_PASSWORD@smtp.gmail.com:465"

# DÉVELOPPEMENT - Transport test qui ne fait rien mais ne génère pas d'erreur
# Les emails apparaîtront comme "envoyés" dans l'interface
MAILER_DSN="smtps://maramouerghi1234@gmail.com:nklezfflmixwkmfp@smtp.gmail.com:465"
###< symfony/mailer ###

###> symfony/google-mailer ###
