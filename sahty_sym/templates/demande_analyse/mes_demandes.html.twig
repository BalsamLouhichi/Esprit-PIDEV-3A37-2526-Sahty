<script>
document.addEventListener('DOMContentLoaded', function() {
    const aiModalElement = document.getElementById('ai-result-modal');
    const aiModal = aiModalElement ? new bootstrap.Modal(aiModalElement) : null;
    const aiResultError = document.getElementById('aiResultError');
    const aiResultStatus = document.getElementById('aiResultStatus');
    const aiResultDanger = document.getElementById('aiResultDanger');
    const aiResultModel = document.getElementById('aiResultModel');
    const aiResultUpdated = document.getElementById('aiResultUpdated');
    const aiResultSummary = document.getElementById('aiResultSummary');
    const aiResultRecCount = document.getElementById('aiResultRecCount');
    const aiResultRecommendations = document.getElementById('aiResultRecommendations');

    const setPillVariant = (element, variant) => {
        if (!element) {
            return;
        }

        element.className = `ai-pill ai-pill-${variant}`;
    };

    const normalizeToken = (value) => (value || '').toString().trim().toLowerCase();

    const mapStatusLabel = (status) => {
        const token = normalizeToken(status);
        if (token === 'done') return 'Terminee';
        if (token === 'failed') return 'Echec';
        if (token === 'pending') return 'En attente';
        if (token === 'processing') return 'En cours';
        if (token === 'queued') return 'File d attente';
        return status || '-';
    };

    const mapStatusVariant = (status) => {
        const token = normalizeToken(status);
        if (token === 'done') return 'success';
        if (token === 'failed') return 'danger';
        if (token === 'pending') return 'warning';
        if (token === 'processing' || token === 'queued') return 'info';
        return 'neutral';
    };

    const mapDangerVariant = (level, score) => {
        const token = normalizeToken(level);
        const numericScore = Number(score);
        const hasScore = !Number.isNaN(numericScore);

        if (token.includes('critical') || token.includes('critique') || (hasScore && numericScore >= 85)) {
            return 'danger';
        }

        if (token.includes('high') || token.includes('haut') || (hasScore && numericScore >= 65)) {
            return 'warning';
        }

        if (token.includes('low') || token.includes('bas') || (hasScore && numericScore <= 35)) {
            return 'success';
        }

        if (token.includes('medium') || token.includes('modere') || (hasScore && numericScore > 35 && numericScore < 65)) {
            return 'info';
        }

        return 'neutral';
    };

    const renderRecommendations = (recommendations, options = {}) => {
        if (!aiResultRecommendations || !aiResultRecCount) {
            return;
        }

        const isLoading = options.loading === true;
        aiResultRecommendations.innerHTML = '';

        if (isLoading) {
            aiResultRecCount.textContent = '0';
            aiResultRecommendations.innerHTML = '<li class="ai-rec-item ai-rec-item-muted"><i class="bi bi-hourglass-split ai-rec-icon"></i><span>Chargement...</span></li>';
            return;
        }

        const list = Array.isArray(recommendations) ? recommendations : [];
        if (list.length === 0) {
            aiResultRecCount.textContent = '0';
            aiResultRecommendations.innerHTML = '<li class="ai-rec-item ai-rec-item-muted"><i class="bi bi-info-circle ai-rec-icon"></i><span>Aucune recommandation disponible.</span></li>';
            return;
        }

        aiResultRecCount.textContent = String(list.length);
        list.forEach((item) => {
            const li = document.createElement('li');
            li.className = 'ai-rec-item';

            const icon = document.createElement('i');
            icon.className = 'bi bi-check-circle-fill ai-rec-icon';

            const text = document.createElement('span');
            text.textContent = item;

            li.appendChild(icon);
            li.appendChild(text);
            aiResultRecommendations.appendChild(li);
        });
    };

    const setAiModalLoading = () => {
        if (!aiModal) {
            return;
        }

        aiResultError.classList.add('d-none');
        aiResultError.textContent = '';
        aiResultStatus.textContent = 'Chargement';
        setPillVariant(aiResultStatus, 'info');
        aiResultDanger.textContent = '-';
        setPillVariant(aiResultDanger, 'neutral');
        aiResultModel.textContent = '-';
        aiResultUpdated.textContent = '-';
        aiResultSummary.textContent = 'Chargement de l interpretation IA...';
        renderRecommendations([], { loading: true });
    };

    const showAiModalError = (message) => {
        if (!aiModal) {
            alert(message);
            return;
        }

        aiResultError.textContent = message;
        aiResultError.classList.remove('d-none');
        aiResultStatus.textContent = 'Indisponible';
        setPillVariant(aiResultStatus, 'danger');
        aiResultDanger.textContent = '-';
        setPillVariant(aiResultDanger, 'neutral');
        aiResultModel.textContent = '-';
        aiResultUpdated.textContent = '-';
        aiResultSummary.textContent = message;
        renderRecommendations([]);
    };

    const showAiModalData = (payload) => {
        if (!aiModal) {
            return;
        }

        const dangerLevel = payload.danger_level || '-';
        const dangerScore = payload.danger_score;
        const dangerText = dangerScore !== null && dangerScore !== undefined && dangerScore !== ''
            ? `${dangerLevel} (${dangerScore}/100)`
            : dangerLevel;

        aiResultError.classList.add('d-none');
        aiResultError.textContent = '';
        aiResultStatus.textContent = mapStatusLabel(payload.ai_status || 'done');
        setPillVariant(aiResultStatus, mapStatusVariant(payload.ai_status || 'done'));
        aiResultDanger.textContent = dangerText;
        setPillVariant(aiResultDanger, mapDangerVariant(dangerLevel, dangerScore));
        aiResultModel.textContent = payload.model || 'N/A';
        aiResultUpdated.textContent = payload.updated_at || '-';
        aiResultSummary.textContent = payload.summary || 'Aucun resume IA.';

        const recommendations = Array.isArray(payload.recommendations) ? payload.recommendations : [];
        renderRecommendations(recommendations);
    };

    const initDemandesHandlers = function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        const deleteForms = document.querySelectorAll('form[action*="/delete"]');
        deleteForms.forEach(form => {
            form.addEventListener('submit', function(e) {
                if (!confirm('ÃŠtes-vous sÃ»r de vouloir supprimer cette demande ? Cette action est irrÃ©versible.')) {
                    e.preventDefault();
                }
            });
        });

        const medecinCells = document.querySelectorAll('.medecin-cell');
        medecinCells.forEach(cell => {
            const medecinDiv = cell.querySelector('.medecin-info');
            if (medecinDiv) {
                cell.addEventListener('mouseenter', function() {
                    this.style.cursor = 'help';
                });

                const medecinName = cell.querySelector('.fw-bold').textContent;
                const specialite = cell.querySelector('.text-muted')?.textContent || 'SpÃ©cialitÃ© non spÃ©cifiÃ©e';

                cell.setAttribute('title', `MÃ©decin: ${medecinName}\nSpÃ©cialitÃ©: ${specialite}`);
                new bootstrap.Tooltip(cell, {
                    placement: 'top',
                    trigger: 'hover'
                });
            }
        });

        const resultButtons = document.querySelectorAll('.js-result-pdf');
        resultButtons.forEach(button => {
            button.addEventListener('click', function() {
                const status = this.getAttribute('data-status');
                const pdfUrl = this.getAttribute('data-pdf');

                if (status === 'en_attente') {
                    alert('Le resultat n\'est pas encore disponible.');
                    return;
                }

                if (!pdfUrl) {
                    alert('Aucun resultat PDF n\'est disponible pour cette demande.');
                    return;
                }

                window.open(pdfUrl, '_blank', 'noopener');
            });
        });

        const aiButtons = document.querySelectorAll('.js-ai-result');
        aiButtons.forEach(button => {
            button.addEventListener('click', function() {
                const status = this.getAttribute('data-status');
                const aiUrl = this.getAttribute('data-ai-url');

                if (status === 'en_attente') {
                    alert('Le resultat n\'est pas encore disponible.');
                    return;
                }

                if (!aiUrl) {
                    alert('Aucun lien IA disponible pour cette demande.');
                    return;
                }

                if (aiModal) {
                    setAiModalLoading();
                    aiModal.show();
                }

                fetch(aiUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(async (response) => {
                        let data = {};
                        try {
                            data = await response.json();
                        } catch (_) {
                            data = {};
                        }

                        if (!response.ok || data.ok === false) {
                            throw new Error(data.message || 'Interpretation IA indisponible pour cette demande.');
                        }

                        return data;
                    })
                    .then((data) => {
                        showAiModalData(data);
                    })
                    .catch((error) => {
                        showAiModalError(error.message || 'Erreur de chargement IA.');
                    });
            });
        });
    };

    const filterForm = document.getElementById('mes-demandes-filter');
    const filterSelect = document.getElementById('type_bilan');
    const resultsContainer = document.getElementById('mes-demandes-results');
    const countContainer = document.getElementById('mes-demandes-count');
    let debounceTimer;

    const fetchResults = () => {
        if (!filterForm) return;
        const params = new URLSearchParams(new FormData(filterForm));
        const url = `{{ path('app_demande_analyse_mes_demandes_filter') }}?${params.toString()}`;

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(response => response.json())
            .then(data => {
                if (resultsContainer) {
                    resultsContainer.innerHTML = data.html;
                }
                if (countContainer) {
                    countContainer.innerHTML = data.count_text;
                }
                initDemandesHandlers();
            })
            .catch(() => {
                if (resultsContainer) {
                    resultsContainer.innerHTML = '<div class="row"><div class="col-12 text-center text-muted">Erreur de chargement.</div></div>';
                }
            });
    };

    const scheduleFetch = () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(fetchResults, 250);
    };

    if (filterSelect) {
        filterSelect.addEventListener('change', scheduleFetch);
    }

    initDemandesHandlers();
    // Animation pour les cartes
    const cards = document.querySelectorAll('.demande-card');
    cards.forEach((card, index) => {
        card.style.animationDelay = `${index * 0.1}s`;
        card.classList.add('animate__animated', 'animate__fadeInUp');
    });
    
    // Mode test indicator
    {% if test_mode is defined and test_mode %}
        const testIndicator = document.querySelector('.test-mode-indicator');
        if (testIndicator) {
            testIndicator.addEventListener('click', function() {
                alert('Mode test activÃ© :\n\n' +
                      'â€¢ Pas besoin de connexion\n' +
                      'â€¢ Utilisation d\'un patient par dÃ©faut\n' +
                      'â€¢ Les donnÃ©es sont sauvegardÃ©es normalement\n' +
                      'â€¢ En production, l\'authentification sera requise');
            });
        }
    {% endif %}
    
});
</script>

 </div>
</body>
</html>
