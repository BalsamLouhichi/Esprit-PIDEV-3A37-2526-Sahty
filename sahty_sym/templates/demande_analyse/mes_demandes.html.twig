                    <ul id="aiResultRecommendations" class="ai-recommendations"></ul>
                </section>

                <p class="ai-disclaimer mt-3">
                    Ces informations sont indicatives et doivent etre validees par un professionnel de sante.
                </p>
            </div>
        </div>
    </div>
</div>

