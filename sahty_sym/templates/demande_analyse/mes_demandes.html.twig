<body>
<div id="mes-demandes-page">

{# âœ… Topbar + Navbar #}
{% include 'partials/header.html.twig' with { header_compact: false } %}

{# Mode test indicator #}
{% if test_mode is defined and test_mode %}
    <div class="test-mode-indicator">
        <i class="fas fa-flask me-1"></i> MODE TEST
    </div>
{% endif %}

{# ===========================
   Header
   =========================== #}
<div class="container-fluid demandes-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
