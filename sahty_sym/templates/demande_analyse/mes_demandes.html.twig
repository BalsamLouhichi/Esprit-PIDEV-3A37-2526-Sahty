<script>

document.addEventListener('DOMContentLoaded', function() {

    const aiModalElement = document.getElementById('ai-result-modal');

    const aiModal = aiModalElement ?new bootstrap.Modal(aiModalElement) : null;

    const aiResultError = document.getElementById('aiResultError');

    const aiResultStatus = document.getElementById('aiResultStatus');

    const aiResultDanger = document.getElementById('aiResultDanger');

    const aiResultModel = document.getElementById('aiResultModel');

    const aiResultUpdated = document.getElementById('aiResultUpdated');

    const aiResultSummary = document.getElementById('aiResultSummary');
    const aiResultEvidenceCount = document.getElementById('aiResultEvidenceCount');
    const aiResultEvidence = document.getElementById('aiResultEvidence');
    const aiResultRecCount = document.getElementById('aiResultRecCount');

    const aiResultRecommendations = document.getElementById('aiResultRecommendations');
    const qaModalElement = document.getElementById('ai-patient-qa-modal');
    const qaModal = qaModalElement ? new bootstrap.Modal(qaModalElement) : null;
    const qaError = document.getElementById('aiQaError');
    const qaQuestion = document.getElementById('aiQaQuestion');
    const qaAskBtn = document.getElementById('aiQaAskBtn');
    const qaLoading = document.getElementById('aiQaLoading');
    const qaResultWrap = document.getElementById('aiQaResultWrap');
    const qaAnswer = document.getElementById('aiQaAnswer');
    const qaSafety = document.getElementById('aiQaSafety');
    const qaDisclaimer = document.getElementById('aiQaDisclaimer');
    const qaSuggestionButtons = document.querySelectorAll('.js-qa-suggestion');
    let currentQaUrl = '';
    let iaMetricGlossary = {};

    const setPillVariant = (element, variant) => {

        if (!element) {

            return;

        }



        element.className = `ai-pill ai-pill-${variant}`;

    };



    const normalizeToken = (value) => (value || '').toString().trim().toLowerCase();
    const normalizeGlossaryKey = (value) => String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '');

    const normalizeMetricGlossary = (payload) => {
        if (!payload || typeof payload !== 'object' || Array.isArray(payload)) return {};
        const normalized = {};
        Object.entries(payload).forEach(([name, description]) => {
            if (typeof description !== 'string') return;
            const cleanName = String(name || '').trim();
            const cleanDescription = description.replace(/\s+/g, ' ').trim();
            if (!cleanName || !cleanDescription) return;
            normalized[cleanName] = cleanDescription;
        });
        return normalized;
    };

    const findMetricDescription = (item) => {
        if (!iaMetricGlossary || Object.keys(iaMetricGlossary).length === 0) return '';
        const metricName = String(item.metric_name || '').trim();
        const line = String(item.line || '').trim();

        const directCandidates = [];
        if (metricName) directCandidates.push(metricName);
        const inferred = (() => {
            const m = line.match(/^([^:]{2,80})\s*:/);
            return m ? m[1].trim() : '';
        })();
        if (inferred) directCandidates.push(inferred);

        for (const candidate of directCandidates) {
            if (iaMetricGlossary[candidate]) return iaMetricGlossary[candidate];
        }

        const normalizedCandidates = directCandidates
            .map(normalizeGlossaryKey)
            .filter((v) => v !== '');
        const entries = Object.entries(iaMetricGlossary);
        for (const [name, description] of entries) {
            const key = normalizeGlossaryKey(name);
            if (key === '') continue;
            if (normalizedCandidates.includes(key)) return description;
        }

        const normalizedLine = normalizeGlossaryKey(line);
        if (normalizedLine === '') return '';
        const ordered = entries
            .map(([name, description]) => ({ key: normalizeGlossaryKey(name), description }))
            .filter((e) => e.key !== '')
            .sort((a, b) => b.key.length - a.key.length);
        for (const entry of ordered) {
            if (normalizedLine.includes(entry.key)) return entry.description;
        }

        return '';
    };

    const mapStatusLabel = (status) => {

        const token = normalizeToken(status);

        if (token === 'done') return 'Terminee';

        if (token === 'failed') return 'Echec';

        if (token === 'pending') return 'En attente';

        if (token === 'processing') return 'En cours';

        if (token === 'queued') return 'File d attente';

        return status || '-';

    };



    const mapStatusVariant = (status) => {

        const token = normalizeToken(status);

        if (token === 'done') return 'success';

        if (token === 'failed') return 'danger';

        if (token === 'pending') return 'warning';

        if (token === 'processing' || token === 'queued') return 'info';

        return 'neutral';

    };



    const mapDangerVariant = (level, score) => {

        const token = normalizeToken(level);

        const numericScore = Number(score);

        const hasScore = !Number.isNaN(numericScore);



        if (token.includes('critical') || token.includes('critique') || (hasScore && numericScore >= 85)) {

            return 'danger';

        }



        if (token.includes('high') || token.includes('haut') || token.includes('eleve') || (hasScore && numericScore >= 65)) {
            return 'warning';

        }



        if (token.includes('low') || token.includes('bas') || token.includes('faible') || (hasScore && numericScore <= 35)) {
            return 'success';

        }



        if (token.includes('medium') || token.includes('modere') || token.includes('moyen') || (hasScore && numericScore > 35 && numericScore < 65)) {
            return 'info';

        }



        return 'neutral';

    };



    const renderRecommendations = (recommendations, options = {}) => {

        if (!aiResultRecommendations || !aiResultRecCount) {

            return;

        }



        const isLoading = options.loading === true;

        aiResultRecommendations.innerHTML = '';



        if (isLoading) {

            aiResultRecCount.textContent = '0';

            aiResultRecommendations.innerHTML = '<li class="ai-rec-item ai-rec-item-muted"><i class="bi bi-hourglass-split ai-rec-icon"></i><span>Chargement...</span></li>';

            return;

        }



        const list = Array.isArray(recommendations) ?recommendations : [];

        if (list.length === 0) {

            aiResultRecCount.textContent = '0';

            aiResultRecommendations.innerHTML = '<li class="ai-rec-item ai-rec-item-muted"><i class="bi bi-info-circle ai-rec-icon"></i><span>Aucune recommandation disponible.</span></li>';

            return;

        }



        aiResultRecCount.textContent = String(list.length);

        list.forEach((item) => {

            const li = document.createElement('li');

            li.className = 'ai-rec-item';



            const icon = document.createElement('i');

            icon.className = 'bi bi-check-circle-fill ai-rec-icon';



            const text = document.createElement('span');

            text.textContent = item;



            li.appendChild(icon);

            li.appendChild(text);

            aiResultRecommendations.appendChild(li);

        });

    };

    const renderEvidence = (evidenceLines, options = {}) => {
        if (!aiResultEvidence || !aiResultEvidenceCount) {
            return;
        }

        const isLoading = options.loading === true;
        aiResultEvidence.innerHTML = '';

        if (isLoading) {
            aiResultEvidenceCount.textContent = '0';
            aiResultEvidence.innerHTML = '<li class="ai-evidence-item ai-rec-item-muted"><i class="bi bi-hourglass-split ai-evidence-icon"></i><span>Chargement...</span></li>';
            return;
        }

        const computePriority = (item) => {
            const level = String(item.level || '').toLowerCase();
            if (item.is_critical || level === 'critical') return 0;
            if (level === 'high' || level === 'eleve' || level === 'elevated') return 1;
            if (level === 'low' || level === 'bas' || level === 'faible') return 2;
            return 3;
        };

        const normalizeEvidenceItem = (item) => {
            if (item && typeof item === 'object' && !Array.isArray(item)) {
                const line = String(item.line || '').trim();
                const level = String(item.level || '').trim().toLowerCase();
                const isCritical = Boolean(item.is_critical) || level === 'critical' || /\bCRITIQUE\b/i.test(line);
                const metricName = String(item.metric_name || item.name || item.metric || '').trim();
                return { line, metric_name: metricName, level, is_critical: isCritical, priority: Number(item.priority ?? computePriority({ level, is_critical: isCritical })) };
            }

            const line = String(item || '').trim();
            const token = line.toUpperCase();
            const isCritical = /\bCRITIQUE\b|\bCRITICAL\b/.test(token);
            const level = isCritical ? 'critical' : (/\bELEVE\b|\bHIGH\b/.test(token) ? 'high' : (/\bBAS\b|\bLOW\b/.test(token) ? 'low' : 'unknown'));
            const m = line.match(/^([^:]{2,80})\s*:/);
            const metricName = m ? m[1].trim() : '';
            return { line, metric_name: metricName, level, is_critical: isCritical, priority: computePriority({ level, is_critical: isCritical }) };
        };

        const list = Array.isArray(evidenceLines)
            ? evidenceLines.map(normalizeEvidenceItem).filter((item) => item.line !== '').sort((a, b) => a.priority - b.priority)
            : [];
        if (list.length === 0) {
            aiResultEvidenceCount.textContent = '1';
            aiResultEvidence.innerHTML = '<li class="ai-evidence-item ai-rec-item-muted"><i class="bi bi-quote ai-evidence-icon"></i><span>Aucune valeur hors norme detaillee n est fournie.</span></li>';
            return;
        }

        const appendEvidenceText = (target, text) => {
            const parts = String(text || '').split(/(\bELEVE\b|\bBAS\b|\bMOYEN\b|\bCRITIQUE\b)/gi);
            parts.forEach((part) => {
                if (['ELEVE', 'BAS', 'MOYEN', 'CRITIQUE'].includes(part.toUpperCase())) {
                    const strong = document.createElement('strong');
                    strong.textContent = part;
                    target.appendChild(strong);
                    return;
                }
                target.appendChild(document.createTextNode(part));
            });
        };

        aiResultEvidenceCount.textContent = String(list.length);
        list.forEach((line) => {
            const li = document.createElement('li');
            li.className = 'ai-evidence-item';

            const icon = document.createElement('i');
            icon.className = 'bi bi-quote ai-evidence-icon';

            const text = document.createElement('span');
            text.className = 'ai-evidence-line';
            appendEvidenceText(text, line.line);

            li.appendChild(icon);
            li.appendChild(text);

            const description = findMetricDescription(line) || 'Description indisponible pour ce parametre.';
            const help = document.createElement('details');
            help.className = 'metric-help';
            const summary = document.createElement('summary');
            const labelName = String(line.metric_name || '').trim() || 'ce parametre';
            summary.setAttribute('aria-label', 'Aide pour ' + labelName);
            summary.textContent = '?';
            const detail = document.createElement('div');
            detail.textContent = description;
            help.appendChild(summary);
            help.appendChild(detail);
            li.appendChild(help);

            if (line.is_critical) {
                const badge = document.createElement('span');
                badge.className = 'ai-evidence-badge-critical';
                badge.textContent = 'CRITIQUE';
                li.appendChild(badge);
            }
            aiResultEvidence.appendChild(li);
        });
    };

    const setAiModalLoading = () => {

        if (!aiModal) {

            return;

        }

        iaMetricGlossary = {};
        aiResultError.classList.add('d-none');

        aiResultError.textContent = '';

        aiResultStatus.textContent = 'Chargement';

        setPillVariant(aiResultStatus, 'info');

        aiResultDanger.textContent = '-';

        setPillVariant(aiResultDanger, 'neutral');

        aiResultModel.textContent = '-';

        aiResultUpdated.textContent = '-';

        aiResultSummary.textContent = 'Chargement de l interpretation IA...';
        renderEvidence([], { loading: true });
        renderRecommendations([], { loading: true });

    };



    const showAiModalError = (message) => {

        if (!aiModal) {

            alert(message);

            return;

        }

        iaMetricGlossary = {};
        aiResultError.textContent = message;

        aiResultError.classList.remove('d-none');

        aiResultStatus.textContent = 'Indisponible';

        setPillVariant(aiResultStatus, 'danger');

        aiResultDanger.textContent = '-';

        setPillVariant(aiResultDanger, 'neutral');

        aiResultModel.textContent = '-';

        aiResultUpdated.textContent = '-';

        aiResultSummary.textContent = message;
        renderEvidence([]);
        renderRecommendations([]);

    };



    const showAiModalData = (payload) => {

        if (!aiModal) {

            return;

        }

        iaMetricGlossary = normalizeMetricGlossary(payload.metric_glossary || {});
        const dangerLevel = payload.danger_level || '-';
        const dangerLevelLabel = payload.danger_level_label || payload.danger_level || '-';
        const dangerScore = payload.danger_score;

        const dangerText = dangerScore !== null && dangerScore !== undefined && dangerScore !== ''
            ? `${dangerLevelLabel} (${dangerScore}/100)`
            : dangerLevelLabel;



        aiResultError.classList.add('d-none');

        aiResultError.textContent = '';

        aiResultStatus.textContent = mapStatusLabel(payload.ai_status || 'done');

        setPillVariant(aiResultStatus, mapStatusVariant(payload.ai_status || 'done'));

        aiResultDanger.textContent = dangerText;

        setPillVariant(aiResultDanger, mapDangerVariant(dangerLevel, dangerScore));

        aiResultModel.textContent = payload.model || 'N/A';

        aiResultUpdated.textContent = payload.updated_at || '-';

        aiResultSummary.textContent = payload.summary || 'Aucun resume IA.';
        renderEvidence(payload.evidence_items || payload.evidence_lines || []);



        const recommendations = Array.isArray(payload.recommendations) ?payload.recommendations : [];

        renderRecommendations(recommendations);

    };

    const resetQaState = () => {
        if (qaError) {
            qaError.classList.add('d-none');
            qaError.textContent = '';
        }
        if (qaLoading) {
            qaLoading.classList.add('d-none');
        }
        if (qaResultWrap) {
            qaResultWrap.classList.add('d-none');
        }
        if (qaAnswer) {
            qaAnswer.textContent = '-';
        }
        if (qaSafety) {
            qaSafety.classList.add('d-none');
            qaSafety.textContent = '';
        }
        if (qaDisclaimer) {
            qaDisclaimer.textContent = '';
        }
    };

    const showQaError = (message) => {
        if (!qaError) {
            alert(message);
            return;
        }

        qaError.textContent = message;
        qaError.classList.remove('d-none');
        if (qaLoading) {
            qaLoading.classList.add('d-none');
        }
        if (qaResultWrap) {
            qaResultWrap.classList.add('d-none');
        }
    };

    const showQaLoading = () => {
        if (qaError) {
            qaError.classList.add('d-none');
            qaError.textContent = '';
        }
        if (qaLoading) {
            qaLoading.classList.remove('d-none');
        }
        if (qaResultWrap) {
            qaResultWrap.classList.add('d-none');
        }
    };

    const showQaData = (payload) => {
        if (qaLoading) {
            qaLoading.classList.add('d-none');
        }
        if (qaResultWrap) {
            qaResultWrap.classList.remove('d-none');
        }
        if (qaAnswer) {
            qaAnswer.textContent = payload.answer || 'Aucune reponse disponible.';
        }
        if (qaDisclaimer) {
            qaDisclaimer.textContent = payload.disclaimer || '';
        }
        if (qaSafety) {
            const safety = (payload.safety_notice || '').toString().trim();
            if (safety !== '') {
                qaSafety.textContent = safety;
                qaSafety.classList.remove('d-none');
            } else {
                qaSafety.classList.add('d-none');
                qaSafety.textContent = '';
            }
        }
    };

    const askQaQuestion = () => {
        if (!qaQuestion) {
            return;
        }

        const question = qaQuestion.value.trim();
        if (question === '') {
            showQaError('Veuillez saisir une question.');
            return;
        }

        if (!currentQaUrl) {
            showQaError('Aucun lien Q/R disponible pour cette demande.');
            return;
        }

        showQaLoading();

        fetch(currentQaUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
            },
            body: JSON.stringify({ question }),
        })
            .then(async (response) => {
                let data = {};
                try {
                    data = await response.json();
                } catch (_) {
                    data = {};
                }

                if (!response.ok || data.ok === false) {
                    throw new Error(data.message || 'Assistant patient indisponible.');
                }

                return data;
            })
            .then((data) => {
                showQaData(data);
            })
            .catch((error) => {
                showQaError(error.message || 'Erreur de chargement Q/R.');
            });
    };

    const initDemandesHandlers = function() {

        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));

        tooltipTriggerList.map(function (tooltipTriggerEl) {

            return new bootstrap.Tooltip(tooltipTriggerEl);

        });



        const deleteForms = document.querySelectorAll('form[action*="/delete"]');

        deleteForms.forEach(form => {

            form.addEventListener('submit', function(e) {
                if (!confirm('Êtes-vous sûr de vouloir supprimer cette demande ? Cette action est irréversible.')) {
                    e.preventDefault();

                }

            });

        });



        const medecinCells = document.querySelectorAll('.medecin-cell');

        medecinCells.forEach(cell => {

            const medecinDiv = cell.querySelector('.medecin-info');

            if (medecinDiv) {

                cell.addEventListener('mouseenter', function() {

                    this.style.cursor = 'help';

                });



                const medecinName = cell.querySelector('.fw-bold').textContent;
                const specialite = cell.querySelector('.text-muted')?.textContent || 'Spécialité non spécifiée';

                cell.setAttribute('title', `Médecin: ${medecinName}\nSpécialité: ${specialite}`);
                new bootstrap.Tooltip(cell, {

                    placement: 'top',

                    trigger: 'hover'

                });

            }

        });



        const resultButtons = document.querySelectorAll('.js-result-pdf');

        resultButtons.forEach(button => {

            button.addEventListener('click', function() {

                const status = this.getAttribute('data-status');

                const pdfUrl = this.getAttribute('data-pdf');



                if (status === 'en_attente') {

                    alert('Le resultat n\'est pas encore disponible.');

                    return;

                }



                if (!pdfUrl) {

                    alert('Aucun resultat PDF n\'est disponible pour cette demande.');

                    return;

                }



                window.open(pdfUrl, '_blank', 'noopener');

            });

        });



        const aiButtons = document.querySelectorAll('.js-ai-result');

        aiButtons.forEach(button => {

            button.addEventListener('click', function() {

                const status = this.getAttribute('data-status');

                const aiUrl = this.getAttribute('data-ai-url');



                if (status === 'en_attente') {

                    alert('Le resultat n\'est pas encore disponible.');

                    return;

                }



                if (!aiUrl) {

                    alert('Aucun lien IA disponible pour cette demande.');

                    return;

                }



                if (aiModal) {

                    setAiModalLoading();

                    aiModal.show();

                }



                fetch(aiUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })

                    .then(async (response) => {

                        let data = {};

                        try {

                            data = await response.json();

                        } catch (_) {

                            data = {};

                        }



                        if (!response.ok || data.ok === false) {

                            throw new Error(data.message || 'Interpretation IA indisponible pour cette demande.');

                        }



                        return data;

                    })

                    .then((data) => {

                        showAiModalData(data);

                    })

                    .catch((error) => {

                        showAiModalError(error.message || 'Erreur de chargement IA.');

                    });

            });

        });

        const qaButtons = document.querySelectorAll('.js-ai-qa');
        qaButtons.forEach(button => {
            button.addEventListener('click', function() {
                const status = this.getAttribute('data-status');
                const qaUrl = this.getAttribute('data-qa-url');

                if (status === 'en_attente') {
                    alert('Le resultat n est pas encore disponible.');
                    return;
                }

                if (!qaUrl) {
                    alert('Aucun lien Q/R disponible pour cette demande.');
                    return;
                }

                currentQaUrl = qaUrl;
                resetQaState();

                if (qaQuestion) {
                    qaQuestion.value = '';
                    qaQuestion.focus();
                }

                if (qaModal) {
                    qaModal.show();
                }
            });
        });
    };



    const filterForm = document.getElementById('mes-demandes-filter');

    const filterSelect = document.getElementById('type_bilan');

    const resultsContainer = document.getElementById('mes-demandes-results');

    const countContainer = document.getElementById('mes-demandes-count');

    let debounceTimer;



    const fetchResults = () => {

        if (!filterForm) return;

        const params = new URLSearchParams(new FormData(filterForm));

        const url = `{{ path('app_demande_analyse_mes_demandes_filter') }}?${params.toString()}`;



        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })

            .then(response => response.json())

            .then(data => {

                if (resultsContainer) {

                    resultsContainer.innerHTML = data.html;

                }

                if (countContainer) {

                    countContainer.innerHTML = data.count_text;

                }

                initDemandesHandlers();

            })

            .catch(() => {

                if (resultsContainer) {

                    resultsContainer.innerHTML = '<div class="row"><div class="col-12 text-center text-muted">Erreur de chargement.</div></div>';

                }

            });

    };



    const scheduleFetch = () => {

        clearTimeout(debounceTimer);

        debounceTimer = setTimeout(fetchResults, 250);

    };



    if (filterSelect) {

        filterSelect.addEventListener('change', scheduleFetch);

    }

    if (qaAskBtn) {
        qaAskBtn.addEventListener('click', askQaQuestion);
    }

    if (qaQuestion) {
        qaQuestion.addEventListener('keydown', function(event) {
            if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
                askQaQuestion();
            }
        });
    }

    qaSuggestionButtons.forEach((button) => {
        button.addEventListener('click', function() {
            const suggestion = (this.getAttribute('data-question') || '').trim();
            if (!qaQuestion) {
                return;
            }

            qaQuestion.value = suggestion;
            qaQuestion.focus();
        });
    });

    if (qaModalElement) {
        qaModalElement.addEventListener('hidden.bs.modal', function() {
            currentQaUrl = '';
            resetQaState();
        });
    }

    initDemandesHandlers();

    // Animation pour les cartes

    const cards = document.querySelectorAll('.demande-card');

    cards.forEach((card, index) => {

        card.style.animationDelay = `${index * 0.1}s`;

        card.classList.add('animate__animated', 'animate__fadeInUp');

    });

    

    // Mode test indicator

    {% if test_mode is defined and test_mode %}

        const testIndicator = document.querySelector('.test-mode-indicator');

        if (testIndicator) {

            testIndicator.addEventListener('click', function() {
                alert('Mode test activé :\n\n' +
                      '• Pas besoin de connexion\n' +
                      '• Utilisation d\'un patient par défaut\n' +
                      '• Les données sont sauvegardées normalement\n' +
                      '• En production, l\'authentification sera requise');
            });

        }

    {% endif %}

    

});

</script>



 </div>

</body>

</html>

