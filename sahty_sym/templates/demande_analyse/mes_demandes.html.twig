                    <a href="{{ path('app_labo_index') }}" class="btn btn-outline-primary btn-action">
                        <i class="fas fa-hospital"></i> Voir Laboratoires
                    </a>
                </div>
            </div>
        </div>

        {# Filtre par type de bilan #}
