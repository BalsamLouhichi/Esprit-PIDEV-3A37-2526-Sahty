{% extends 'base.html.twig' %}

{% block title %}{{ parapharmacie.nom }} - Détails{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .para-details-container {
            max-width: 1100px;
            margin: 2rem auto;
        }

        .para-card {
            border: 1px solid rgba(29, 93, 155, 0.15);
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.06);
        }

        .para-card-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            padding: 1.2rem 1.4rem;
        }

        .map-wrap {
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(29, 93, 155, 0.12);
            min-height: 380px;
        }

        .map-wrap iframe {
            width: 100%;
            height: 380px;
            border: 0;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container para-details-container">
    <div class="mb-3">
        <a href="{{ path('app_parapharmacie_produits') }}" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
    </div>

    <div class="para-card">
        <div class="para-card-header">
            <h2 class="mb-0">{{ parapharmacie.nom }}</h2>
        </div>
        <div class="p-4">
            <div class="row g-4">
                <div class="col-lg-5">
                    <h5 class="mb-3">Informations</h5>
                    <p class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i>{{ parapharmacie.adresse }}</p>
                    <p class="mb-2"><i class="fas fa-phone me-2 text-primary"></i>{{ parapharmacie.telephone }}</p>
                    <p class="mb-3">
                        <i class="fas fa-envelope me-2 text-primary"></i>{{ parapharmacie.email ?: 'Non renseigné' }}
                    </p>

                    <a class="btn btn-primary"
                       href="https://www.google.com/maps/search/?api=1&query={{ parapharmacie.adresse|url_encode }}"
                       target="_blank"
                       rel="noopener noreferrer">
                        <i class="fas fa-location-arrow me-2"></i>Ouvrir dans Google Maps
                    </a>
                </div>

                <div class="col-lg-7">
                    <h5 class="mb-3">Emplacement</h5>
                    <div class="map-wrap">
                        <iframe
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            src="https://www.google.com/maps?q={{ parapharmacie.adresse|url_encode }}&output=embed">
                        </iframe>
                    </div>
                </div>
            </div>

            {% if parapharmacie.produits|length > 0 %}
                <hr class="my-4">
                <h5 class="mb-3">Produits disponibles ({{ parapharmacie.produits|length }})</h5>
                <div class="d-flex flex-wrap gap-2">
                    {% for prod in parapharmacie.produits|slice(0, 20) %}
                        <a href="{{ path('app_produit_details', {'id': prod.id}) }}" class="badge bg-light text-dark text-decoration-none border">
                            {{ prod.nom }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
