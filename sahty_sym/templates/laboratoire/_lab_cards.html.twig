{% if laboratoires is defined and laboratoires|length > 0 %}
    <div class="lab-grid">
        {% for laboratoire in laboratoires %}
            <div class="labo-card" data-latitude="{{ laboratoire.latitude }}" data-longitude="{{ laboratoire.longitude }}" data-labo-id="{{ laboratoire.id }}">
                <img src="https://www.onisep.fr/var/onisep/storage/images/_aliases/dso_grid_8_columns/7/8/5/3/17903587-5-fre-FR/251c54dec500-technicien-d-analyses-biomedicales.jpg.webp" alt="Laboratoire medical" class="labo-img">
                <div class="labo-icon">
                    <i class="fa fa-flask"></i>
                </div>
                <div class="labo-content">
                    <h3>{{ laboratoire.nom }}</h3>
                    <div class="labo-location">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>{{ laboratoire.ville }}{% if laboratoire.adresse is defined %}, {{ laboratoire.adresse }}{% endif %}</span>
                    </div>
                    <div class="distance-badge is-hidden" data-distance-badge>
                        <i class="fas fa-location-crosshairs"></i>
                        <span data-distance-value></span>
                    </div>

                    <div class="labo-services">
                        <h6>
                            <i class="fas fa-vial"></i>
                            Analyses disponibles
                        </h6>
                        <ul>
                            <li><i class="fas fa-check-circle"></i> Analyses sanguines</li>
                            <li><i class="fas fa-check-circle"></i> Imagerie medicale</li>
                            <li><i class="fas fa-check-circle"></i> Pathologie</li>
                        </ul>
                    </div>

                    <div class="labo-hours">
                        <i class="fas fa-clock"></i>
                        <span>Lun-Ven: 8h00 - 18h00 | Sam: 9h00 - 14h00</span>
                    </div>

                    <div class="labo-footer">
                        <a href="{{ path('app_labo_show', {'id': laboratoire.id}) }}" class="btn-view">
                            <i class="fas fa-eye"></i>
                            Voir details
                        </a>
                        <a href="{{ path('app_labo_show', {'id': laboratoire.id}) }}" class="btn-appointment">
                            <i class="fas fa-calendar-check"></i>
                            Rendez-vous
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="empty-state">
        <i class="fas fa-flask"></i>
        <h4>Aucun laboratoire trouve</h4>
        <p>Essayez de modifier vos filtres de recherche</p>
        <a href="{{ path('app_labo_index') }}" class="btn-reset">
            <i class="fas fa-redo-alt me-2"></i>
            Reinitialiser les filtres
        </a>
    </div>
{% endif %}
