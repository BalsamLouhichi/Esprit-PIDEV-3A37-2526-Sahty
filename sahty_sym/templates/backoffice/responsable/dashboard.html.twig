{# templates/backoffice/responsable/dashboard.html.twig #}
{% extends 'backoffice/responsable/base.html.twig' %}

{% block title %}Tableau de bord - {{ parapharmacie.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .card.bg-primary,
        .card.bg-info,
        .card.bg-warning,
        .card.bg-success {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
            color: #fff !important;
        }

        .btn-outline-primary {
            border-color: var(--primary) !important;
            color: var(--primary) !important;
        }

        .btn-outline-primary:hover {
            background: var(--primary) !important;
            color: #fff !important;
        }

        .page-header h1 {
            color: var(--primary-dark);
        }

        .ai-summary-card {
            border: 1px solid #dce7f7;
            border-left: 5px solid var(--primary);
            background: linear-gradient(180deg, #f7fbff 0%, #ffffff 100%);
        }

        .ai-summary-priority {
            font-weight: 700;
            padding: 0.25rem 0.65rem;
            border-radius: 999px;
        }

        .ai-summary-priority.high {
            background: #ffe5e5;
            color: #b42318;
        }

        .ai-summary-priority.medium {
            background: #fff4d6;
            color: #9a6700;
        }

        .ai-summary-priority.low {
            background: #e8f5e9;
            color: #1f7a35;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="page-header">
        <h1><i class="fas fa-tachometer-alt me-2"></i>Tableau de bord</h1>
        <p class="text-muted">Bienvenue dans l'espace de gestion de {{ parapharmacie.nom }}</p>
    </div>

    <!-- Cartes de statistiques -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Commandes en attente</h6>
                            <h2 class="mb-0">{{ commandesEnAttente }}</h2>
                        </div>
                        <i class="fas fa-clock fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Chiffre d'affaires</h6>
                            <h2 class="mb-0">{{ statsVentes.total_chiffre_affaires|default(0) }} €</h2>
                        </div>
                        <i class="fas fa-euro-sign fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total produits</h6>
                            <h2 class="mb-0">{{ totalProduits }}</h2>
                        </div>
                        <i class="fas fa-boxes fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Commandes totales</h6>
                            <h2 class="mb-0">{{ statsVentes.total_commandes|default(0) }}</h2>
                        </div>
                        <i class="fas fa-shopping-cart fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card ai-summary-card shadow-sm">
                <div class="card-header bg-transparent border-0 pb-0">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h5 class="mb-1">{{ aiSummary.title|default('Resume du jour') }}</h5>
                            <p class="text-muted mb-0">{{ aiSummary.subtitle|default('') }}</p>
                        </div>
                        {% set priorityClass = {
                            'Elevee': 'high',
                            'Moyenne': 'medium',
                            'Faible': 'low'
                        }[aiSummary.priorite|default('Faible')]|default('low') %}
                        <span class="ai-summary-priority {{ priorityClass }}">
                            Priorite: {{ aiSummary.priorite|default('Faible') }}
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-4 mb-3 mb-lg-0">
                            <h6 class="text-uppercase text-muted small mb-2">KPI Jour</h6>
                            <div class="d-flex flex-column gap-1">
                                <span><strong>{{ aiSummary.kpis.commandes_en_attente|default(0) }}</strong> en attente</span>
                                <span><strong>{{ aiSummary.kpis.commandes_urgentes|default(0) }}</strong> urgente(s)</span>
                                <span><strong>{{ aiSummary.kpis.commandes_jour|default(0) }}</strong> aujourd'hui</span>
                                <span><strong>{{ aiSummary.kpis.ca_jour|default(0) }}</strong> EUR de CA jour</span>
                            </div>
                        </div>
                        <div class="col-lg-4 mb-3 mb-lg-0">
                            <h6 class="text-uppercase text-muted small mb-2">Insights IA</h6>
                            <ul class="mb-0 ps-3">
                                {% for insight in aiSummary.insights|default([]) %}
                                    <li>{{ insight }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                        <div class="col-lg-4">
                            <h6 class="text-uppercase text-muted small mb-2">Actions recommandees</h6>
                            <ul class="mb-0 ps-3">
                                {% for action in aiSummary.actions|default([]) %}
                                    <li>{{ action }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Commandes récentes -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i>Commandes récentes</h5>
                </div>
                <div class="card-body">
                    {% if commandesRecent|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>N° Commande</th>
                                        <th>Client</th>
                                        <th>Produit</th>
                                        <th>Quantité</th>
                                        <th>Total</th>
                                        <th>Statut</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for commande in commandesRecent %}
                                        <tr>
                                            <td><strong>#{{ commande.numero }}</strong></td>
                                            <td>{{ commande.nomClient }}</td>
                                            <td>{{ commande.produit.nom }}</td>
                                            <td>{{ commande.quantite }}</td>
                                            <td>{{ commande.prixTotal }} €</td>
                                            <td>
                                                {% set badge_color = {
                                                    'en_attente': 'warning',
                                                    'confirmee': 'info',
                                                    'preparation': 'primary',
                                                    'expediee': 'secondary',
                                                    'livree': 'success',
                                                    'annulee': 'danger'
                                                } %}
                                                <span class="badge bg-{{ badge_color[commande.statut]|default('secondary') }}">
                                                    {{ commande.statut|replace({'_': ' '})|capitalize }}
                                                </span>
                                            </td>
                                            <td>{{ commande.dateCreation|date('d/m/Y H:i') }}</td>
                                            <td>
                                                <a href="{{ path('app_responsable_commande_details', {'id': commande.id}) }}" 
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted text-center py-4">Aucune commande récente</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
