{# templates/backoffice/responsable/produit_form.html.twig #}
{% extends 'backoffice/responsable/base.html.twig' %}

{% block title %}{{ mode == 'ajouter' ? 'Ajouter' : 'Modifier' }} un produit - {{ parapharmacie.nom }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="page-header">
        <h1>
            <i class="fas fa-{{ mode == 'ajouter' ? 'plus-circle' : 'edit' }} me-2"></i>
            {{ mode == 'ajouter' ? 'Ajouter' : 'Modifier' }} un produit
        </h1>
        <p class="text-muted">{{ parapharmacie.nom }}</p>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        {{ form_label(form.nom, 'Nom du produit', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Crème hydratante'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div class="mb-3">
                        <div class="card border-info">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 text-info">
                                        <i class="fas fa-wand-magic-sparkles me-2"></i>Generateur IA de fiche produit
                                    </h6>
                                    <button type="button" id="btn-generate-fiche-ia" class="btn btn-outline-primary btn-sm">
                                        Generer avec IA
                                    </button>
                                </div>
                                <small class="text-muted d-block">
                                    L IA genere une description, 3 benefices, 3 conseils d usage et des mots-cles SEO.
                                </small>
                                <div id="fiche-ia-feedback" class="small mt-2"></div>
                                <div id="fiche-ia-preview" class="mt-2 d-none"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.prix, 'Prix (€)', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.prix, {'attr': {'class': 'form-control', 'placeholder': '0.00'}}) }}
                                {{ form_errors(form.prix) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.stock, 'Stock', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.stock, {'attr': {'class': 'form-control', 'placeholder': '0'}}) }}
                                {{ form_errors(form.stock) }}
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.categorie, 'Catégorie', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.categorie, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.categorie) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.marque, 'Marque', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.marque, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Nivea'}}) }}
                                {{ form_errors(form.marque) }}
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Description détaillée du produit...'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.promotion, 'Promotion (%)', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.promotion, {'attr': {'class': 'form-control', 'placeholder': '0'}}) }}
                                {{ form_errors(form.promotion) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.poids, 'Poids (g)', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.poids, {'attr': {'class': 'form-control', 'placeholder': '0'}}) }}
                                {{ form_errors(form.poids) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.codeBarre, 'Code-barres', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.codeBarre, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 123456789'}}) }}
                                {{ form_errors(form.codeBarre) }}
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        {{ form_widget(form.estActif, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.estActif, 'Produit actif', {'label_attr': {'class': 'form-check-label fw-semibold'}}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Image du produit</h5>
                        </div>
                        <div class="card-body text-center">
                            {% if produit.image %}
                                <img src="{{ asset('uploads/images/produits/' ~ produit.image) }}" 
                                     alt="{{ produit.nom }}"
                                     class="img-fluid mb-3 rounded"
                                     style="max-height: 200px; object-fit: cover;">
                                <p class="small text-muted mb-3">Image actuelle</p>
                            {% endif %}
                            
                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.imageFile) }}
                            
                            <small class="text-muted d-block mt-2">
                                <i class="fas fa-info-circle me-1"></i>
                                Formats : JPEG, PNG, WebP (max 5 Mo)
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <hr>
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_responsable_produits') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>
                            {{ mode == 'ajouter' ? 'Ajouter le produit' : 'Enregistrer les modifications' }}
                        </button>
                    </div>
                </div>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const button = document.getElementById('btn-generate-fiche-ia');
            const feedback = document.getElementById('fiche-ia-feedback');
            const preview = document.getElementById('fiche-ia-preview');
            if (!button || !feedback || !preview) {
                return;
            }

            const nomInput = document.getElementById('{{ form.nom.vars.id }}');
            const categorieInput = document.getElementById('{{ form.categorie.vars.id }}');
            const marqueInput = document.getElementById('{{ form.marque.vars.id }}');
            const prixInput = document.getElementById('{{ form.prix.vars.id }}');
            const descriptionInput = document.getElementById('{{ form.description.vars.id }}');

            const buildDescription = (result) => {
                const benefits = (result.benefits || []).map((item) => '- ' + item).join('\n');
                const usageTips = (result.usageTips || []).map((item) => '- ' + item).join('\n');
                const seoKeywords = (result.seoKeywords || []).join(', ');

                return [
                    result.description || '',
                    '',
                    'Benefices:',
                    benefits,
                    '',
                    'Conseils d usage:',
                    usageTips,
                    '',
                    'Mots-cles SEO:',
                    seoKeywords
                ].join('\n').trim();
            };

            button.addEventListener('click', async function () {
                if (!nomInput || !descriptionInput || !nomInput.value.trim()) {
                    feedback.className = 'small mt-2 text-danger';
                    feedback.textContent = 'Renseigne au minimum le nom du produit.';
                    return;
                }

                button.disabled = true;
                const previousText = button.textContent;
                button.textContent = 'Generation...';
                feedback.className = 'small mt-2 text-muted';
                feedback.textContent = 'Generation en cours...';

                try {
                    const response = await fetch('{{ path('app_responsable_produit_generer_fiche_ia') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            nom: nomInput ? nomInput.value : '',
                            categorie: categorieInput ? categorieInput.value : '',
                            marque: marqueInput ? marqueInput.value : '',
                            prix: prixInput ? prixInput.value : ''
                        })
                    });

                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error((payload && payload.message) ? payload.message : 'Erreur de generation IA');
                    }

                    const result = payload.data || {};
                    descriptionInput.value = buildDescription(result);
                    const meta = result._meta || {};

                    const keywords = (result.seoKeywords || [])
                        .map((keyword) => '<span class="badge bg-light text-dark border me-1 mb-1">' + keyword + '</span>')
                        .join('');

                    preview.innerHTML = keywords
                        ? '<div><strong>Mots-cles SEO proposes:</strong></div><div class="mt-1">' + keywords + '</div>'
                        : '';
                    preview.classList.remove('d-none');

                    if (meta.usedFallback) {
                        feedback.className = 'small mt-2 text-warning';
                        feedback.textContent = 'Description generee en mode secours (' + (meta.reason || 'fallback') + '). Verifie la configuration IA.';
                    } else {
                        feedback.className = 'small mt-2 text-success';
                        feedback.textContent = 'Fiche generee par IA. Tu peux ajuster le texte avant enregistrement.';
                    }
                } catch (error) {
                    feedback.className = 'small mt-2 text-danger';
                    feedback.textContent = error.message || 'Erreur lors de la generation.';
                } finally {
                    button.disabled = false;
                    button.textContent = previousText;
                }
            });
        })();
    </script>
{% endblock %}
