{# templates/backoffice/responsable/commandes.html.twig #}
{% extends 'backoffice/responsable/base.html.twig' %}

{% block title %}Gestion des commandes - {{ parapharmacie.nom }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1><i class="fas fa-shopping-cart me-2"></i>Gestion des commandes</h1>
            <p class="text-muted">{{ parapharmacie.nom }}</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="btn-group">
                <a href="{{ path('app_responsable_commandes', {'statut': 'tous'}) }}" class="btn btn-outline-primary {{ statutActuel == 'tous' ? 'active' : '' }}">Toutes</a>
                <a href="{{ path('app_responsable_commandes', {'statut': 'en_attente'}) }}" class="btn btn-outline-warning {{ statutActuel == 'en_attente' ? 'active' : '' }}">En attente</a>
                <a href="{{ path('app_responsable_commandes', {'statut': 'confirmee'}) }}" class="btn btn-outline-info {{ statutActuel == 'confirmee' ? 'active' : '' }}">Confirmées</a>
                <a href="{{ path('app_responsable_commandes', {'statut': 'livree'}) }}" class="btn btn-outline-success {{ statutActuel == 'livree' ? 'active' : '' }}">Livrées</a>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>N° Commande</th>
                            <th>Date</th>
                            <th>Client</th>
                            <th>Produit</th>
                            <th>Quantité</th>
                            <th>Total</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for commande in commandes %}
                        <tr>
                            <td><strong>#{{ commande.numero }}</strong></td>
                            <td>{{ commande.dateCreation|date('d/m/Y H:i') }}</td>
                            <td>
                                {{ commande.nomClient }}<br>
                                <small class="text-muted">{{ commande.email }}</small>
                            </td>
                            <td>{{ commande.produit.nom }}</td>
                            <td>{{ commande.quantite }}</td>
                            <td>{{ commande.prixTotal }} €</td>
                            <td>
                                {% set badge_color = {
                                    'en_attente': 'warning',
                                    'confirmee': 'info',
                                    'preparation': 'primary',
                                    'expediee': 'secondary',
                                    'livree': 'success',
                                    'annulee': 'danger'
                                } %}
                                <span class="badge bg-{{ badge_color[commande.statut]|default('secondary') }}">
                                    {{ commande.statut|replace({'_': ' '})|capitalize }}
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a href="{{ path('app_responsable_commande_details', {'id': commande.id}) }}" 
                                       class="btn btn-sm btn-outline-primary" title="Voir détails">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button type="button" 
                                            class="btn btn-sm btn-outline-success dropdown-toggle" 
                                            data-bs-toggle="dropdown" 
                                            aria-expanded="false">
                                        Statut
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                                <input type="hidden" name="statut" value="confirmee">
                                                <button type="submit" class="dropdown-item">Confirmer</button>
                                            </form>
                                        </li>
                                        <li>
                                            <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                                <input type="hidden" name="statut" value="preparation">
                                                <button type="submit" class="dropdown-item">En préparation</button>
                                            </form>
                                        </li>
                                        <li>
                                            <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                                <input type="hidden" name="statut" value="expediee">
                                                <button type="submit" class="dropdown-item">Expédiée</button>
                                            </form>
                                        </li>
                                        <li>
                                            <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                                <input type="hidden" name="statut" value="livree">
                                                <button type="submit" class="dropdown-item">Livrée</button>
                                            </form>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}" 
                                                  onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette commande ?');">
                                                <input type="hidden" name="statut" value="annulee">
                                                <button type="submit" class="dropdown-item text-danger">Annuler</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                                <p class="text-muted">Aucune commande trouvée</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}