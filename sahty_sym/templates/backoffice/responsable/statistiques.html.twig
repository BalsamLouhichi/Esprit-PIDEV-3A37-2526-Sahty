{# templates/backoffice/responsable/statistiques.html.twig #}
{% extends 'backoffice/responsable/base.html.twig' %}

{% block title %}Statistiques - {{ parapharmacie.nom }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="page-header">
        <h1><i class="fas fa-chart-line me-2"></i>Statistiques</h1>
        <p class="text-muted">{{ parapharmacie.nom }}</p>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Répartition des commandes par statut</h5>
                </div>
                <div class="card-body">
                    {% if statsStatuts is defined and statsStatuts|length > 0 %}
                        <canvas id="statsStatuts" style="max-height: 300px;"></canvas>
                    {% else %}
                        <p class="text-muted text-center py-4">Aucune donnée disponible</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Top 10 des produits les plus vendus</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th>Quantité vendue</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in topProduits %}
                                <tr>
                                    <td>{{ item.nom }}</td>
                                    <td><strong>{{ item.total_vendu|default(0) }}</strong></td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="2" class="text-center">Aucune vente</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Évolution mensuelle</h5>
                </div>
                <div class="card-body">
                    {% if statsMensuelles is defined and statsMensuelles|length > 0 %}
                        <canvas id="statsMensuelles" style="max-height: 400px;"></canvas>
                    {% else %}
                        <p class="text-muted text-center py-4">Aucune donnée disponible</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{% if statsStatuts is defined and statsStatuts|length > 0 or statsMensuelles is defined and statsMensuelles|length > 0 %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    {% if statsStatuts is defined and statsStatuts|length > 0 %}
    // Graphique des statuts
    const ctxStatuts = document.getElementById('statsStatuts').getContext('2d');
    const statuts = {{ statsStatuts|json_encode|raw }};
    
    new Chart(ctxStatuts, {
        type: 'pie',
        data: {
            labels: statuts.map(s => s.statut ? s.statut.replace('_', ' ') : 'Inconnu'),
            datasets: [{
                data: statuts.map(s => s.nb_commandes),
                backgroundColor: [
                    '#ffc107', '#0dcaf0', '#0d6efd', '#6c757d', '#198754', '#dc3545'
                ]
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });
    {% endif %}

    {% if statsMensuelles is defined and statsMensuelles|length > 0 %}
    // Graphique des stats mensuelles
    const ctxMensuelles = document.getElementById('statsMensuelles').getContext('2d');
    const mensuelles = {{ statsMensuelles|json_encode|raw }};
    
    new Chart(ctxMensuelles, {
        type: 'line',
        data: {
            labels: mensuelles.map(m => m.mois + '/' + m.annee),
            datasets: [{
                label: 'Chiffre d\'affaires (€)',
                data: mensuelles.map(m => parseFloat(m.chiffre_affaires) || 0),
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                tension: 0.1,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });
    {% endif %}
});
</script>
{% endif %}
{% endblock %}