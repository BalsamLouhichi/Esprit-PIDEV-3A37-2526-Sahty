{# templates/backoffice/responsable/commande_details.html.twig #}
{% extends 'backoffice/responsable/base.html.twig' %}

{% block title %}Détails de la commande #{{ commande.numero }} - {{ parapharmacie.nom }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1><i class="fas fa-file-invoice me-2"></i>Détails de la commande #{{ commande.numero }}</h1>
            <p class="text-muted">{{ parapharmacie.nom }}</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Informations de la commande</h5>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th style="width: 200px;">Numéro de commande</th>
                            <td><strong>#{{ commande.numero }}</strong></td>
                        </tr>
                        <tr>
                            <th>Date de création</th>
                            <td>{{ commande.dateCreation|date('d/m/Y H:i:s') }}</td>
                        </tr>
                        <tr>
                            <th>Dernière modification</th>
                            <td>{{ commande.dateModification ? commande.dateModification|date('d/m/Y H:i:s') : '-' }}</td>
                        </tr>
                        <tr>
                            <th>Statut actuel</th>
                            <td>
                                {% set badge_color = {
                                    'en_attente': 'warning',
                                    'confirmee': 'info',
                                    'preparation': 'primary',
                                    'expediee': 'secondary',
                                    'livree': 'success',
                                    'annulee': 'danger'
                                } %}
                                <span class="badge bg-{{ badge_color[commande.statut]|default('secondary') }} fs-6">
                                    {{ commande.statut|replace({'_': ' '})|capitalize }}
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Détails du produit</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 text-center">
                            {% if commande.produit.image %}
                                <img src="{{ asset('uploads/images/produits/' ~ commande.produit.image) }}" 
                                     alt="{{ commande.produit.nom }}"
                                     class="img-fluid rounded"
                                     style="max-height: 150px;">
                            {% else %}
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                     style="height: 150px;">
                                    <i class="fas fa-image fa-3x text-muted"></i>
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-md-9">
                            <table class="table">
                                <tr>
                                    <th style="width: 150px;">Produit</th>
                                    <td><strong>{{ commande.produit.nom }}</strong></td>
                                </tr>
                                <tr>
                                    <th>Référence</th>
                                    <td>{{ commande.produit.reference }}</td>
                                </tr>
                                <tr>
                                    <th>Prix unitaire</th>
                                    <td>{{ commande.prixUnitaire }} €</td>
                                </tr>
                                <tr>
                                    <th>Quantité commandée</th>
                                    <td>{{ commande.quantite }}</td>
                                </tr>
                                <tr>
                                    <th>Prix total</th>
                                    <td><strong class="text-primary">{{ commande.prixTotal }} €</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Informations client</h5>
                </div>
                <div class="card-body">
                    <p><strong>Nom :</strong> {{ commande.nomClient }}</p>
                    <p><strong>Email :</strong> {{ commande.email }}</p>
                    <p><strong>Téléphone :</strong> {{ commande.telephone }}</p>
                    <p><strong>Adresse de livraison :</strong><br>
                    {{ commande.adresseLivraison|nl2br }}</p>
                    {% if commande.notes %}
                        <p><strong>Notes :</strong><br>
                        {{ commande.notes|nl2br }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_responsable_commandes') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour aux commandes
                        </a>
                        
                        {% if commande.statut != 'livree' and commande.statut != 'annulee' %}
                            <div class="dropdown">
                                <button class="btn btn-primary w-100 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-sync-alt me-2"></i>Changer le statut
                                </button>
                                <ul class="dropdown-menu w-100">
                                    {% if commande.statut != 'confirmee' %}
                                    <li>
                                        <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                            <input type="hidden" name="statut" value="confirmee">
                                            <button type="submit" class="dropdown-item">Confirmer</button>
                                        </form>
                                    </li>
                                    {% endif %}
                                    {% if commande.statut != 'preparation' %}
                                    <li>
                                        <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                            <input type="hidden" name="statut" value="preparation">
                                            <button type="submit" class="dropdown-item">En préparation</button>
                                        </form>
                                    </li>
                                    {% endif %}
                                    {% if commande.statut != 'expediee' %}
                                    <li>
                                        <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                            <input type="hidden" name="statut" value="expediee">
                                            <button type="submit" class="dropdown-item">Expédiée</button>
                                        </form>
                                    </li>
                                    {% endif %}
                                    {% if commande.statut != 'livree' %}
                                    <li>
                                        <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}">
                                            <input type="hidden" name="statut" value="livree">
                                            <button type="submit" class="dropdown-item">Livrée</button>
                                        </form>
                                    </li>
                                    {% endif %}
                                    {% if commande.statut != 'annulee' and commande.statut != 'livree' %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="{{ path('app_responsable_commande_statut', {'id': commande.id}) }}"
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette commande ?');">
                                            <input type="hidden" name="statut" value="annulee">
                                            <button type="submit" class="dropdown-item text-danger">Annuler</button>
                                        </form>
                                    </li>
                                    {% endif %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}