{% extends 'backoffice/responsable/base.html.twig' %}

{% block title %}Gestion des produits - {{ parapharmacie.nom }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1><i class="fas fa-boxes me-2"></i>Gestion des produits</h1>
            <p class="text-muted mb-1">{{ parapharmacie.nom }}</p>
            <small class="text-muted">Resultats: <span id="productsCount">{{ produits|length }}</span></small>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_responsable_produit_ajouter') }}" class="btn btn-success">
                <i class="fas fa-plus-circle me-2"></i>Nouveau produit
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_responsable_produits') }}" class="row g-3" id="productSearchForm">
                <div class="col-md-8">
                    <input type="text"
                           id="productSearchInput"
                           name="search"
                           class="form-control"
                           placeholder="Rechercher un produit..."
                           value="{{ searchTerm|default('') }}"
                           autocomplete="off">
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100" id="productSearchBtn">
                        <i class="fas fa-search me-2"></i>Rechercher
                    </button>
                    <a href="{{ path('app_responsable_produits') }}" class="btn btn-outline-secondary" id="productResetBtn">
                        Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-none mb-3" id="productsLoading">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                Recherche en cours...
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Image</th>
                            <th>Reference</th>
                            <th>Nom</th>
                            <th>Categorie</th>
                            <th>Prix</th>
                            <th>Stock</th>
                            <th>Promo</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="productsTableBody">
                        {% include 'backoffice/responsable/_produits_rows.html.twig' with { produits: produits } %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('productSearchForm');
            const input = document.getElementById('productSearchInput');
            const tbody = document.getElementById('productsTableBody');
            const count = document.getElementById('productsCount');
            const loading = document.getElementById('productsLoading');
            const resetBtn = document.getElementById('productResetBtn');

            if (!form || !input || !tbody) {
                return;
            }

            let controller = null;
            let debounceTimer = null;
            const endpoint = '{{ path('app_responsable_produits') }}';

            const setLoading = (state) => {
                if (!loading) return;
                loading.classList.toggle('d-none', !state);
            };

            const fetchResults = async (term) => {
                if (controller) {
                    controller.abort();
                }
                controller = new AbortController();

                const params = new URLSearchParams();
                if (term && term.trim() !== '') {
                    params.set('search', term.trim());
                }

                setLoading(true);
                try {
                    const response = await fetch(endpoint + (params.toString() ? ('?' + params.toString()) : ''), {
                        method: 'GET',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        signal: controller.signal
                    });

                    if (!response.ok) {
                        throw new Error('HTTP ' + response.status);
                    }

                    const data = await response.json();
                    if (!data || data.success !== true) {
                        throw new Error('Invalid payload');
                    }

                    tbody.innerHTML = data.html || '';
                    if (count) {
                        count.textContent = String(data.count ?? 0);
                    }

                    const url = new URL(window.location.href);
                    if (term && term.trim() !== '') {
                        url.searchParams.set('search', term.trim());
                    } else {
                        url.searchParams.delete('search');
                    }
                    window.history.replaceState({}, '', url.toString());
                } catch (error) {
                    if (error.name !== 'AbortError') {
                        console.error('Search failed', error);
                    }
                } finally {
                    setLoading(false);
                }
            };

            form.addEventListener('submit', function (event) {
                event.preventDefault();
                fetchResults(input.value);
            });

            input.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(function () {
                    fetchResults(input.value);
                }, 300);
            });

            if (resetBtn) {
                resetBtn.addEventListener('click', function (event) {
                    event.preventDefault();
                    input.value = '';
                    fetchResults('');
                });
            }
        });
    </script>
{% endblock %}
