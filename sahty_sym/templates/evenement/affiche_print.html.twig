<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Affiche - {{ evenement.titre }}</title>
    <style>
        @page {
            size: A4;
            margin: 12mm;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            color: #0f172a;
            background: #fff;
        }

        .print-bar {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 10px;
        }

        .print-btn {
            border: 1px solid #2563eb;
            background: #2563eb;
            color: #fff;
            border-radius: 6px;
            padding: 8px 12px;
            font-size: 13px;
            cursor: pointer;
        }

        .poster {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
        }

        .poster-head {
            padding: 14px 16px;
            color: #fff;
            background: {{ experience_pack.poster.theme.bg|default('linear-gradient(135deg,#2563eb,#1d4ed8)') }};
        }

        .poster-head h1 {
            margin: 0 0 6px 0;
            font-size: 26px;
            line-height: 1.2;
        }

        .poster-head .sub {
            margin: 0;
            font-size: 14px;
            opacity: 0.95;
        }

        .poster-body {
            padding: 14px 16px 16px;
        }

        .meta {
            margin: 0 0 10px 0;
            font-size: 14px;
            color: #334155;
        }

        .chips {
            margin: 0 0 12px 0;
        }

        .chip {
            display: inline-block;
            margin: 0 6px 6px 0;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            color: #1e3a8a;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
        }

        .section-title {
            margin: 10px 0 8px;
            font-size: 15px;
            color: #0f172a;
        }

        .planning {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
            font-size: 13px;
        }

        .planning th,
        .planning td {
            border: 1px solid #e2e8f0;
            padding: 7px 8px;
            text-align: left;
        }

        .planning th {
            background: #f8fafc;
            color: #334155;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .02em;
        }

        .desc {
            font-size: 13px;
            line-height: 1.5;
            color: #334155;
            white-space: pre-line;
            border-top: 1px dashed #cbd5e1;
            padding-top: 10px;
        }

        @media print {
            .print-bar { display: none; }
        }
    </style>
</head>
<body>
    <div class="print-bar">
        <button type="button" class="print-btn" onclick="window.print()">Imprimer / Enregistrer en PDF</button>
    </div>

    <div class="poster">
        <div class="poster-head">
            <h1>{{ experience_pack.poster.title|default(evenement.titre) }}</h1>
            <p class="sub">{{ experience_pack.poster.subtitle|default('Programme officiel SAHTY') }}</p>
        </div>

        <div class="poster-body">
            <p class="meta"><strong>Date:</strong> {{ experience_pack.poster.date_label|default('Date a definir') }}</p>
            <p class="meta"><strong>Lieu:</strong> {{ experience_pack.poster.lieu_label|default('Lieu a confirmer') }}</p>
            <p class="meta"><strong>Mode:</strong> {{ experience_pack.poster.mode_label|default(evenement.mode|default('presentiel')) }}</p>

            <div class="chips">
                {% for chip in experience_pack.highlights|default([]) %}
                    <span class="chip">{{ chip }}</span>
                {% endfor %}
            </div>

            <h2 class="section-title">Planning genere</h2>
            <table class="planning">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Etape</th>
                        <th>Horaire</th>
                        <th>Duree</th>
                    </tr>
                </thead>
                <tbody>
                    {% for card in experience_pack.cards|default([]) %}
                        <tr>
                            <td>{{ loop.index }}</td>
                            <td>{{ card.title|default('Phase') }}</td>
                            <td>{{ card.time_label|default('~') }}</td>
                            <td>{{ card.duration|default(0) }} min</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4">Planning indisponible</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            {% if display_description is defined and display_description %}
                <h2 class="section-title">Description</h2>
                <div class="desc">{{ display_description }}</div>
            {% endif %}
        </div>
    </div>
</body>
</html>
