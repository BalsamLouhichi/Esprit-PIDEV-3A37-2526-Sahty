<!DOCTYPE html>

<html lang="fr">

<head>

    <meta charset="UTF-8">

    <title>Demander un Événement</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">



    <!-- Fonts first -->

    <link rel="preconnect" href="https://fonts.gstatic.com">

    <link href="https://fonts.googleapis.com/css2family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    

    <!-- Bootstrap CSS - MUST come before custom CSS -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">

    

    <!-- Font Awesome -->

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.0/css/all.min.css" rel="stylesheet">

    <!-- Bootstrap Icons (if your header uses them) -->

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    

    <!-- Flatpickr CSS -->

    <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">

    

    <!-- Your custom CSS - always last -->

    <link href="{{ asset('css/style.css') }}" rel="stylesheet">



    <style>

        body {

            overflow-x: hidden;

        }



        .form-control, .form-select {

            padding: 0.75rem 1rem;

            border-radius: 0.5rem;

            font-size: 0.95rem;

            transition: all 0.2s;

        }

        .form-control:focus, .form-select:focus {

            border-color: #0d6efd;

            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);

            outline: none;

        }

        .form-label {

            font-weight: 600;

            margin-bottom: 0.5rem;

            font-size: 0.95rem;

            color: #495057;

        }

        .form-textarea {

            min-height: 120px;

            resize: vertical;

        }

        .input-group .form-control, .input-group-text {

            border-radius: 0.5rem;

        }

        .is-invalid {

            border-color: #dc3545 !important;

        }

        .invalid-feedback {

            font-size: 0.85rem;

            margin-top: 0.25rem;

        }

        .btn-primary, .btn-secondary {

            padding: 0.75rem 2rem;

            font-weight: 600;

            border-radius: 0.5rem;

        }

        .card {

            border: none;

            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);

        }

        .card-body {

            padding: 2rem;

        }

        .display-6 {

            color: #212529;

        }

        .container-fluid.py-5 {

            background-color: #f8f9fa;

            min-height: 100vh;

            padding-top: 2rem;

            padding-bottom: 2rem;

        }

        

        /* Groupes cibles redesign styles */

        .group-card {

            transition: all 0.2s ease;

            cursor: pointer;

            border-color: #dee2e6 !important;

        }

        

        .group-card:hover {

            border-color: #0d6efd !important;

            box-shadow: 0 2px 8px rgba(13, 110, 253, 0.1);

            transform: translateY(-2px);

        }

        

        .group-card .form-check-input {

            margin-top: 0;

            cursor: pointer;

        }

        

        .group-card .form-check-input:checked {

            background-color: #0d6efd;

            border-color: #0d6efd;

        }

        

        .group-card .form-check-input:checked + .form-check-label .rounded-circle {

            background-color: rgba(13, 110, 253, 0.1) !important;

        }

        

        .group-card .form-check-label {

            cursor: pointer;

            width: 100%;

        }

        

        #groupSearch:focus {

            box-shadow: none;

            border-color: #dee2e6;

        }

        

        #groupSearch:focus + .input-group-text {

            border-color: #dee2e6;

        }

        

        #hiddenGroups {

            animation: slideDown 0.3s ease;

        }

        

        @keyframes slideDown {

            from {

                opacity: 0;

                transform: translateY(-10px);

            }

            to {

                opacity: 1;

                transform: translateY(0);

            }

        }

        

        .limited-groups {

            position: relative;

        }

        

        .btn-link {

            color: #0d6efd;

            font-weight: 500;

        }

        

        .btn-link:hover {

            color: #0a58ca;

        }

        

        .groups-count-badge {

            background-color: rgba(13, 110, 253, 0.1);

            color: #0d6efd;

            font-size: 0.8rem;

            padding: 0.25rem 0.5rem;

            border-radius: 1rem;

        }

        

        .info-box {

            background: #e8f4fd;

            border-left: 4px solid #2196F3;

            padding: 1rem;

            border-radius: 0.5rem;

            margin-bottom: 2rem;

        }

        .info-box i {

            color: #2196F3;

        }



        .resource-panel {

            border: 1px solid #dbeafe;

            background: linear-gradient(135deg, #f8fbff 0%, #eef6ff 100%);

            border-radius: 0.75rem;

            padding: 1rem;

        }



        .resource-chip {

            border-radius: 999px;

            padding: 0.2rem 0.6rem;

            font-size: 0.75rem;

            font-weight: 600;

        }



        .online-config-card {

            border: 1px solid #dbeafe;

            background: linear-gradient(135deg, #f8fbff 0%, #edf4ff 100%);

            border-radius: 0.75rem;

            padding: 1rem;

        }



        .online-preview {

            background: #fff;

            border: 1px dashed #bfdbfe;

            border-radius: 0.6rem;

            padding: 0.7rem;

            font-size: 0.85rem;

            color: #334155;

        }



        @media (max-width: 768px) {

            .group-card .form-check-label .d-flex {

                flex-direction: column;

                text-align: center;

            }

            

            .group-card .rounded-circle {

                margin-right: 0 !important;

                margin-bottom: 0.5rem;

            }

        }

    
        .planning-showcase {
            background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
            border: 1px solid #d7e7ff;
            border-radius: 14px;
            padding: 14px;
            box-shadow: 0 6px 18px rgba(29, 93, 155, 0.08);
        }

        .planning-headline {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }

        .planning-headline h6 {
            margin: 0;
            font-weight: 800;
            color: #0b5ed7;
        }

        .planning-kpi {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            font-size: 0.75rem;
            padding: 4px 10px;
            border: 1px solid #cfe2ff;
            background: #eef5ff;
            color: #0a58ca;
            font-weight: 700;
        }

        .planning-timeline {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 10px;
            margin: 10px 0;
        }

        .planning-step {
            border: 1px solid #e2e8f0;
            border-left: 4px solid #0d6efd;
            border-radius: 10px;
            padding: 10px;
            background: #fff;
        }

        .planning-step-index {
            font-size: 0.75rem;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .planning-step-title {
            font-size: 0.98rem;
            font-weight: 800;
            color: #1e293b;
            margin: 4px 0 6px;
        }

        .planning-step-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.83rem;
            color: #475569;
        }

        .planning-note {
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 10px;
            padding: 10px;
            font-size: 0.86rem;
            color: #475569;
        }
    </style>

</head>



<body>



{% include 'partials/header.html.twig' %}



<div class="container-fluid py-5">

    <div class="container">

        <div class="row mb-5">

            <div class="col-md-8">

                <h1 class="display-6 fw-bold mb-3 text-dark">

                    <i class="fas fa-paper-plane text-primary me-2"></i>

                    Demander un Événement

                </h1>

                <p class="text-muted mb-0">Soumettez votre événement pour approbation par l'administrateur</p>

            </div>

            <div class="col-md-4 d-flex align-items-center justify-content-end">

                <a href="{{ path('evenements_client_events') }}" class="btn btn-outline-secondary">

                    <i class="fas fa-arrow-left me-2"></i>Retour

                </a>

            </div>

        </div>



        <div class="info-box">

            <div class="d-flex align-items-start">

                <i class="fas fa-info-circle fa-lg me-3 mt-1"></i>

                <div>

                    <h6 class="fw-bold mb-2">Comment ça marche </h6>

                    <p class="mb-0">

                        1. Remplissez le formulaire ci-dessous avec les détails de votre événement<br>

                        2. Soumettez votre demande pour approbation<br>

                        3. Un administrateur examinera votre demande sous 48h<br>

                        4. Vous serez notifié par email lorsque votre événement sera approuvé ou refusé

                    </p>

                </div>

            </div>

        </div>



        <div class="card">

            <div class="card-body">

                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

                {% if form.vars.errors|length > 0 %}

                    <div class="alert alert-danger shadow-sm mb-4" role="alert">

                        <div class="fw-semibold mb-2">

                            <i class="fas fa-exclamation-triangle me-2"></i>

                            Impossible de soumettre la demande

                        </div>

                        {{ form_errors(form) }}

                    </div>

                {% endif %}



                <div class="row g-4">

                    <!-- Titre - Full width -->

                    <div class="col-12">

                        {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label'}}) }}

                        {{ form_widget(form.titre, {'attr': {

                            'class': 'form-control', 

                            'placeholder': 'Ex: Nutrition et Santé Cardiovasculaire',

                            'required': 'required',

                            'minlength': '5',

                            'maxlength': '200'

                        }}) }}

                        {{ form_errors(form.titre) }}

                    </div>



                    <!-- Type et Mode côte à côte -->

                    <div class="col-md-6">

                        {{ form_label(form.type, null, {'label_attr': {'class': 'form-label'}}) }}

                        {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}

                        {{ form_errors(form.type) }}

                    </div>



                    <div class="col-md-6">

                        {{ form_label(form.mode, null, {'label_attr': {'class': 'form-label'}}) }}

                        {{ form_widget(form.mode, {'attr': {'class': 'form-select'}}) }}

                        {{ form_errors(form.mode) }}

                    </div>



                    <div class="col-12" id="online-config-panel" style="display:none;">

                        <div class="online-config-card">

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <h6 class="mb-0 fw-bold text-primary">

                                    <i class="fas fa-video me-2"></i>Configuration réunion en ligne

                                </h6>

                                <span class="badge bg-info-subtle text-info border">Jitsi auto ou lien personnalisé</span>

                            </div>

                            <div class="row g-3">

                                <div class="col-md-6" id="meeting-platform-wrapper">

                                    {{ form_label(form.meetingPlatform, null, {'label_attr': {'class': 'form-label'}}) }}

                                    {{ form_widget(form.meetingPlatform, {'attr': {'class': 'form-select'}}) }}

                                    {{ form_errors(form.meetingPlatform) }}

                                </div>

                                <div class="col-md-6" id="meeting-link-wrapper">

                                    {{ form_label(form.meetingLink, null, {'label_attr': {'class': 'form-label'}}) }}

                                    {{ form_widget(form.meetingLink, {'attr': {'class': 'form-control', 'placeholder': 'https://...'}}) }}

                                    {{ form_errors(form.meetingLink) }}

                                </div>

                                <div class="col-12">

                                    <div class="online-preview">

                                        <div class="fw-semibold mb-1"><i class="fas fa-link me-1"></i>Aperçu lien de réunion</div>

                                        <div id="meeting-preview-text">Sélectionnez une plateforme pour générer un aperçu.</div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>



                    <!-- Description - Full width -->

                    <div class="col-12">

                        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}

                        {{ form_widget(form.description, {'attr': {

                            'class': 'form-control form-textarea', 

                            'placeholder': 'Décrivez votre événement en détail...',

                            'maxlength': '5000'

                        }}) }}

                        {{ form_errors(form.description) }}

                    </div>



                    <!-- Dates côte à côte -->

                    <div class="col-md-6">

                        {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'form-label'}}) }}

                        <div class="input-group">

                            {{ form_widget(form.dateDebut, {'attr': {

                                'class': 'form-control', 

                                'type': 'datetime-local',

                                'required': 'required',

                                'min': "now"|date_modify("+2 days")|date('Y-m-d\\TH:i')

                            }}) }}

                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>

                        </div>

                        {{ form_errors(form.dateDebut) }}

                        <small class="text-muted">L'événement doit être prévu au moins 48h à l'avance</small>

                    </div>



                    <div class="col-md-6">

                        {{ form_label(form.dateFin, null, {'label_attr': {'class': 'form-label'}}) }}

                        <div class="input-group">

                            {{ form_widget(form.dateFin, {'attr': {

                                'class': 'form-control', 

                                'type': 'datetime-local',

                                'required': 'required',

                                'min': "now"|date_modify("+2 days")|date('Y-m-d\\TH:i')

                            }}) }}

                            <span class="input-group-text"><i class="fas fa-calendar"></i></span>

                        </div>

                        {{ form_errors(form.dateFin) }}

                    </div>



                    <!-- Lieu -->

                    <div class="col-md-6">

                        {{ form_label(form.lieu, null, {'label_attr': {'class': 'form-label'}}) }}

                        {{ form_widget(form.lieu, {'attr': {

                            'class': 'form-control', 

                            'placeholder': 'Adresse ou lien de connexion',

                            'maxlength': '500'

                        }}) }}

                        {{ form_errors(form.lieu) }}
                        <div id="lieu-validation-feedback" class="small mt-1 text-muted"></div>
                        <input type="hidden" id="venue-source-input" name="venue_source" value="manual">

                    </div>



                    <div class="col-md-6" id="venue-reco-panel">

                        <label class="form-label">Recherche intelligente de lieu présentiel</label>

                        <div class="input-group mb-2">

                            <input type="text" id="venue-city-input" class="form-control" placeholder="Ex: Tunis, Sousse, Sfax">

                            <button type="button" id="venue-search-btn" class="btn btn-outline-primary">

                                <i class="fas fa-search-location me-1"></i> Rechercher

                            </button>

                        </div>

                        <small class="text-muted">

                            Lieux recommandés avec contacts pour faciliter l'organisation réelle.

                        </small>

                        <div id="venue-search-results" class="mt-2"></div>

                    </div>



                    <!-- Places max et Tarif côte à côte -->

                    <div class="col-md-6">

                        {{ form_label(form.placesMax, null, {'label_attr': {'class': 'form-label'}}) }}

                        <div class="input-group">

                            {{ form_widget(form.placesMax, {'attr': {

                                'class': 'form-control', 

                                'placeholder': 'Illimité',

                                'min': '1',

                                'max': '10000'

                            }}) }}

                            <span class="input-group-text">places</span>

                        </div>

                        {{ form_errors(form.placesMax) }}

                        <small class="text-muted">Laissez vide pour illimité</small>

                    </div>



                    <div class="col-md-6">

                        {{ form_label(form.tarif, null, {'label_attr': {'class': 'form-label'}}) }}

                        <div class="input-group">

                            {{ form_widget(form.tarif, {'attr': {

                                'class': 'form-control', 

                                'placeholder': '0.00',

                                'min': '0',

                                'max': '10000',

                                'step': '0.01'

                            }}) }}

                            <span class="input-group-text">TND</span>

                        </div>

                        {{ form_errors(form.tarif) }}

                        <small class="text-muted">Gratuit si vide ou 0</small>

                    </div>



                    <div class="col-12">

                        <div class="resource-panel">

                            <div class="d-flex justify-content-between align-items-center mb-2">

                                <h6 class="mb-0 fw-bold text-primary">

                                    <i class="fas fa-boxes me-2"></i>Plan de ressources intelligent

                                </h6>

                                <span class="resource-chip bg-light text-dark border" id="resource-risk-chip">Analyse en cours...</span>

                            </div>

                            <div id="resource-plan-body" class="small text-muted">

                                Le plan logistique sera calcule selon type, mode et capacite.

                            </div>

                        </div>

                    </div>



                    <div class="col-12" id="planning-ia-panel">
                        <div class="card border shadow-sm">
                            <div class="card-body">
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                                    <h6 class="mb-0 fw-bold text-primary">
                                        <i class="fas fa-brain me-2"></i>Plan IA recommande (modele entraine)
                                    </h6>
                                    <button type="button" class="btn btn-sm btn-outline-primary" id="planning-ia-generate-btn">
                                        <i class="fas fa-magic me-1"></i>Generer un planning
                                    </button>
                                </div>
                                <div class="small text-muted mb-2">
                                    Genere depuis votre dataset local (Python). Vous pouvez ensuite ajuster les phases manuellement.
                                </div>
                                <div id="planning-ia-body" class="small text-muted">
                                    Cliquez sur "Generer un planning" apres avoir choisi type + mode + dates.
                                </div>
                                <div id="planning-ia-actions" class="d-none mt-3">
                                    <div class="d-flex flex-wrap gap-2">
                                        <button type="button" class="btn btn-sm btn-success" id="planning-ia-accept-btn">
                                            <i class="fas fa-check me-1"></i>Accepter ce planning
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-primary" id="planning-ia-customize-btn">
                                            <i class="fas fa-sliders-h me-1"></i>Personnaliser dans le studio
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" id="planning-ia-reject-btn">
                                            <i class="fas fa-times me-1"></i>Refuser
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" id="planning-ia-regenerate-btn">
                                            <i class="fas fa-rotate-right me-1"></i>Regenerer
                                        </button>
                                    </div>
                                    <div id="planning-ia-status" class="small mt-2 text-muted"></div>
                                    <input type="hidden" id="planning-ia-decision" name="planning_ia_decision" value="">
                                    <input type="hidden" id="planning-ia-payload" name="planning_ia_payload" value="">
                                </div>
                            </div>
                        </div>
                    </div>

                    {% include 'evenement/_scenario_studio.html.twig' %}



                    <div class="col-12">

                        <div class="card border shadow-sm">

                            <div class="card-header bg-white py-3">

                                <h5 class="mb-0 fw-semibold">

                                    <i class="fas fa-layer-group text-primary me-2"></i>

                                    Série d'éditions (surface intelligente)

                                </h5>

                            </div>

                            <div class="card-body">

                                <div class="row g-3">

                                    <div class="col-12">

                                        <div class="form-check form-switch">

                                            {{ form_widget(form.isEdition, {'attr': {'class': 'form-check-input'}}) }}

                                            {{ form_label(form.isEdition, null, {'label_attr': {'class': 'form-check-label fw-semibold ms-2'}}) }}

                                        </div>

                                    </div>

                                    <div class="col-md-8 edition-fields">

                                        {{ form_label(form.editionSourceEventId, null, {'label_attr': {'class': 'form-label'}}) }}

                                        {{ form_widget(form.editionSourceEventId, {'attr': {'class': 'form-select'}}) }}

                                        {{ form_errors(form.editionSourceEventId) }}

                                    </div>

                                    <div class="col-md-4 edition-fields">

                                        {{ form_label(form.editionNumero, null, {'label_attr': {'class': 'form-label'}}) }}

                                        {{ form_widget(form.editionNumero, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 3'}}) }}

                                        {{ form_errors(form.editionNumero) }}

                                    </div>

                                </div>

                                <div class="small text-muted mt-3">

                                    <i class="fas fa-brain me-1"></i>

                                    L'IA évaluera ensuite l'évolution de la série, la continuité pédagogique et la fidélité des participants.

                                </div>

                            </div>

                        </div>

                    </div>



                    <!-- Groupes Cibles - Redesigned -->

                    <div class="col-12 mb-4">

                        <div class="card border shadow-sm">

                            <div class="card-header bg-white py-3">

                                <div class="d-flex justify-content-between align-items-center">

                                    <h5 class="mb-0 fw-semibold">

                                        <i class="fas fa-users text-primary me-2"></i>

                                        Groupes cibles

                                    </h5>

                                    <div class="d-flex gap-2">
                                        <a href="{{ path('groupe_cible_index', {'referrer': 'evenements_client_demande_evenement'}) }}"
                                           class="btn btn-sm btn-outline-primary"
                                           >
                                            <i class="fas fa-list me-1"></i> Gerer
                                        </a>
                                        <a href="{{ path('groupe_cible_new', {'referrer': 'evenements_client_demande_evenement', 'return_to': 'form'}) }}"
                                           class="btn btn-sm btn-primary"
                                           >
                                            <i class="fas fa-plus me-1"></i> Nouveau
                                        </a>
                                    </div>

                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">

                                        <i class="fas fa-tag me-1"></i>

                                        {% if form.groupeCibles.vars.choices|length %}

                                            {{ form.groupeCibles.vars.choices|length }} groupe{{ form.groupeCibles.vars.choices|length > 1 ? 's' : '' }}

                                        {% else %}

                                            Aucun groupe

                                        {% endif %}

                                    </span>

                                </div>

                            </div>

                            

                            <div class="card-body">

                                <!-- Info badge with count and instructions -->

                                <div class="d-flex align-items-center mb-4">

                                    <div class="bg-light rounded-3 p-2 px-3">

                                        <span class="fw-bold text-primary">{{ form.groupeCibles.vars.choices|length }}</span>

                                        <span class="text-muted">groupe(s) disponible(s)</span>

                                    </div>

                                    <div class="ms-3">

                                        <span class="badge bg-info text-dark">

                                            <i class="fas fa-info-circle me-1"></i>

                                            Sélection facultative

                                        </span>

                                    </div>

                                </div>



                                {% if form.groupeCibles.vars.choices|length > 0 %}

                                    <!-- Search bar -->

                                    <div class="mb-4">

                                        <div class="input-group">

                                            <span class="input-group-text bg-white border-end-0">

                                                <i class="fas fa-search text-muted"></i>

                                            </span>

                                            <input type="text" 

                                                   class="form-control border-start-0 ps-0" 

                                                   id="groupSearch" 

                                                   placeholder="Rechercher un groupe..."

                                                   onkeyup="filterGroups()">

                                        </div>

                                    </div>



                                    <!-- Groups grid -->

                                    <div class="limited-groups" id="limitedGroups">

                                        <!-- Visible groups (first 6) -->

                                        <div class="row g-3" id="visibleGroups">

                                            {% for choice in form.groupeCibles.vars.choices|slice(0, 6) %}

                                                <div class="col-lg-4 col-md-6 group-item" data-label="{{ choice.label|lower }}">

                                                    <div class="card border group-card h-100">

                                                        <div class="card-body p-3">

                                                            <div class="form-check">

                                                                <input type="checkbox" 

                                                                       class="form-check-input"

                                                                       id="groupe_cible_{{ choice.value }}"

                                                                       name="{{ form.groupeCibles.vars.full_name }}[]"

                                                                       value="{{ choice.value }}"

                                                                       {% if choice.value in form.groupeCibles.vars.value %}checked{% endif %}>

                                                                <label class="form-check-label d-block ms-2" 

                                                                       for="groupe_cible_{{ choice.value }}">

                                                                    <div class="d-flex align-items-center">

                                                                        <div class="rounded-circle bg-light p-2 me-2">

                                                                            <i class="fas fa-users text-primary small"></i>

                                                                        </div>

                                                                        <div>

                                                                            <span class="fw-medium">{{ choice.label }}</span>

                                                                            <small class="text-muted d-block">Groupe cible</small>

                                                                        </div>

                                                                    </div>

                                                                </label>

                                                            </div>

                                                        </div>

                                                    </div>

                                                </div>

                                            {% endfor %}

                                        </div>



                                        <!-- Hidden groups (remaining) -->

                                        {% if form.groupeCibles.vars.choices|length > 6 %}

                                            <div class="row g-3 mt-2" id="hiddenGroups" style="display: none;">

                                                {% for choice in form.groupeCibles.vars.choices|slice(6) %}

                                                    <div class="col-lg-4 col-md-6 group-item" data-label="{{ choice.label|lower }}">

                                                        <div class="card border group-card h-100">

                                                            <div class="card-body p-3">

                                                                <div class="form-check">

                                                                    <input type="checkbox" 

                                                                           class="form-check-input"

                                                                           id="groupe_cible_{{ choice.value }}_hidden"

                                                                           name="{{ form.groupeCibles.vars.full_name }}[]"

                                                                           value="{{ choice.value }}"

                                                                           {% if choice.value in form.groupeCibles.vars.value %}checked{% endif %}>

                                                                    <label class="form-check-label d-block ms-2" 

                                                                           for="groupe_cible_{{ choice.value }}_hidden">

                                                                        <div class="d-flex align-items-center">

                                                                            <div class="rounded-circle bg-light p-2 me-2">

                                                                                <i class="fas fa-users text-primary small"></i>

                                                                            </div>

                                                                            <div>

                                                                                <span class="fw-medium">{{ choice.label }}</span>

                                                                                <small class="text-muted d-block">Groupe cible</small>

                                                                            </div>

                                                                        </div>

                                                                    </label>

                                                                </div>

                                                            </div>

                                                        </div>

                                                    </div>

                                                {% endfor %}

                                            </div>



                                            <!-- Show more/less button -->

                                            <div class="text-center mt-4">

                                                <button type="button" 

                                                        class="btn btn-link text-decoration-none" 

                                                        id="toggleGroupsBtn"

                                                        onclick="toggleGroups()">

                                                    <i class="fas fa-chevron-down me-1" id="toggleIcon"></i>

                                                    <span id="toggleText">Voir tous les groupes ({{ form.groupeCibles.vars.choices|length - 6 }} supplémentaires)</span>

                                                </button>

                                            </div>

                                        {% endif %}

                                    </div>



                                    <!-- Quick actions -->

                                    <div class="mt-4 pt-3 border-top">

                                        <div class="d-flex justify-content-between align-items-center">

                                            <div>

                                                <button type="button" class="btn btn-sm btn-link text-success me-2" onclick="selectAllGroups()">

                                                    <i class="fas fa-check-circle me-1"></i>Tout sélectionner

                                                </button>

                                                <button type="button" class="btn btn-sm btn-link text-danger" onclick="deselectAllGroups()">

                                                    <i class="fas fa-times-circle me-1"></i>Tout désélectionner

                                                </button>

                                            </div>

                                            <small class="text-muted">

                                                <i class="fas fa-lightbulb me-1"></i>

                                                Laissez vide pour tous les groupes

                                            </small>

                                        </div>

                                    </div>



                                {% else %}

                                    <!-- Empty state -->

                                    <div class="text-center py-5">

                                        <div class="mb-3">

                                            <i class="fas fa-users fa-3x text-muted opacity-50"></i>

                                        </div>

                                        <h6 class="fw-semibold mb-2">Aucun groupe disponible</h6>

                                        <p class="text-muted small mb-0">Les groupes sont créés par les administrateurs.</p>

                                    </div>

                                {% endif %}



                                {{ form_errors(form.groupeCibles) }}

                                

                                <!-- Approval status badge (moved from bottom) -->

                                <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">

                                    <div class="text-muted small">

                                        <i class="fas fa-clock me-1"></i>

                                        En attente d'approbation

                                    </div>

                                    <div>

                                        <span class="badge bg-warning text-dark px-3 py-2">

                                            <i class="fas fa-hourglass-half me-1"></i>

                                            Validation requise

                                        </span>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div> <!-- Fin row g-4 -->



                <div class="mt-5 d-flex justify-content-between align-items-center">

                    <div class="text-muted">

                        <i class="fas fa-clock me-1"></i>

                        Temps d'approbation estimé : 24-48h

                    </div>

                    <div class="d-flex gap-2">

                        <a href="{{ path('evenements_client_events') }}" class="btn btn-secondary px-4">Annuler</a>

                        <button type="submit" class="btn btn-primary px-4">

                            <i class="fas fa-paper-plane me-1"></i>Soumettre la demande

                        </button>

                    </div>

                </div>



                {{ form_end(form) }}

            </div>

        </div>

    </div>

</div>



{% include 'partials/footer.html.twig' %}



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>

document.addEventListener('DOMContentLoaded', function() {
    if (window.__sahtyClientDemandeInitDone) {
        return;
    }
    window.__sahtyClientDemandeInitDone = true;


    const form = document.querySelector('form');

    if (form) {

        form.addEventListener('submit', function(e) {

            if (!form.checkValidity()) {

                e.preventDefault();

                e.stopPropagation();

            }

            form.classList.add('was-validated');

        });

    }



    // Validation des dates

    const dateDebut = document.querySelector('#{{ form.dateDebut.vars.id|default('') }}');

    const dateFin = document.querySelector('#{{ form.dateFin.vars.id|default('') }}');

    

    if (dateDebut && dateFin) {

        // Calculer la date minimum (J+2)

        const now = new Date();

        const minDate = new Date(now);

        minDate.setDate(now.getDate() + 2);

        

        // Formater pour l'attribut min (YYYY-MM-DDTHH:mm)

        const year = minDate.getFullYear();

        const month = String(minDate.getMonth() + 1).padStart(2, '0');

        const day = String(minDate.getDate()).padStart(2, '0');

        const hours = String(minDate.getHours()).padStart(2, '0');

        const minutes = String(minDate.getMinutes()).padStart(2, '0');

        const minDateStr = `${year}-${month}-${day}T${hours}:${minutes}`;

        

        dateDebut.min = minDateStr;

        dateFin.min = minDateStr;

        

        dateDebut.addEventListener('change', function() {

            if (this.value) {

                dateFin.min = this.value;

                // Si la date de fin est antérieure à la date de début, la réinitialiser

                if (dateFin.value && dateFin.value < this.value) {

                    dateFin.value = this.value;

                }

            }

        });

    }



    // Make entire card clickable

    const groupCards = document.querySelectorAll('.group-card');

    groupCards.forEach(card => {

        card.addEventListener('click', function(e) {

            const checkbox = this.querySelector('input[type="checkbox"]');

            if (e.target.tagName !== 'INPUT' && e.target.tagName !== 'LABEL') {

                checkbox.checked = !checkbox.checked;

            }

        });

    });



    const isEditionEl = document.getElementById('evenement_isEdition');

    const editionFieldBlocks = document.querySelectorAll('.edition-fields');

    const venueSearchBtn = document.getElementById('venue-search-btn');

    const venueCityInput = document.getElementById('venue-city-input');

    const venueResults = document.getElementById('venue-search-results');

    const lieuInput = document.getElementById('evenement_lieu');

    const typeInput = document.getElementById('evenement_type');

    const titleInput = document.getElementById('evenement_titre');

    const descriptionInput = document.getElementById('evenement_description');

    const tarifInput = document.getElementById('evenement_tarif');

    const dateDebutInput = document.getElementById('evenement_dateDebut');

    const dateFinInput = document.getElementById('evenement_dateFin');

    const modeEl = document.getElementById('evenement_mode');

    const platformEl = document.getElementById('evenement_meetingPlatform');

    const linkEl = document.getElementById('evenement_meetingLink');

    const platformWrap = document.getElementById('meeting-platform-wrapper');

    const linkWrap = document.getElementById('meeting-link-wrapper');

    const onlineConfigPanel = document.getElementById('online-config-panel');

    const meetingPreviewText = document.getElementById('meeting-preview-text');

    const placesInput = document.getElementById('evenement_placesMax');

    const resourcePlanBody = document.getElementById('resource-plan-body');

    const resourceRiskChip = document.getElementById('resource-risk-chip');

    function getFieldValue(primaryEl, fallbackName) {
        const byId = (primaryEl.value || '').trim();
        if (byId !== '') return byId;
        const byName = document.querySelector(`[name="${fallbackName}"]`);
        return ((byName.value) || '').trim();
    }



    function toggleEditionFields() {

        if (!isEditionEl) {

            return;

        }

        editionFieldBlocks.forEach((block) => {

            block.style.display = isEditionEl.checked ? '' : 'none';

        });

    }



    if (isEditionEl) {
        isEditionEl.addEventListener('change', toggleEditionFields);
        toggleEditionFields();
    }



    function updateMeetingFieldsVisibility() {

        if (!modeEl || !platformEl || !platformWrap || !linkWrap || !onlineConfigPanel) {

            return;

        }



        const isOnline = modeEl.value === 'en_ligne' || modeEl.value === 'hybride';

        const isPresential = modeEl.value === 'presentiel' || modeEl.value === 'hybride';

        const venuePanel = document.getElementById('venue-reco-panel');

        const localVenueResults = document.getElementById('venue-search-results');

        onlineConfigPanel.style.display = isOnline ? '' : 'none';

        platformWrap.style.display = isOnline ? '' : 'none';

        linkWrap.style.display = (isOnline && platformEl.value === 'custom') ? '' : 'none';

        if (venuePanel) {

            venuePanel.style.display = isPresential ? '' : 'none';

            if (!isPresential && localVenueResults) {

                localVenueResults.innerHTML = '';

            }

        }



        if (!isOnline) {

            platformEl.value = '';

            if (linkEl) {

                linkEl.value = '';

            }

            if (meetingPreviewText) {                meetingPreviewText.textContent = "Configuration cachee: cet evenement n'est pas en ligne.";

            }

            return;

        }



        if (isOnline && platformEl.value !== 'custom' && linkEl) {

            linkEl.value = '';

        }



        if (meetingPreviewText) {

            if (platformEl.value === 'custom' && linkEl.value) {

                meetingPreviewText.innerHTML = `<a href="${linkEl.value}" target="_blank" rel="noopener noreferrer">${linkEl.value}</a>`;

            } else if (platformEl.value === 'jitsi' || platformEl.value === '') {

                const baseTitle = (document.getElementById('evenement_titre').value || 'evenement')

                    .toLowerCase()

                    .replace(/[^a-z0-9]+/g, '-')

                    .replace(/^-+|-+$/g, '')

                    .slice(0, 40);

                meetingPreviewText.textContent = `https://meet.jit.si/sahty-${baseTitle || 'session'}`;

            } else {

                meetingPreviewText.textContent = 'Aperçu indisponible pour cette configuration.';

            }

        }

    }



    modeEl.addEventListener('change', updateMeetingFieldsVisibility);

    platformEl.addEventListener('change', updateMeetingFieldsVisibility);

    linkEl.addEventListener('input', updateMeetingFieldsVisibility);

    document.getElementById('evenement_titre').addEventListener('input', updateMeetingFieldsVisibility);

    updateMeetingFieldsVisibility();



    async function refreshResourcePlan() {

        if (!typeInput || !modeEl || !resourcePlanBody || !resourceRiskChip) {

            return;

        }



        const typeValue = getFieldValue(typeInput, 'evenement[type]');

        const modeValue = getFieldValue(modeEl, 'evenement[mode]');

        const placesValue = parseInt((placesInput.value || '').trim(), 10);



        if (typeValue === '' || modeValue === '' || !Number.isFinite(placesValue) || placesValue <= 0) {

            resourceRiskChip.className = 'resource-chip bg-light text-muted border';

            resourceRiskChip.textContent = 'En attente de donnees';

            resourcePlanBody.innerHTML = 'Renseignez le type, le mode et une capacité valide pour lancer l'analyse.';

            return;

        }



        const url = new URL('{{ path('evenements_api_plan_ressources') }}', window.location.origin);

        url.searchParams.set('type', typeValue);

        url.searchParams.set('mode', modeValue);

        url.searchParams.set('capacity', String(placesValue));

        url.searchParams.set('strict', '1');



        try {

            const response = await fetchWithTimeout(url.toString(), 12000);

            const data = await response.json();

            if (data.ready === false) {

                resourceRiskChip.className = 'resource-chip bg-light text-muted border';

                resourceRiskChip.textContent = 'En attente de donnees';

                resourcePlanBody.innerHTML = data.message || 'Complétez les informations pour lancer le plan.';

                return;

            }



            const plan = data.plan || null;

            if (!plan) {

                resourcePlanBody.innerHTML = '<div class="text-danger">Plan indisponible.</div>';

                return;

            }



            const riskLevel = (plan.risk && plan.risk.level) ? plan.risk.level : 'moyen';

            const riskClass = riskLevel === 'faible'
                ? 'bg-success text-white'
                : (riskLevel === 'moyen' ? 'bg-warning text-dark' : 'bg-danger text-white');

            resourceRiskChip.className = `resource-chip ${riskClass}`;

            resourceRiskChip.textContent = `Risque ${riskLevel.toUpperCase()}`;



            const rows = (plan.resources || []).slice(0, 6).map((item) => {

                const status = item.status === 'ok'
                    ? '<span class="text-success">OK</span>'
                    : (item.status === 'attention' ? '<span class="text-warning">Tension</span>' : '<span class="text-danger">Rupture</span>');

                return `<tr>

                    <td>${item.ressource}</td>

                    <td>${item.required}</td>

                    <td>${item.available}</td>

                    <td>${item.shortage}</td>

                    <td>${status}</td>

                </tr>`;

            }).join('');



            const actions = (plan.actions || []).slice(0, 3).map((a) => `<li>${a}</li>`).join('');



            resourcePlanBody.innerHTML = `

                <div class="mb-2">${plan.risk.message || ''}</div>

                <div class="table-responsive">

                    <table class="table table-sm mb-2">

                        <thead><tr><th>Ressource</th><th>Besoin</th><th>Stock</th><th>Manque</th><th>Etat</th></tr></thead>

                        <tbody>${rows}</tbody>

                    </table>

                </div>

                <div><strong>Actions avant validation:</strong></div>

                <ul class="mb-0">${actions}</ul>

            `;

        } catch (e) {

            resourcePlanBody.innerHTML = '<div class="text-danger">Impossible de calculer le plan pour le moment.</div>';

        }

    }



    typeInput.addEventListener('change', refreshResourcePlan);

    modeEl.addEventListener('change', refreshResourcePlan);

    placesInput.addEventListener('input', refreshResourcePlan);

    refreshResourcePlan();



    function applyVenueToInput(nom, adresse) {

        if (!lieuInput) {

            return;

        }

        const finalLieu = [nom || '', adresse || ''].filter((value) => value !== '').join(', ');

        lieuInput.value = finalLieu;

        lieuInput.dispatchEvent(new Event('input', { bubbles: true }));

        lieuInput.dispatchEvent(new Event('change', { bubbles: true }));

        lieuInput.focus();

    }



    window.sahtyApplyVenue = function (button) {

        if (!button) {

            return;

        }

        applyVenueToInput(

            button.getAttribute('data-lieu-nom') || '',

            button.getAttribute('data-lieu-adresse') || ''

        );

    };



    venueResults.addEventListener('click', function (event) {

        const target = event.target;

        if (!(target instanceof Element)) {

            return;

        }

        const button = target.closest('.venue-pick-btn');

        if (!button) {

            return;

        }

        applyVenueToInput(

            button.getAttribute('data-lieu-nom') || '',

            button.getAttribute('data-lieu-adresse') || ''

        );

    });



    const planningIaGenerateBtn = document.getElementById('planning-ia-generate-btn');
    const planningIaBody = document.getElementById('planning-ia-body');

    function resolveTypeModeDefaults() {
        const typeValueRaw = getFieldValue(typeInput, 'evenement[type]');
        const modeValueRaw = getFieldValue(modeEl, 'evenement[mode]');
        const typeValue = typeValueRaw !== '' ? typeValueRaw : 'formation';
        const modeValue = modeValueRaw !== '' ? modeValueRaw : 'presentiel';
        return { typeValue, modeValue, typeMissing: typeValueRaw === '', modeMissing: modeValueRaw === '' };
    }

    async function fetchWithTimeout(url, ms = 10000) {
        const controller = new AbortController();
        const id = setTimeout(() => controller.abort(), ms);
        try {
            const response = await fetch(url, { headers: { 'Accept': 'application/json' }, signal: controller.signal });
            return response;
        } finally {
            clearTimeout(id);
        }
    }

    function inferAudienceFromGroups() {
        const checkedLabels = Array.from(document.querySelectorAll("input[name='evenement[groupeCibles][]']:checked"))
            .map((checkbox) => {
                const label = document.querySelector(`label[for='${checkbox.id}']`);
                return (label.textContent || '').toLowerCase();
            })
            .join(' ');

        if (checkedLabels.includes('etudiant')) {
            return 'etudiants';
        }
        if (checkedLabels.includes('medecin') || checkedLabels.includes('professionnel') || checkedLabels.includes('laboratoire')) {
            return 'professionnels';
        }
        return 'mixte';
    }

    function inferLevelFromText() {
        const text = `${(titleInput.value || '')} ${(descriptionInput.value || '')}`.toLowerCase();
        if (text.includes('avancé') || text.includes('avance') || text.includes('expert') || text.includes('complexe')) {
            return 'avance';
        }
        if (text.includes('introduction') || text.includes('débutant') || text.includes('debutant') || text.includes('initiation')) {
            return 'intro';
        }
        return 'intermediaire';
    }

    function inferDurationMinutes() {
        const start = dateDebutInput.value ? new Date(dateDebutInput.value) : null;
        const end = dateFinInput.value ? new Date(dateFinInput.value) : null;
        if (start instanceof Date && end instanceof Date && !isNaN(start) && !isNaN(end) && end > start) {
            const diff = Math.round((end.getTime() - start.getTime()) / 60000);
            return Math.max(60, Math.min(diff, 720));
        }
        return 180;
    }

    function formatPhaseLabel(label) {
        const map = {
            ouverture: 'Ouverture',
            introduction: 'Introduction',
            keynote: 'Keynote',
            panel: 'Panel',
            pause: 'Pause',
            cloture: 'Clôture',
            intervention_invite: 'Intervention invité',
            atelier_principal: 'Atelier principal',
            module_pratique: 'Module pratique',
            etude_de_cas: 'Étude de cas',
            session_qr: 'Session Q&R',
            orientation: 'Orientation',
            flux_depistage: 'Flux dépistage',
            briefing: 'Briefing',
        };
        return map[label] || (label || '').replace(/_/g, ' ').replace(/\b\w/g, (m) => m.toUpperCase());
    }

    planningIaGenerateBtn.addEventListener('click', async function () {
        if (!planningIaBody || !typeInput || !modeEl) {
            return;
        }

        const { typeValue, modeValue, typeMissing, modeMissing } = resolveTypeModeDefaults();
        if (typeMissing || modeMissing) {
            planningIaBody.innerHTML = '<div class="alert alert-info py-2 mb-2">Type/Mode incomplet: valeurs par défaut appliquees (formation, presentiel).</div>' + planningIaBody.innerHTML;
        }

        planningIaBody.innerHTML = '<div class="text-muted">Génération IA en cours...</div>';

        const url = new URL('{{ path('evenements_api_planning_ia') }}', window.location.origin);
        url.searchParams.set('type', typeValue);
        url.searchParams.set('mode', modeValue);
        url.searchParams.set('audience', inferAudienceFromGroups());
        url.searchParams.set('level', inferLevelFromText());
        url.searchParams.set('duration', String(inferDurationMinutes()));

        try {
            const response = await fetchWithTimeout(url.toString(), 12000);
            const data = await response.json();

            if (!data.ready || !data.recommendation || !Array.isArray(data.recommendation.phases)) {
                planningIaBody.innerHTML = `<div class="alert alert-info py-2 mb-0">${data.message || 'Le modèle IA n\'est pas prêt.'}</div>`;
                return;
            }

            const rec = data.recommendation;
            const confidence = rec.confidence ? `${Math.round(rec.confidence * 100)}%` : 'N/A';
            const phases = rec.phases
                .map((p) => `<li><strong>${p.ordre}. ${formatPhaseLabel(p.phase_label)}</strong> - ${p.duree_min} min</li>`)
                .join('');

            planningIaBody.innerHTML = `
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-semibold">Planning recommandé</div>
                    <span class="badge bg-primary-subtle text-primary border">Confiance modèle: ${confidence}</span>
                </div>
                <ol class="mb-2">${phases}</ol>
                <div class="text-muted">Vous pouvez garder ce plan comme base puis l'ajuster dans le studio de scénario ci-dessous.</div>
            `;
        } catch (e) {
            planningIaBody.innerHTML = '<div class="alert alert-danger py-2 mb-0">Erreur de communication avec le service IA planning.</div>';
        }
    });

    venueSearchBtn.addEventListener('click', async function () {

        const selectedMode = (modeEl.value || '').trim();

        if (selectedMode === 'en_ligne') {

            venueResults.innerHTML = '<div class="alert alert-info py-2 mb-0">Mode en ligne: la recherche de lieu presentiel est desactivee.</div>';

            return;

        }



        const city = venueCityInput.value.trim() || '';

        if (!city) {

            venueResults.innerHTML = '<div class="alert alert-warning py-2 mb-0">Veuillez saisir une ville.</div>';

            return;

        }



        venueResults.innerHTML = '<div class="text-muted small">Recherche en cours...</div>';
        const defaults = resolveTypeModeDefaults();
        if (defaults.typeMissing || defaults.modeMissing) {
            venueResults.innerHTML = '<div class="alert alert-info py-2 mb-2">Type/Mode incomplet: valeurs par défaut appliquees (formation, presentiel).</div>' + venueResults.innerHTML;
        }



        const url = new URL('{{ path('evenements_api_lieux_recommandes') }}', window.location.origin);

        url.searchParams.set('ville', city);

        const { typeValue, modeValue, typeMissing, modeMissing } = resolveTypeModeDefaults();

        url.searchParams.set('type', typeValue);

        if (placesInput.value) {

            url.searchParams.set('capacity', placesInput.value);

        }

        url.searchParams.set('mode', modeValue);

        if (titleInput.value.trim()) {

            url.searchParams.set('title', titleInput.value.trim());

        }

        if (descriptionInput.value.trim()) {

            url.searchParams.set('description', descriptionInput.value.trim());

        }

        if (tarifInput.value.trim()) {

            url.searchParams.set('budget', tarifInput.value.trim());

        }

        if (dateDebutInput.value) {

            url.searchParams.set('dateDebut', dateDebutInput.value);

        }

        if (dateFinInput.value) {

            url.searchParams.set('dateFin', dateFinInput.value);

        }



        try {

            const response = await fetchWithTimeout(url.toString(), 12000);

            const data = await response.json();



            if (!data.success || !Array.isArray(data.lieux) || data.lieux.length === 0) {

                venueResults.innerHTML = `<div class="alert alert-info py-2 mb-0">${data.message || 'Aucun lieu trouvé.'}</div>`;

                return;

            }



            const escapeAttr = (value) => String(value || '')

                .replace(/&/g, '&amp;')

                .replace(/"/g, '&quot;')

                .replace(/</g, '&lt;')

                .replace(/>/g, '&gt;');



            venueResults.innerHTML = data.lieux.map((lieu) => {

                const phone = (lieu.contacts && lieu.contacts.telephone)
                    ? `<div><i class="fas fa-phone me-1"></i>${lieu.contacts.telephone}</div>`
                    : '';

                const site = (lieu.contacts && lieu.contacts.site)
                    ? `<div><i class="fas fa-globe me-1"></i><a href="${lieu.contacts.site}" target="_blank" rel="noopener noreferrer">Site</a></div>`
                    : '';

                return `

                    <div class="border rounded p-2 mb-2 bg-white">

                        <div class="d-flex justify-content-between align-items-start">

                            <div>

                                <div class="fw-semibold">${lieu.nom}</div>

                                <div class="small text-muted">${lieu.adresse} - ${lieu.distance_km} km</div>

                                <div class="small text-muted">Score: ${lieu.score}/100 | ${lieu.indice_evenements_similaires}</div>

                                <div class="small text-muted">${phone}${site}</div>

                            </div>

                            <button type="button" class="btn btn-sm btn-outline-success venue-pick-btn" data-lieu-nom="${escapeAttr(lieu.nom)}" data-lieu-adresse="${escapeAttr(lieu.adresse)}" onclick="window.sahtyApplyVenue && window.sahtyApplyVenue(this)">

                                Utiliser

                            </button>

                        </div>

                    </div>

                `;

            }).join('');



        } catch (e) {

            venueResults.innerHTML = '<div class="alert alert-danger py-2 mb-0">Service de recommandation indisponible pour le moment.</div>';

        }

    });

});



// Toggle groups visibility

function toggleGroups() {

    const hiddenGroups = document.getElementById('hiddenGroups');

    const toggleIcon = document.getElementById('toggleIcon');

    const toggleText = document.getElementById('toggleText');

    const visibleCount = 6;

    const totalGroups = {{ form.groupeCibles.vars.choices|length }};

    

    if (hiddenGroups && hiddenGroups.style.display === 'none') {

        hiddenGroups.style.display = 'flex';

        toggleIcon.className = 'fas fa-chevron-up me-1';

        toggleText.textContent = 'Voir moins de groupes';

    } else if (hiddenGroups) {

        hiddenGroups.style.display = 'none';

        toggleIcon.className = 'fas fa-chevron-down me-1';

        toggleText.textContent = `Voir tous les groupes (${totalGroups - visibleCount} supplémentaires)`;

    }

}



// Filter groups by search

function filterGroups() {

    const searchInput = document.getElementById('groupSearch');

    if (!searchInput) return;

    

    const filter = searchInput.value.toLowerCase();

    const groupItems = document.querySelectorAll('.group-item');

    

    groupItems.forEach(item => {

        const label = item.getAttribute('data-label');

        if (label.includes(filter)) {

            item.style.display = '';

        } else {

            item.style.display = 'none';

        }

    });

    

    // Show "no results" message if needed

    const visibleItems = document.querySelectorAll('.group-item[style="display: none;"]').length;

    const totalItems = groupItems.length;

    

    let noResultsMsg = document.getElementById('noResultsMsg');

    

    if (visibleItems === totalItems && totalItems > 0) {

        if (!noResultsMsg) {

            noResultsMsg = document.createElement('div');

            noResultsMsg.id = 'noResultsMsg';

            noResultsMsg.className = 'text-center py-4 text-muted';

            noResultsMsg.innerHTML = '<i class="fas fa-search me-2"></i>Aucun groupe trouvé';

            document.getElementById('limitedGroups').appendChild(noResultsMsg);

        }

    } else if (noResultsMsg) {

        noResultsMsg.remove();

    }

}



// Select all groups

function selectAllGroups() {

    const checkboxes = document.querySelectorAll('input[name="{{ form.groupeCibles.vars.full_name }}[]"]');

    checkboxes.forEach(checkbox => {

        checkbox.checked = true;

    });

}



// Deselect all groups

function deselectAllGroups() {

    const checkboxes = document.querySelectorAll('input[name="{{ form.groupeCibles.vars.full_name }}[]"]');

    checkboxes.forEach(checkbox => {

        checkbox.checked = false;

    });

}

</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.__sahtyClientDemandeInitDone) {
        return;
    }
    window.__sahtyClientDemandeInitDone = true;

    const venueBtn = document.getElementById('venue-search-btn');
    const planningBtn = document.getElementById('planning-ia-generate-btn');
    const planningAcceptBtn = document.getElementById('planning-ia-accept-btn');
    const planningCustomizeBtn = document.getElementById('planning-ia-customize-btn');
    const planningRejectBtn = document.getElementById('planning-ia-reject-btn');
    const planningRegenerateBtn = document.getElementById('planning-ia-regenerate-btn');
    const planningActions = document.getElementById('planning-ia-actions');
    const planningStatus = document.getElementById('planning-ia-status');
    const planningDecisionInput = document.getElementById('planning-ia-decision');
    const planningPayloadInput = document.getElementById('planning-ia-payload');
    const cityInput = document.getElementById('venue-city-input');
    const venueResults = document.getElementById('venue-search-results');
    const planningBody = document.getElementById('planning-ia-body');

    const typeEl = document.getElementById('evenement_type');
    const modeEl = document.getElementById('evenement_mode');
    const placesEl = document.getElementById('evenement_placesMax');
    const titleEl = document.getElementById('evenement_titre');
    const descEl = document.getElementById('evenement_description');
    const tarifEl = document.getElementById('evenement_tarif');
    const dateDebutEl = document.getElementById('evenement_dateDebut');
    const dateFinEl = document.getElementById('evenement_dateFin');
    const lieuEl = document.getElementById('evenement_lieu');
    const lieuFeedbackEl = document.getElementById('lieu-validation-feedback');
    const venueSourceInput = document.getElementById('venue-source-input');
    let selectingVenue = false;
    let lieuValidationTimer = null;
    let lieuValidationSeq = 0;
    let lastPlanningPhases = [];

    function setLieuFeedback(message, state) {
        if (!lieuFeedbackEl) return;
        lieuFeedbackEl.className = 'small mt-1';
        if (state === 'ok') {
            lieuFeedbackEl.classList.add('text-success');
        } else if (state === 'warn') {
            lieuFeedbackEl.classList.add('text-warning');
        } else if (state === 'error') {
            lieuFeedbackEl.classList.add('text-danger');
        } else {
            lieuFeedbackEl.classList.add('text-muted');
        }
        lieuFeedbackEl.textContent = message || '';
    }

    async function validateLieuInline() {
        if (!lieuEl || !modeEl) return;
        const lieu = (lieuEl.value || '').trim();
        if (lieu === '') {
            setLieuFeedback('', 'info');
            return;
        }

        const mode = (modeEl.value || 'presentiel').trim() || 'presentiel';
        if (mode !== 'presentiel' && mode !== 'hybride') {
            setLieuFeedback('', 'info');
            return;
        }

        const currentSeq = ++lieuValidationSeq;
        setLieuFeedback('Verification du lieu...', 'info');

        try {
            const url = new URL('{{ path('evenements_api_validation_lieu') }}', window.location.origin);
            url.searchParams.set('lieu', lieu);
            url.searchParams.set('mode', mode);
            const response = await fetch(url.toString(), { headers: { Accept: 'application/json' } });
            const data = await response.json();
            if (currentSeq !== lieuValidationSeq) return;

            if (data && data.success && data.valid) {
                setLieuFeedback((data.message || 'Lieu verifie.').toString(), 'ok');
                return;
            }

            const msg = (data && data.message)
                ? String(data.message)
                : 'Lieu non verifiable pour le moment.';
            setLieuFeedback(msg, 'warn');
        } catch (e) {
            if (currentSeq !== lieuValidationSeq) return;
            setLieuFeedback('Verification temporairement indisponible.', 'warn');
        }
    }

    if (lieuEl && venueSourceInput) {
        lieuEl.addEventListener('input', function () {
            if (!selectingVenue) {
                venueSourceInput.value = 'manual';
            }
            if (lieuValidationTimer) {
                clearTimeout(lieuValidationTimer);
            }
            lieuValidationTimer = setTimeout(validateLieuInline, 500);
        });
        lieuEl.addEventListener('blur', validateLieuInline);
    }

    if (modeEl) {
        modeEl.addEventListener('change', function () {
            if (lieuValidationTimer) {
                clearTimeout(lieuValidationTimer);
            }
            lieuValidationTimer = setTimeout(validateLieuInline, 250);
        });
    }

    function defaults() {
        return {
            type: (typeEl && typeEl.value ? typeEl.value : 'formation').trim() || 'formation',
            mode: (modeEl && modeEl.value ? modeEl.value : 'presentiel').trim() || 'presentiel'
        };
    }

    function inferAudience() {
        const labels = Array.from(document.querySelectorAll("input[name='evenement[groupeCibles][]']:checked"))
            .map((checkbox) => {
                const label = document.querySelector("label[for='" + checkbox.id + "']");
                return (label ? label.textContent : '').toLowerCase();
            })
            .join(' ');
        if (labels.indexOf('etudiant') >= 0) return 'etudiants';
        if (labels.indexOf('medecin') >= 0 || labels.indexOf('professionnel') >= 0 || labels.indexOf('laboratoire') >= 0) return 'professionnels';
        return 'mixte';
    }

    function inferLevel() {
        const text = ((titleEl ? titleEl.value : '') + ' ' + (descEl ? descEl.value : '')).toLowerCase();
        if (text.indexOf('avance') >= 0 || text.indexOf('expert') >= 0) return 'avance';
        if (text.indexOf('introduction') >= 0 || text.indexOf('debutant') >= 0 || text.indexOf('initiation') >= 0) return 'intro';
        return 'intermediaire';
    }

    function inferDuration() {
        const s = dateDebutEl && dateDebutEl.value ? new Date(dateDebutEl.value) : null;
        const e = dateFinEl && dateFinEl.value ? new Date(dateFinEl.value) : null;
        if (s && e && !isNaN(s) && !isNaN(e) && e > s) {
            const diff = Math.round((e.getTime() - s.getTime()) / 60000);
            return Math.max(60, Math.min(diff, 720));
        }
        return 180;
    }

    function prettyPhase(label) {
        const map = {
            ouverture: 'Ouverture',
            introduction: 'Introduction',
            keynote: 'Keynote',
            panel: 'Panel',
            pause: 'Pause',
            cloture: 'Cloture',
            intervention_invite: 'Intervention invitee',
            atelier_principal: 'Atelier principal',
            module_pratique: 'Module pratique',
            etude_de_cas: 'Etude de cas',
            session_qr: 'Session Q&R',
            orientation: 'Orientation',
            flux_depistage: 'Flux depistage',
            briefing: 'Briefing'
        };
        return map[label] || String(label || '').replace(/_/g, ' ').replace(/\b\w/g, (m) => m.toUpperCase());
    }

    function toScenarioPhases(phases) {
        return (phases || []).map((p, i) => ({
            title: prettyPhase(p.phase_label),
            duration: parseInt(p.duree_min, 10) || 15,
            intensity: Math.max(1, Math.min(5, Math.round((parseInt(p.duree_min, 10) || 15) / 20))),
            type: (function () {
                const key = (p.phase_label || '').toLowerCase();
                if (key.includes('ouverture') || key.includes('intro')) return 'intro';
                if (key.includes('pause')) return 'break';
                if (key.includes('atelier') || key.includes('cas') || key.includes('pratique')) return 'workshop';
                if (key.includes('q') || key.includes('orientation')) return 'qa';
                if (key.includes('cloture')) return 'close';
                if (key.includes('invite')) return 'guest';
                return 'talk';
            })(),
            order: parseInt(p.ordre, 10) || (i + 1)
        }));
    }

    function showPlanningActions() {
        planningActions.classList.remove('d-none');
    }

    function setPlanningStatus(message, state) {
        if (!planningStatus) return;
        planningStatus.className = 'small mt-2';
        if (state === 'ok') {
            planningStatus.classList.add('text-success');
        } else if (state === 'warn') {
            planningStatus.classList.add('text-warning');
        } else {
            planningStatus.classList.add('text-muted');
        }
        planningStatus.textContent = message;
    }

    function applyPlanningToStudio(accepted) {
        if (!lastPlanningPhases.length) {
            setPlanningStatus('Aucun planning IA disponible. Generez d abord.', 'warn');
            return;
        }
        if (window.SahtyScenarioStudio && typeof window.SahtyScenarioStudio.applyPhases === 'function') {
            window.SahtyScenarioStudio.applyPhases(toScenarioPhases(lastPlanningPhases));
            document.getElementById('scenario-track').scrollIntoView({ behavior: 'smooth', block: 'center' });
            if (accepted) {
                setPlanningStatus('Planning accepte et charge dans le studio.', 'ok');
            } else {
                setPlanningStatus('Planning charge pour personnalisation.', 'ok');
            }
        } else {
            setPlanningStatus('Studio scenario indisponible.', 'warn');
        }
    }

    async function generatePlanning() {
        const d = defaults();
        planningBody.innerHTML = '<div class="planning-showcase"><div class="text-muted">Generation IA en cours...</div></div>';
        planningActions.classList.add('d-none');
        setPlanningStatus('', 'info');

        const url = new URL('{{ path('evenements_api_planning_ia') }}', window.location.origin);
        url.searchParams.set('type', d.type);
        url.searchParams.set('mode', d.mode);
        const audience = inferAudience();
        const level = inferLevel();
        const duration = inferDuration();
        url.searchParams.set('audience', audience);
        url.searchParams.set('level', level);
        url.searchParams.set('duration', String(duration));

        try {
            const res = await fetch(url.toString(), { headers: { Accept: 'application/json' } });
            const data = await res.json();
            if (!data || !data.ready || !data.recommendation || !Array.isArray(data.recommendation.phases)) {
                planningBody.innerHTML = '<div class="alert alert-info py-2 mb-0">' + ((data && data.message) ? data.message : 'Modele IA indisponible.') + '</div>';
                return;
            }

            const rec = data.recommendation;
            const phases = rec.phases || [];
            lastPlanningPhases = phases;
            const totalMin = phases.reduce((acc, p) => acc + (parseInt(p.duree_min, 10) || 0), 0);
            const confidence = rec.confidence ? Math.round(rec.confidence * 100) + '%' : 'N/A';

            const cards = phases.map((p) => {
                const step = parseInt(p.ordre, 10) || 0;
                const duration = parseInt(p.duree_min, 10) || 0;
                return '<div class="planning-step">'
                    + '<div class="planning-step-index">Etape ' + step + '</div>'
                    + '<div class="planning-step-title">' + prettyPhase(p.phase_label) + '</div>'
                    + '<div class="planning-step-meta"><span>Duree</span><strong>' + duration + ' min</strong></div>'
                    + '</div>';
            }).join('');

            planningBody.innerHTML = ''
                + '<div class="planning-showcase">'
                + '  <div class="planning-headline">'
                + '    <h6><i class="fas fa-wand-magic-sparkles me-1"></i>Planning IA recommande</h6>'
                + '    <div class="d-flex gap-2">'
                + '      <span class="planning-kpi"><i class="fas fa-layer-group"></i>' + phases.length + ' phases</span>'
                + '      <span class="planning-kpi"><i class="fas fa-clock"></i>' + totalMin + ' min</span>'
                + '      <span class="planning-kpi"><i class="fas fa-shield-check"></i>Confiance: ' + confidence + '</span>'
                + '    </div>'
                + '  </div>'
                + '  <div class="planning-timeline">' + cards + '</div>'
                + '  <div class="planning-note">'
                + '    <i class="fas fa-lightbulb me-1"></i>'
                + '    Base IA: audience=' + audience + ', niveau=' + level + ', duree=' + duration + ' min.'
                + '    Acceptez ce plan ou personnalisez-le dans le studio de scenario ci-dessous.'
                + '  </div>'
                + '</div>';

            showPlanningActions();
            setPlanningStatus('Planning pret. Choisissez Accepter ou Personnaliser.', 'info');
            if (planningDecisionInput) planningDecisionInput.value = '';
            if (planningPayloadInput) planningPayloadInput.value = JSON.stringify(phases || []);
            window.dispatchEvent(new CustomEvent('sahty:planning-generated', { detail: { phases: toScenarioPhases(phases) } }));
        } catch (e) {
            planningBody.innerHTML = '<div class="alert alert-danger py-2 mb-0">Erreur de communication avec le service IA.</div>';
        }
    }

    if (planningBtn && planningBody) {
        planningBtn.addEventListener('click', async function (ev) {
            ev.preventDefault();
            ev.stopImmediatePropagation();
            await generatePlanning();
        }, true);
    }

    if (planningRegenerateBtn) {
        planningRegenerateBtn.addEventListener('click', async function () {
            await generatePlanning();
        });
    }

    if (planningAcceptBtn) {
        planningAcceptBtn.addEventListener('click', function () {
            applyPlanningToStudio(true);
            if (planningDecisionInput) planningDecisionInput.value = 'accepted';
            setPlanningStatus('Planning approuve. Il sera utilise comme base officielle.', 'ok');
        });
    }

    if (planningCustomizeBtn) {
        planningCustomizeBtn.addEventListener('click', function () {
            applyPlanningToStudio(false);
            if (planningDecisionInput) planningDecisionInput.value = 'customized';
            setPlanningStatus('Planning en mode personnalisation.', 'ok');
        });
    }

    if (planningRejectBtn) {
        planningRejectBtn.addEventListener('click', function () {
            lastPlanningPhases = [];
            if (planningDecisionInput) planningDecisionInput.value = 'rejected';
            if (planningPayloadInput) planningPayloadInput.value = '';
            planningActions.classList.add('d-none');
            planningBody.innerHTML = '<div class="alert alert-warning py-2 mb-0">Planning refuse. Vous pouvez en regenerer un autre ou construire manuellement votre scenario.</div>';
            setPlanningStatus('Planning refuse.', 'warn');
        });
    }

    if (venueBtn && venueResults) {
        venueBtn.addEventListener('click', async function (ev) {
            ev.preventDefault();
            ev.stopImmediatePropagation();

            const city = (cityInput && cityInput.value ? cityInput.value : '').trim();
            if (!city) {
                venueResults.innerHTML = '<div class="alert alert-warning py-2 mb-0">Veuillez saisir une ville.</div>';
                return;
            }

            const d = defaults();
            venueResults.innerHTML = '<div class="text-muted small">Recherche en cours...</div>';

            const url = new URL('{{ path('evenements_api_lieux_recommandes') }}', window.location.origin);
            url.searchParams.set('ville', city);
            url.searchParams.set('type', d.type);
            url.searchParams.set('mode', d.mode);
            if (placesEl && placesEl.value) url.searchParams.set('capacity', placesEl.value);
            if (titleEl && titleEl.value) url.searchParams.set('title', titleEl.value);
            if (descEl && descEl.value) url.searchParams.set('description', descEl.value);
            if (tarifEl && tarifEl.value) url.searchParams.set('budget', tarifEl.value);
            if (dateDebutEl && dateDebutEl.value) url.searchParams.set('dateDebut', dateDebutEl.value);
            if (dateFinEl && dateFinEl.value) url.searchParams.set('dateFin', dateFinEl.value);

            try {
                const res = await fetch(url.toString(), { headers: { Accept: 'application/json' } });
                const data = await res.json();
                if (!data || !data.success || !Array.isArray(data.lieux) || data.lieux.length === 0) {
                    venueResults.innerHTML = '<div class="alert alert-info py-2 mb-0">' + ((data && data.message) ? data.message : 'Aucun lieu trouve.') + '</div>';
                    return;
                }
                venueResults.innerHTML = data.lieux.map(function (lieu) {
                    const nom = lieu.nom || '';
                    const adresse = lieu.adresse || '';
                    return '<div class="border rounded p-2 mb-2 bg-white">'
                        + '<div class="d-flex justify-content-between align-items-start">'
                        + '<div><div class="fw-semibold">' + nom + '</div><div class="small text-muted">' + adresse + '</div></div>'
                        + '<button type="button" class="btn btn-sm btn-outline-success">Utiliser</button>'
                        + '</div></div>';
                }).join('');

                Array.from(venueResults.querySelectorAll('button.btn-outline-success')).forEach(function (btn, idx) {
                    btn.addEventListener('click', function () {
                        const item = data.lieux[idx] || {};
                        const nom = item.nom || '';
                        const adr = item.adresse || '';
                        if (lieuEl) {
                            selectingVenue = true;
                            lieuEl.value = [nom, adr].filter(Boolean).join(', ');
                            lieuEl.dispatchEvent(new Event('input', { bubbles: true }));
                            lieuEl.dispatchEvent(new Event('change', { bubbles: true }));
                            selectingVenue = false;
                        }
                        if (venueSourceInput) {
                            venueSourceInput.value = 'search';
                        }
                        setLieuFeedback('Lieu choisi depuis les recommandations.', 'ok');
                    });
                });
            } catch (e) {
                venueResults.innerHTML = '<div class="alert alert-danger py-2 mb-0">Service de recommandation indisponible pour le moment.</div>';
            }
        }, true);
    }
});
</script>
</body>

</html>










