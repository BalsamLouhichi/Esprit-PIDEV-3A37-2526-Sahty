            margin-bottom: 1rem;
            position: relative;
            display: inline-block;
        }

        .sahty-logo::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
