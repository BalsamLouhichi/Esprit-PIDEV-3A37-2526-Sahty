{# templates/emails/commande_acceptee_patient.html.twig #}
<div style="margin:0;padding:24px;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#102a43;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:640px;margin:0 auto;background:#ffffff;border:1px solid #d9e2ec;border-radius:12px;overflow:hidden;">
        <tr>
            <td style="background:#1D5D9B;padding:20px 24px;">
                <div style="font-size:22px;line-height:1;font-weight:800;color:#ffffff;letter-spacing:.2px;">Sahty</div>
                <div style="font-size:13px;color:#d6e8ff;margin-top:8px;">Notification de commande</div>
            </td>
        </tr>

        <tr>
            <td style="padding:24px;">
                <h2 style="margin:0 0 12px 0;font-size:22px;line-height:1.3;color:#0f4c81;">Commande acceptee</h2>

                <p style="margin:0 0 14px 0;font-size:15px;line-height:1.6;">
                    Bonjour <strong>{{ commande.nomClient }}</strong>,
                </p>

                <p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;">
                    Votre commande <strong>#{{ commande.numero }}</strong> a ete acceptee
                    par la parapharmacie <strong>{{ parapharmacie.nom }}</strong>.
                </p>

                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 18px 0;border:1px solid #e6edf5;border-radius:10px;background:#f8fbff;">
                    <tr>
                        <td style="padding:14px 16px;font-size:14px;line-height:1.7;color:#334e68;">
                            <div><strong>Numero:</strong> #{{ commande.numero }}</div>
                            <div><strong>Statut:</strong> {{ commande.getStatutLibelle() }}</div>
                            <div><strong>Date de mise a jour:</strong> {{ "now"|date("d/m/Y H:i") }}</div>
                        </td>
                    </tr>
                </table>

                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 16px 0;">
                    <tr>
                        <td style="border-radius:8px;background:#1D5D9B;">
                            <a href="{{ url('app_mes_commandes') }}" style="display:inline-block;padding:11px 18px;color:#ffffff;text-decoration:none;font-weight:700;font-size:14px;">
                                Voir mes commandes
                            </a>
                        </td>
                    </tr>
                </table>

                <p style="margin:0;font-size:14px;line-height:1.6;color:#486581;">
                    Merci pour votre confiance.<br>
                    L equipe <strong>Sahty</strong>
                </p>
            </td>
        </tr>
    </table>
</div>
