{% extends 'base.html.twig' %}

{% block title %}Nouvelle parapharmacie - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="mb-0">Ajouter une parapharmacie</h4>
        <a href="{{ path('admin_parapharmacies') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i> Retour
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_row(form.nom) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.telephone) }}
                    </div>
                    <div class="col-12">
                        {{ form_row(form.adresse) }}
                    </div>
                    <div class="col-12">
                        {{ form_row(form.email) }}
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Enregistrer
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
