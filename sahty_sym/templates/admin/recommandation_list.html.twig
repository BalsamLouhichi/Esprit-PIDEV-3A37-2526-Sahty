{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Recommandations{% endblock %}

{% block content %}
<section class="reco-admin-page">
    <div class="admin-panel-card mb-4">
        <div class="admin-section-header">
            <div>
                <h2 class="admin-section-title"><i class="fas fa-lightbulb me-2"></i>Gestion des Recommandations</h2>
                <p class="admin-section-subtitle">Administrez les conseils de sante, leur severite et leur ciblage.</p>
            </div>
            <a href="{{ path('app_recommandation_new') }}" class="btn btn-success btn-lg rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Ajouter une Recommandation
            </a>
        </div>
    </div>

    <div class="reco-stats row g-3 mb-4">
        <div class="col-md-4">
            <article class="stat-box">
                <span class="stat-label">Total Recommandations</span>
                <strong class="stat-value">{{ total_recommandations|default(recommandations|length) }}</strong>
            </article>
        </div>
        <div class="col-md-4">
            <article class="stat-box">
                <span class="stat-label">Niveau Eleve</span>
                <strong class="stat-value">
                    {% set high_count = 0 %}
                    {% for reco in recommandations %}
                        {% if reco.severity == 'high' %}
                            {% set high_count = high_count + 1 %}
                        {% endif %}
                    {% endfor %}
                    {{ high_count }}
                </strong>
            </article>
        </div>
        <div class="col-md-4">
            <article class="stat-box">
                <span class="stat-label">Videos Manuelles</span>
                <strong class="stat-value">
                    {% set manual_video_count = 0 %}
                    {% for reco in recommandations %}
                        {% if reco.videoUrl %}
                            {% set manual_video_count = manual_video_count + 1 %}
                        {% endif %}
                    {% endfor %}
                    {{ manual_video_count }}
                </strong>
            </article>
        </div>
    </div>

    <form method="get" class="admin-filter-card p-3 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Recherche</label>
                <input type="text" name="search" value="{{ active_search|default('') }}" class="form-control" placeholder="Nom, titre, description">
            </div>
            <div class="col-md-2">
                <label class="form-label">Severite</label>
                <select name="severity" class="form-select">
                    <option value="">Toutes</option>
                    <option value="low" {{ active_severity == 'low' ? 'selected' : '' }}>Faible</option>
                    <option value="medium" {{ active_severity == 'medium' ? 'selected' : '' }}>Moyen</option>
                    <option value="high" {{ active_severity == 'high' ? 'selected' : '' }}>Eleve</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Quiz</label>
                <select name="quiz_id" class="form-select">
                    <option value="">Tous</option>
                    {% for quiz in quiz_options|default([]) %}
                        <option value="{{ quiz.id }}" {{ active_quiz_id == quiz.id ? 'selected' : '' }}>{{ quiz.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Categorie</label>
                <input type="text" name="type" value="{{ active_type|default('') }}" class="form-control" placeholder="stress, sommeil...">
            </div>
            <div class="col-md-2">
                <label class="form-label">Tri</label>
                <select name="sort" class="form-select">
                    <option value="recent" {{ active_sort == 'recent' ? 'selected' : '' }}>Plus recentes</option>
                    <option value="name_asc" {{ active_sort == 'name_asc' ? 'selected' : '' }}>Titre A-Z</option>
                    <option value="name_desc" {{ active_sort == 'name_desc' ? 'selected' : '' }}>Titre Z-A</option>
                    <option value="score_asc" {{ active_sort == 'score_asc' ? 'selected' : '' }}>Score min +</option>
                    <option value="score_desc" {{ active_sort == 'score_desc' ? 'selected' : '' }}>Score max -</option>
                    <option value="severity" {{ active_sort == 'severity' ? 'selected' : '' }}>Severite</option>
                </select>
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Appliquer</button>
                <a href="{{ path('admin_recommandation_index') }}" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
    </form>

    {% if recommandations is empty %}
        <div class="admin-empty-state">
            <i class="fas fa-inbox mb-3"></i>
            <h4 class="mb-2">Aucune recommandation disponible</h4>
            <p class="text-muted mb-3">Ajoutez votre premiere recommandation pour demarrer.</p>
            <a href="{{ path('app_recommandation_new') }}" class="btn btn-primary rounded-pill px-4">Creer une recommandation</a>
        </div>
    {% else %}
        <div class="admin-table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th style="width: 72px;">#</th>
                        <th>Titre</th>
                        <th>Quiz</th>
                        <th>Categorie</th>
                        <th>Score</th>
                        <th>Severite</th>
                        <th>Video</th>
                        <th>Date</th>
                        <th style="width: 140px;">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for reco in recommandations %}
                        <tr>
                            <td><span class="admin-id-pill">#{{ reco.id }}</span></td>
                            <td>
                                <div class="fw-semibold text-dark">{{ reco.title ?: reco.name }}</div>
                                <small class="text-muted">{{ reco.name }}</small>
                            </td>
                            <td>
                                {% if reco.quiz %}
                                    <span class="badge bg-secondary-subtle text-secondary">{{ reco.quiz.name }}</span>
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if reco.typeProbleme %}
                                    {{ reco.typeProbleme|slice(0, 28) }}{{ reco.typeProbleme|length > 28 ? '...' : '' }}
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td><span class="badge text-bg-light">{{ reco.minScore }} - {{ reco.maxScore }}</span></td>
                            <td>
                                <span class="badge {{ reco.severity == 'high' ? 'bg-danger' : (reco.severity == 'medium' ? 'bg-warning text-dark' : 'bg-success') }}">
                                    {{ reco.severity|upper }}
                                </span>
                            </td>
                            <td>
                                {% if reco.videoUrl %}
                                    <span class="badge bg-primary-subtle text-primary">Manuelle</span>
                                {% else %}
                                    <span class="badge bg-light text-dark">Auto categorie</span>
                                {% endif %}
                            </td>
                            <td>{{ reco.createdAt ? reco.createdAt|date('d/m/Y H:i') : '' }}</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_recommandation_edit', {id: reco.id}) }}" class="btn btn-outline-warning btn-sm rounded-circle action-btn" title="Modifier">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_recommandation_delete', {id: reco.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette recommandation ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reco.id) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle action-btn" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if total_pages|default(1) > 1 %}
            <nav class="mt-4">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('admin_recommandation_index', app.request.query.all|merge({page: current_page - 1})) }}">Precedent</a>
                    </li>
                    {% for p in 1..total_pages %}
                        <li class="page-item {{ p == current_page ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('admin_recommandation_index', app.request.query.all|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('admin_recommandation_index', app.request.query.all|merge({page: current_page + 1})) }}">Suivant</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% endif %}
</section>
{% endblock %}

{% block head_extra %}
<style>
    .reco-admin-page {
        animation: fadeIn 0.25s ease-out;
    }

    .reco-stats .stat-box {
        background: #fff;
        border: 1px solid #e7eef2;
        border-radius: 14px;
        padding: 1rem 1.1rem;
        box-shadow: 0 6px 18px rgba(29, 42, 77, 0.05);
        height: 100%;
    }

    .stat-label {
        display: block;
        color: #6c7a89;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.35rem;
    }

    .stat-value {
        font-size: 1.55rem;
        color: #1d2a4d;
        line-height: 1.1;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    @media (max-width: 768px) {
        .admin-section-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(4px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
{% endblock %}
