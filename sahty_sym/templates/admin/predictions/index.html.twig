{% extends 'base.html.twig' %}

{% block title %}Predictions Utilisateurs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .chart-card {
            min-height: 320px;
        }
        .chart-wrapper {
            position: relative;
            height: 240px;
        }
        .chart-wrapper.chart-wide {
            height: 280px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Predictions utilisateurs</h1>
    </div>

    {% if predictions is empty %}
        <div class="alert alert-info">Aucune donnee disponible.</div>
    {% else %}
        <div class="row g-4 mb-4">
            <div class="col-lg-4">
                <div class="card shadow-sm chart-card">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Risque d'inactivite</h6>
                        <div class="chart-wrapper">
                            <canvas id="churnRiskChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm chart-card">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Risque d'annulation</h6>
                        <div class="chart-wrapper">
                            <canvas id="cancelRiskChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm chart-card">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Score de demande</h6>
                        <div class="chart-wrapper">
                            <canvas id="demandScoreChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Top 10 scores de demande</h6>
                        <div class="chart-wrapper chart-wide">
                            <canvas id="topDemandChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Derniere activite</th>
                                <th>Activite 30j</th>
                                <th>Demandes 30j</th>
                                <th>RDV 30j</th>
                                <th>Annulation 30j</th>
                                <th>Risque inactivite</th>
                                <th>Risque annulation</th>
                                <th>Score demande</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in predictions %}
                                <tr>
                                    <td>{{ row.user_id }}</td>
                                    <td>{{ row.last_activity ?? '—' }}</td>
                                    <td>{{ row.activity_30d }}</td>
                                    <td>{{ row.demands_30d }}</td>
                                    <td>{{ row.appointments_30d }}</td>
                                    <td>{{ row.cancel_rate_30d }}%</td>
                                    <td>
                                        <strong>{{ row.churn_risk_score }}</strong>
                                        <span class="text-muted">({{ row.churn_risk_label }})</span>
                                    </td>
                                    <td>
                                        <strong>{{ row.cancel_risk_score }}</strong>
                                        <span class="text-muted">({{ row.cancel_risk_label }})</span>
                                    </td>
                                    <td>
                                        <strong>{{ row.demand_score }}</strong>
                                        <span class="text-muted">({{ row.demand_label }})</span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% if predictions is not empty %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const predictions = {{ predictions|json_encode|raw }};
            const riskLabels = ['faible', 'moyen', 'eleve'];
            const riskDisplay = {
                faible: 'Faible',
                moyen: 'Moyen',
                eleve: 'Eleve'
            };

            const countByLabel = (key) => {
                const counts = { faible: 0, moyen: 0, eleve: 0 };
                predictions.forEach((row) => {
                    const label = row[key] || 'faible';
                    if (counts[label] !== undefined) {
                        counts[label] += 1;
                    }
                });
                return riskLabels.map((label) => counts[label]);
            };

            const makeDoughnut = (ctx, data, colors) => {
                if (!ctx) return;
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: riskLabels.map((label) => riskDisplay[label]),
                        datasets: [{
                            data,
                            backgroundColor: colors,
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 8,
                                    padding: 16
                                }
                            }
                        },
                        cutout: '70%'
                    }
                });
            };

            makeDoughnut(
                document.getElementById('churnRiskChart'),
                countByLabel('churn_risk_label'),
                ['#10b981', '#f59e0b', '#ef4444']
            );

            makeDoughnut(
                document.getElementById('cancelRiskChart'),
                countByLabel('cancel_risk_label'),
                ['#10b981', '#f59e0b', '#ef4444']
            );

            makeDoughnut(
                document.getElementById('demandScoreChart'),
                countByLabel('demand_label'),
                ['#3b82f6', '#f59e0b', '#8b5cf6']
            );

            const topDemand = [...predictions]
                .sort((a, b) => b.demand_score - a.demand_score)
                .slice(0, 10);

            const topDemandCtx = document.getElementById('topDemandChart');
            if (topDemandCtx) {
                new Chart(topDemandCtx, {
                    type: 'bar',
                    data: {
                        labels: topDemand.map((row) => `#${row.user_id}`),
                        datasets: [{
                            label: 'Score demande',
                            data: topDemand.map((row) => row.demand_score),
                            backgroundColor: '#2563eb',
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            x: {
                                grid: {
                                    display: false
                                }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
{% endif %}
{% endblock %}
