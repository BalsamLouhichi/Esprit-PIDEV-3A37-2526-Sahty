{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Quizzes{% endblock %}

{% block content %}
<section class="quiz-admin-page">
    <div class="admin-panel-card mb-4">
        <div class="admin-section-header">
            <div>
                <h2 class="admin-section-title"><i class="fas fa-question-circle me-2"></i>Gestion des Quizzes</h2>
                <p class="admin-section-subtitle">Organisez vos questionnaires de sante et suivez leur structure.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="{{ path('admin_quiz_index') }}" class="btn btn-outline-dark btn-lg rounded-pill px-4">
                    <i class="fas fa-chart-line me-2"></i>Analytics
                </a>
                <a href="{{ path('app_quiz_generate_ai') }}" class="btn btn-outline-primary btn-lg rounded-pill px-4">
                    <i class="fas fa-wand-magic-sparkles me-2"></i>Generer par IA
                </a>
                <a href="{{ path('app_quiz_new') }}" class="btn btn-success btn-lg rounded-pill px-4">
                    <i class="fas fa-plus me-2"></i>Ajouter un Quiz
                </a>
            </div>
        </div>
    </div>

    <div class="quiz-stats row g-3 mb-4">
        <div class="col-md-4">
            <article class="stat-box">
                <span class="stat-label">Total Quizzes</span>
                <strong class="stat-value">{{ total_quizzes|default(quizzes|length) }}</strong>
            </article>
        </div>
        <div class="col-md-4">
            <article class="stat-box">
                <span class="stat-label">Questions Totales</span>
                <strong class="stat-value">
                    {% set total_questions = 0 %}
                    {% for quiz in quizzes %}
                        {% set total_questions = total_questions + quiz.questions|length %}
                    {% endfor %}
                    {{ total_questions }}
                </strong>
            </article>
        </div>
        <div class="col-md-4">
            <article class="stat-box">
                <span class="stat-label">Derniere Mise a Jour</span>
                <strong class="stat-value">{{ quizzes|length > 0 ? quizzes|first.createdAt|date('d/m/Y') : '-' }}</strong>
            </article>
        </div>
    </div>

    <form method="get" class="admin-filter-card p-3 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Recherche</label>
                <input type="text" name="search" class="form-control" value="{{ active_search|default('') }}" placeholder="Nom ou description">
            </div>
            <div class="col-md-3">
                <label class="form-label">Tri</label>
                <select name="sort" class="form-select">
                    <option value="recent" {{ active_sort == 'recent' ? 'selected' : '' }}>Plus recents</option>
                    <option value="oldest" {{ active_sort == 'oldest' ? 'selected' : '' }}>Plus anciens</option>
                    <option value="name_asc" {{ active_sort == 'name_asc' ? 'selected' : '' }}>Nom A-Z</option>
                    <option value="name_desc" {{ active_sort == 'name_desc' ? 'selected' : '' }}>Nom Z-A</option>
                    <option value="questions_asc" {{ active_sort == 'questions_asc' ? 'selected' : '' }}>Questions croissant</option>
                    <option value="questions_desc" {{ active_sort == 'questions_desc' ? 'selected' : '' }}>Questions decroissant</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Min Questions</label>
                <input type="number" min="0" name="min_questions" class="form-control" value="{{ active_min_questions|default(0) }}">
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Appliquer</button>
                <a href="{{ path('admin_quiz_index') }}" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
    </form>

    {% if quizzes is empty %}
        <div class="admin-empty-state">
            <i class="fas fa-inbox mb-3"></i>
            <h4 class="mb-2">Aucun quiz disponible</h4>
            <p class="text-muted mb-3">Commencez par creer votre premier quiz.</p>
            <a href="{{ path('app_quiz_new') }}" class="btn btn-primary rounded-pill px-4">Creer un quiz</a>
        </div>
    {% else %}
        <div class="admin-table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th style="width: 150px;">Questions</th>
                        <th style="width: 180px;">Cree le</th>
                        <th style="width: 170px;">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for quiz in quizzes %}
                        <tr>
                            <td><span class="admin-id-pill">#{{ quiz.id }}</span></td>
                            <td>
                                <div class="fw-semibold text-dark">{{ quiz.name }}</div>
                            </td>
                            <td class="text-muted">
                                {% if quiz.description %}
                                    {{ quiz.description|slice(0, 95) ~ (quiz.description|length > 95 ? '...' : '') }}
                                {% else %}
                                    <span class="fst-italic">Sans description</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary">{{ quiz.questions|length }} question{{ quiz.questions|length > 1 ? 's' : '' }}</span>
                            </td>
                            <td>{{ quiz.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_quiz_show', {id: quiz.id}) }}" class="btn btn-outline-info btn-sm rounded-circle action-btn" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_quiz_edit', {id: quiz.id}) }}" class="btn btn-outline-warning btn-sm rounded-circle action-btn" title="Modifier">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_quiz_delete', {id: quiz.id}) }}" onsubmit="return confirm('Supprimer ce quiz ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle action-btn" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if total_pages|default(1) > 1 %}
            <nav class="mt-4">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('admin_quiz_index', app.request.query.all|merge({page: current_page - 1})) }}">Precedent</a>
                    </li>
                    {% for p in 1..total_pages %}
                        <li class="page-item {{ p == current_page ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('admin_quiz_index', app.request.query.all|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('admin_quiz_index', app.request.query.all|merge({page: current_page + 1})) }}">Suivant</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% endif %}
</section>
{% endblock %}

{% block head_extra %}
<style>
    .quiz-admin-page {
        animation: fadeIn 0.25s ease-out;
    }

    .quiz-stats .stat-box {
        background: #fff;
        border: 1px solid #e7eef2;
        border-radius: 14px;
        padding: 1rem 1.1rem;
        box-shadow: 0 6px 18px rgba(29, 42, 77, 0.05);
        height: 100%;
    }

    .stat-label {
        display: block;
        color: #6c7a89;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.35rem;
    }

    .stat-value {
        font-size: 1.55rem;
        color: #1d2a4d;
        line-height: 1.1;
    }

    .action-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    @media (max-width: 768px) {
        .admin-section-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(4px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
{% endblock %}
