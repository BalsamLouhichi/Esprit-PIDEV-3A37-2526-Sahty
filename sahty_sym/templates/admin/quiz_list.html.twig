{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Quizzes{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <!-- En-tête -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-2"><i class="fas fa-question-circle me-2"></i>Gestion des Quizzes</h1>
            <p class="text-muted">Organisez vos questionnaires de santé et suivez leur structure.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('admin_quiz_index') }}" class="btn btn-outline-primary">
                <i class="fas fa-chart-line me-1"></i> Analytics
            </a>
            <a href="{{ path('app_quiz_generate_ai') }}" class="btn btn-outline-primary">
                <i class="fas fa-wand-magic-sparkles me-1"></i> Générer par IA
            </a>
            <a href="{{ path('app_quiz_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Ajouter un Quiz
            </a>
        </div>
    </div>

    <!-- Statistiques -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title text-white-50 mb-2">Total Quizzes</h6>
                    <h2 class="card-text mb-0">{{ total_quizzes|default(quizzes|length) }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title text-white-50 mb-2">Questions Totales</h6>
                    <h2 class="card-text mb-0">
                        {% set total_questions = 0 %}
                        {% for quiz in quizzes %}
                            {% set total_questions = total_questions + quiz.questions|length %}
                        {% endfor %}
                        {{ total_questions }}
                    </h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title text-white-50 mb-2">Dernière Mise à Jour</h6>
                    <h2 class="card-text mb-0">{{ quizzes|length > 0 ? quizzes|first.createdAt|date('d/m/Y') : '-' }}</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">Recherche</label>
                        <input type="text" name="search" class="form-control" value="{{ active_search|default('') }}" placeholder="Nom ou description">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tri</label>
                        <select name="sort" class="form-select">
                            <option value="recent" {{ active_sort == 'recent' ? 'selected' : '' }}>Plus récents</option>
                            <option value="oldest" {{ active_sort == 'oldest' ? 'selected' : '' }}>Plus anciens</option>
                            <option value="name_asc" {{ active_sort == 'name_asc' ? 'selected' : '' }}>Nom A-Z</option>
                            <option value="name_desc" {{ active_sort == 'name_desc' ? 'selected' : '' }}>Nom Z-A</option>
                            <option value="questions_asc" {{ active_sort == 'questions_asc' ? 'selected' : '' }}>Questions croissant</option>
                            <option value="questions_desc" {{ active_sort == 'questions_desc' ? 'selected' : '' }}>Questions décroissant</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Min Questions</label>
                        <input type="number" min="0" name="min_questions" class="form-control" value="{{ active_min_questions|default(0) }}">
                    </div>
                    <div class="col-md-2 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary w-100">Appliquer</button>
                        <a href="{{ path('admin_quiz_index') }}" class="btn btn-outline-secondary">Reset</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tableau des quizzes -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                {% if quizzes is empty %}
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                        <h4 class="mb-2">Aucun quiz disponible</h4>
                        <p class="text-muted mb-3">Commencez par créer votre premier quiz.</p>
                        <a href="{{ path('app_quiz_new') }}" class="btn btn-primary">Créer un quiz</a>
                    </div>
                {% else %}
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width: 60px;">ID</th>
                                <th>Nom</th>
                                <th>Description</th>
                                <th style="width: 120px;">Questions</th>
                                <th style="width: 150px;">Créé le</th>
                                <th style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for quiz in quizzes %}
                                <tr>
                                    <td>
                                        <span class="badge bg-light text-dark">#{{ quiz.id }}</span>
                                    </td>
                                    <td>
                                        <span class="fw-semibold">{{ quiz.name }}</span>
                                    </td>
                                    <td class="text-muted">
                                        {% if quiz.description %}
                                            {{ quiz.description|slice(0, 95) ~ (quiz.description|length > 95 ? '...' : '') }}
                                        {% else %}
                                            <em class="text-muted">Sans description</em>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="badge 
                                            {% if quiz.questions|length == 0 %}bg-secondary
                                            {% elseif quiz.questions|length < 5 %}bg-info
                                            {% elseif quiz.questions|length < 10 %}bg-primary
                                            {% else %}bg-success{% endif %}">
                                            {{ quiz.questions|length }} question{{ quiz.questions|length > 1 ? 's' : '' }}
                                        </span>
                                    </td>
                                    <td>{{ quiz.createdAt|date('d/m/Y H:i') }}</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <a href="{{ path('app_quiz_show', {id: quiz.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_quiz_edit', {id: quiz.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                            <form method="post" action="{{ path('app_quiz_delete', {id: quiz.id}) }}" onsubmit="return confirm('Supprimer ce quiz ?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>

                    {% if total_pages|default(1) > 1 %}
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                                    <a class="page-link" href="{{ path('admin_quiz_index', app.request.query.all|merge({page: current_page - 1})) }}">Précédent</a>
                                </li>
                                {% for p in 1..total_pages %}
                                    <li class="page-item {{ p == current_page ? 'active' : '' }}">
                                        <a class="page-link" href="{{ path('admin_quiz_index', app.request.query.all|merge({page: p})) }}">{{ p }}</a>
                                    </li>
                                {% endfor %}
                                <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                                    <a class="page-link" href="{{ path('admin_quiz_index', app.request.query.all|merge({page: current_page + 1})) }}">Suivant</a>
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}