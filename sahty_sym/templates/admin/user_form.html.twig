<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if user %}Edit User{% else %}Create User{% endif %} - Sahty</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #13C5DD;
            --primary-dark: #0FA8B9;
            --dark: #1D2A4D;
            --light: #F5F7FA;
            --gray-200: #E8ECEF;
            --gray-600: #6B7280;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--light);
            color: #333;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: linear-gradient(135deg, var(--dark) 0%, #2D3E5F 100%);
            color: white;
            padding: 20px;
            overflow-y: auto;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
        }

        .sidebar-header {
            margin-bottom: 30px;
        }

        .sidebar-header h3 {
            font-size: 1.5rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-menu ul {
            list-style: none;
        }

        .sidebar-menu li {
            margin-bottom: 10px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .sidebar-menu a:hover {
            background-color: var(--primary);
            color: white;
        }

        .sidebar-menu a.active {
            background-color: var(--primary);
            color: white;
        }

        .sidebar-menu i {
            font-size: 1.1rem;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            background: white;
            padding: 15px 30px;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar h5 {
            margin: 0;
            color: var(--dark);
            font-weight: 600;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* Content Area */
        .content {
            padding: 30px;
            flex: 1;
            overflow-y: auto;
        }

        /* Cards */
        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            max-width: 600px;
        }

        .card-header {
            background: white;
            border-bottom: 1px solid var(--gray-200);
            padding: 20px;
        }

        .card-header h5 {
            margin: 0;
            color: var(--dark);
            font-weight: 600;
        }

        .card-body {
            padding: 30px;
        }

        /* Form */
        .form-label {
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--dark);
        }

        .form-control {
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            padding: 10px 15px;
            font-size: 0.95rem;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(19, 197, 221, 0.25);
        }

        .form-select {
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            padding: 10px 15px;
            font-size: 0.95rem;
        }

        .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(19, 197, 221, 0.25);
        }

        .form-group {
            margin-bottom: 20px;
        }

        /* Buttons */
        .btn {
            border-radius: 8px;
            font-weight: 500;
            padding: 10px 24px;
        }

        .btn-primary {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
        }

        .btn-secondary {
            background-color: var(--gray-600);
            border-color: var(--gray-600);
            color: white;
        }

        .btn-secondary:hover {
            background-color: #6b7280;
            border-color: #6b7280;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 30px;
        }

        /* Alerts */
        .alert {
            border-radius: 8px;
            margin-bottom: 20px;
        }

        /* Helper Text */
        .form-text {
            font-size: 0.85rem;
            color: var(--gray-600);
            margin-top: 5px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                width: 0;
                transform: translateX(-100%);
                transition: all 0.3s ease;
            }

            .sidebar.active {
                width: 260px;
                transform: translateX(0);
                z-index: 1000;
            }

            .main-content {
                margin-left: 0;
            }

            .topbar {
                padding: 15px;
            }

            .content {
                padding: 15px;
            }

            .card {
                max-width: 100%;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h3><i class="fas fa-clinic-medical"></i> Sahty</h3>
            </div>

            <div class="sidebar-menu">
                <ul>
                    <li>
                        <a href="{{ path('admin_index') }}">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('admin_users') }}" class="active">
                            <i class="fas fa-users"></i>
                            <span>Users Management</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="fas fa-calendar-check"></i>
                            <span>Appointments</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="fas fa-chart-bar"></i>
                            <span>Reports</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="fas fa-cog"></i>
                            <span>Settings</span>
                        </a>
                    </li>
                    <li style="margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
                        <a href="{{ path('app_logout') }}">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Logout</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Topbar -->
            <div class="topbar">
                <h5>{% if user %}Edit User{% else %}Create New User{% endif %}</h5>
                <div class="user-info">
                    <span>Welcome, {{ app.user.nom ?? 'Admin' }}</span>
                    <div class="user-avatar">{{ (app.user.nom ?? 'A')[:1]|upper }}</div>
                </div>
            </div>

            <!-- Content -->
            <div class="content">
                <!-- Back Link -->
                <div class="mb-3">
                    <a href="{{ path('admin_users') }}" class="text-decoration-none">
                        <i class="fas fa-arrow-left me-2"></i>Back to Users
                    </a>
                </div>

                <!-- Form Card -->
                <div class="card">
                    <div class="card-header">
                        <h5>
                            {% if user %}
                                <i class="fas fa-edit me-2"></i>Edit User Information
                            {% else %}
                                <i class="fas fa-user-plus me-2"></i>Create New User
                            {% endif %}
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="_token" value="{{ csrf_token('form') }}">
                            
                            <!-- First Name -->
                            <div class="form-group">
                                <label for="prenom" class="form-label">
                                    First Name <span class="text-danger">*</span>
                                </label>
                                <input 
                                    type="text" 
                                    id="prenom" 
                                    name="prenom" 
                                    class="form-control"
                                    value="{{ user ? user.prenom : '' }}"
                                    required>
                            </div>

                            <!-- Last Name -->
                            <div class="form-group">
                                <label for="nom" class="form-label">
                                    Last Name <span class="text-danger">*</span>
                                </label>
                                <input 
                                    type="text" 
                                    id="nom" 
                                    name="nom" 
                                    class="form-control"
                                    value="{{ user ? user.nom : '' }}"
                                    required>
                            </div>

                            <!-- Email -->
                            <div class="form-group">
                                <label for="email" class="form-label">
                                    Email Address <span class="text-danger">*</span>
                                </label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    class="form-control"
                                    value="{{ user ? user.email : '' }}"
                                    required>
                                <small class="form-text">The email must be unique</small>
                            </div>

                            <!-- Role -->
                            <div class="form-group">
                                <label for="role" class="form-label">
                                    Role <span class="text-danger">*</span>
                                </label>
                                <select id="role" name="role" class="form-select" required>
                                    <option value="">Select a role...</option>
                                    <option value="admin" {% if user and user.role == 'admin' %}selected{% endif %}>
                                        Administrator
                                    </option>
                                    <option value="medecin" {% if user and user.role == 'medecin' %}selected{% endif %}>
                                        Doctor (Médecin)
                                    </option>
                                    <option value="patient" {% if user and user.role == 'patient' %}selected{% endif %}>
                                        Patient
                                    </option>
                                    <option value="responsable_labo" {% if user and user.role == 'responsable_labo' %}selected{% endif %}>
                                        Lab Manager (Responsable Laboratoire)
                                    </option>
                                    <option value="responsable_para" {% if user and user.role == 'responsable_para' %}selected{% endif %}>
                                        Pharmacy Manager (Responsable Parapharmacie)
                                    </option>
                                </select>
                            </div>

                            <!-- Password -->
                            <div class="form-group">
                                <label for="password" class="form-label">
                                    Password {% if not user %}<span class="text-danger">*</span>{% endif %}
                                </label>
                                <input 
                                    type="password" 
                                    id="password" 
                                    name="password" 
                                    class="form-control"
                                    {% if not user %}required{% endif %}>
                                <small class="form-text">
                                    {% if user %}
                                        Leave empty to keep the current password
                                    {% else %}
                                        Enter a secure password (at least 8 characters)
                                    {% endif %}
                                </small>
                            </div>

                            <!-- Telephone -->
                            <div class="form-group">
                                <label for="telephone" class="form-label">Telephone</label>
                                <input type="text" id="telephone" name="telephone" class="form-control" value="{{ user ? user.telephone : '' }}">
                            </div>

                            <!-- Date of Birth -->
                            <div class="form-group">
                                <label for="dateNaissance" class="form-label">Date de naissance</label>
                                <input type="date" id="dateNaissance" name="dateNaissance" class="form-control" value="{{ user and user.dateNaissance ? user.dateNaissance|date('Y-m-d') : '' }}">
                            </div>

                            <!-- Profile Photo URL -->
                            <div class="form-group">
                                <label for="photoProfil" class="form-label">Profile Photo URL</label>
                                <input type="text" id="photoProfil" name="photoProfil" class="form-control" value="{{ user ? user.photoProfil : '' }}">
                                <small class="form-text">Or upload a file below</small>
                            </div>

                            <!-- Profile Photo Upload -->
                            <div class="form-group">
                                <label for="photoUpload" class="form-label">Upload Profile Photo</label>
                                <input type="file" id="photoUpload" name="photoUpload" class="form-control">
                                {% if user and user.photoProfil %}
                                    <div class="form-text mt-2">Current: <a href="{{ user.photoProfil }}" target="_blank">View</a></div>
                                {% endif %}
                            </div>

                            <!-- Active -->
                            <div class="form-group form-check">
                                <input type="checkbox" id="estActif" name="estActif" class="form-check-input" {% if user and user.estActif %}checked{% endif %}>
                                <label for="estActif" class="form-check-label">Active</label>
                            </div>

                            <!-- Role-specific sections -->
                            <div id="medecin-fields" class="role-fields" style="display: none;">
                                <hr>
                                <h6>Doctor (Médecin) details</h6>
                                <div class="form-group">
                                    <label class="form-label">Spécialité</label>
                                    <input type="text" name="specialite" class="form-control" value="{{ user is defined and user is not null and user.specialite ? user.specialite : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Années d'expérience</label>
                                    <input type="number" name="anneeExperience" class="form-control" value="{{ user is defined and user is not null and user.anneeExperience ? user.anneeExperience : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Grade</label>
                                    <input type="text" name="grade" class="form-control" value="{{ user is defined and user is not null and user.grade ? user.grade : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Adresse du cabinet</label>
                                    <input type="text" name="adresseCabinet" class="form-control" value="{{ user is defined and user is not null and user.adresseCabinet ? user.adresseCabinet : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Téléphone cabinet</label>
                                    <input type="text" name="telephoneCabinet" class="form-control" value="{{ user is defined and user is not null and user.telephoneCabinet ? user.telephoneCabinet : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Nom établissement</label>
                                    <input type="text" name="nomEtablissement" class="form-control" value="{{ user is defined and user is not null and user.nomEtablissement ? user.nomEtablissement : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Numéro urgence</label>
                                    <input type="text" name="numeroUrgence" class="form-control" value="{{ user is defined and user is not null and user.numeroUrgence ? user.numeroUrgence : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Disponibilité</label>
                                    <textarea name="disponibilite" class="form-control">{{ user is defined and user is not null and user.disponibilite ? user.disponibilite : '' }}</textarea>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Document PDF (contrat / diplôme)</label>
                                    <input type="file" name="documentPdf" class="form-control">
                                    {% if user is defined and user is not null and user.documentPdf %}
                                        <div class="form-text mt-2">Current doc: <a href="{{ user.documentPdf }}" target="_blank">View</a></div>
                                    {% endif %}
                                </div>
                            </div>

                            <div id="patient-fields" class="role-fields" style="display: none;">
                                <hr>
                                <h6>Patient details</h6>
                                <div class="form-group">
                                    <label class="form-label">Groupe sanguin</label>
                                    <input type="text" name="groupeSanguin" class="form-control" value="{{ user is defined and user is not null and user.groupeSanguin ? user.groupeSanguin : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Contact urgence</label>
                                    <input type="text" name="contactUrgence" class="form-control" value="{{ user is defined and user is not null and user.contactUrgence ? user.contactUrgence : '' }}">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Sexe</label>
                                    <select name="sexe" class="form-select">
                                        <option value="">--</option>
                                        <option value="male" {% if user and user.sexe == 'male' %}selected{% endif %}>Male</option>
                                        <option value="female" {% if user and user.sexe == 'female' %}selected{% endif %}>Female</option>
                                        <option value="other" {% if user and user.sexe == 'other' %}selected{% endif %}>Other</option>
                                    </select>
                                </div>
                            </div>

                            <div id="resp-labo-fields" class="role-fields" style="display: none;">
                                <hr>
                                <h6>Responsable Laboratoire</h6>
                                <div class="form-group">
                                    <label class="form-label">Laboratoire ID</label>
                                    <input type="number" name="laboratoireId" class="form-control" value="{{ user is defined and user is not null and user.laboratoireId ? user.laboratoireId : '' }}">
                                </div>
                            </div>

                            <div id="resp-para-fields" class="role-fields" style="display: none;">
                                <hr>
                                <h6>Responsable Parapharmacie</h6>
                                <div class="form-group">
                                    <label class="form-label">Parapharmacie ID</label>
                                    <input type="number" name="parapharmacieId" class="form-control" value="{{ user is defined and user is not null and user.parapharmacieId ? user.parapharmacieId : '' }}">
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>
                                    {% if user %}Save Changes{% else %}Create User{% endif %}
                                </button>
                                <a href="{{ path('admin_users') }}" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function(){
            const roleEl = document.getElementById('role');
            const sections = {
                'medecin': document.getElementById('medecin-fields'),
                'patient': document.getElementById('patient-fields'),
                'responsable_labo': document.getElementById('resp-labo-fields'),
                'responsable_para': document.getElementById('resp-para-fields')
            };

            function update() {
                const val = roleEl.value;
                Object.keys(sections).forEach(k => {
                    const el = sections[k];
                    if (!el) return;
                    el.style.display = (k === val) ? 'block' : 'none';
                });
            }

            if (roleEl) {
                roleEl.addEventListener('change', update);
                update();
            }
        })();
    </script>
</body>
</html>
