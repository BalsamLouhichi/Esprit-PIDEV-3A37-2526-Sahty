<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des utilisateurs - Sahty</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #13C5DD;
            --primary-dark: #0FA8B9;
            --dark: #1D2A4D;
            --light: #F5F7FA;
            --gray-200: #E8ECEF;
            --gray-600: #6B7280;
            --success: #10B981;
            --danger: #EF4444;
            --warning: #F59E0B;
            --purple: #8B5CF6;
            --orange: #F59E0B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--light);
            color: #333;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: linear-gradient(135deg, var(--dark) 0%, #2D3E5F 100%);
            color: white;
            padding: 20px;
            overflow-y: auto;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
        }

        .sidebar-header {
            margin-bottom: 30px;
        }

        .sidebar-header h3 {
            font-size: 1.5rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-menu ul {
            list-style: none;
            padding-left: 0;
        }

        .sidebar-menu li {
            margin-bottom: 10px;
        }

        .sidebar-menu a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .sidebar-menu a:hover {
            background-color: var(--primary);
            color: white;
        }

        .sidebar-menu a.active {
            background-color: var(--primary);
            color: white;
        }

        .sidebar-menu i {
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            background: white;
            padding: 15px 30px;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar h5 {
            margin: 0;
            color: var(--dark);
            font-weight: 600;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* Content Area */
        .content {
            padding: 30px;
            flex: 1;
            overflow-y: auto;
        }

        /* Cards */
        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .card-header {
            background: white;
            border-bottom: 1px solid var(--gray-200);
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-header h5 {
            margin: 0;
            color: var(--dark);
            font-weight: 600;
        }

        .card-body {
            padding: 20px;
        }

        /* Alerts */
        .alert {
            border-radius: 8px;
            margin-bottom: 20px;
            border: none;
        }

        .alert-success {
            background-color: #D1FAE5;
            color: #065F46;
        }

        .alert-danger {
            background-color: #FEE2E2;
            color: #991B1B;
        }

        /* Buttons */
        .btn {
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-primary {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
        }

        .btn-outline-primary {
            color: var(--primary);
            border-color: var(--primary);
        }

        .btn-outline-primary:hover {
            background-color: var(--primary);
            color: white;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.85rem;
        }

        .btn-group {
            gap: 5px;
        }

        /* Search Box */
        .search-box {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 15px;
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(19, 197, 221, 0.1);
        }

        /* Table */
        .table-responsive {
            border-radius: 8px;
        }

        .table {
            margin-bottom: 0;
        }

        .table thead th {
            border-bottom: 2px solid var(--gray-200);
            color: var(--dark);
            font-weight: 600;
            padding: 15px;
            background-color: #F9FAFB;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .table tbody td {
            padding: 15px;
            vertical-align: middle;
            border-bottom: 1px solid var(--gray-200);
        }

        .table tbody tr:hover {
            background-color: #F9FAFB;
        }

        .badge {
            font-size: 0.75rem;
            padding: 5px 10px;
            border-radius: 6px;
            font-weight: 500;
        }

        .bg-success {
            background-color: var(--success) !important;
        }

        .bg-danger {
            background-color: var(--danger) !important;
        }

        .bg-warning {
            background-color: var(--warning) !important;
            color: white;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--gray-600);
        }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 15px;
            color: #CBD5E1;
        }

        .empty-state h5 {
            color: #64748B;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: #94A3B8;
            margin-bottom: 20px;
        }

        /* Filter Buttons */
        .filter-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-buttons .btn {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Spinner */
        .spinner-border {
            width: 3rem;
            height: 3rem;
            color: var(--primary);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                width: 0;
                transform: translateX(-100%);
                transition: all 0.3s ease;
            }

            .sidebar.active {
                width: 260px;
                transform: translateX(0);
                z-index: 1000;
            }

            .main-content {
                margin-left: 0;
            }

            .card-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .topbar {
                padding: 15px;
            }

            .content {
                padding: 15px;
            }

            .filter-buttons {
                justify-content: center;
            }

            .table thead th,
            .table tbody td {
                padding: 10px;
            }
            
            .btn-group {
                display: flex;
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h3><i class="fas fa-clinic-medical"></i> Sahty</h3>
            </div>

            <div class="sidebar-menu">
                <ul>
                    <li>
                        <a href="{{ path('admin_index') }}">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('admin_users') }}" class="active">
                            <i class="fas fa-users"></i>
                            <span>Users Management</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="fas fa-calendar-check"></i>
                            <span>Appointments</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="fas fa-chart-bar"></i>
                            <span>Reports</span>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="fas fa-cog"></i>
                            <span>Settings</span>
                        </a>
                    </li>
                    <li style="margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
                        <a href="{{ path('app_logout') }}">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Logout</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Topbar -->
            <div class="topbar">
                <h5><i class="fas fa-users me-2"></i>Gestion des utilisateurs</h5>
                <div class="user-info">
                    <span>Bienvenue, {{ app.user.prenom ?? 'Admin' }} {{ app.user.nom ?? '' }}</span>
                    <div class="user-avatar">
                        {% if app.user and app.user.photoProfil %}
                            <img src="{{ app.user.photoProfil }}" alt="Profile" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                        {% else %}
                            {{ (app.user.prenom ?? 'A')[:1]|upper }}{{ (app.user.nom ?? '')[:1]|upper }}
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="content">
                <!-- Alerts -->
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                            {% if label == 'success' %}
                                <i class="fas fa-check-circle me-2"></i>
                            {% else %}
                                <i class="fas fa-exclamation-circle me-2"></i>
                            {% endif %}
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                <!-- Filters Card -->
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="filter-buttons">
                            <strong style="margin-right: 10px;">Filtrer par rôle :</strong>
                            <a href="{{ path('admin_users') }}" 
                               class="btn btn-sm filter-role-link {% if not selectedRole %}btn-primary{% else %}btn-outline-primary{% endif %}">
                                <i class="fas fa-users me-1"></i> Tous
                            </a>
                            <a href="{{ path('admin_users') }}?role=admin" 
                               class="btn btn-sm filter-role-link {% if selectedRole == 'admin' %}btn-dark{% else %}btn-outline-dark{% endif %}">
                                <i class="fas fa-user-shield me-1"></i> Admins
                            </a>
                            <a href="{{ path('admin_users') }}?role=medecin" 
                               class="btn btn-sm filter-role-link {% if selectedRole == 'medecin' %}btn-success{% else %}btn-outline-success{% endif %}">
                                <i class="fas fa-user-md me-1"></i> Médecins
                            </a>
                            <a href="{{ path('admin_users') }}?role=patient" 
                               class="btn btn-sm filter-role-link {% if selectedRole == 'patient' %}btn-info{% else %}btn-outline-info{% endif %}">
                                <i class="fas fa-bed me-1"></i> Patients
                            </a>
                            <a href="{{ path('admin_users') }}?role=responsable_labo" 
                               class="btn btn-sm filter-role-link" 
                               style="{% if selectedRole == 'responsable_labo' %}background-color: #8B5CF6; color: white; border-color: #8B5CF6;{% else %}color: #8B5CF6; border-color: #8B5CF6;{% endif %}">
                                <i class="fas fa-flask me-1"></i> Resp. Labo
                            </a>
                            <a href="{{ path('admin_users') }}?role=responsable_para" 
                               class="btn btn-sm filter-role-link" 
                               style="{% if selectedRole == 'responsable_para' %}background-color: #F59E0B; color: white; border-color: #F59E0B;{% else %}color: #F59E0B; border-color: #F59E0B;{% endif %}">
                                <i class="fas fa-pills me-1"></i> Resp. Para
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Users List Card -->
                <div class="card">
                    <div class="card-header">
                        <div>
                            <h5><i class="fas fa-list me-2"></i>Liste des utilisateurs</h5>
                            <small class="text-muted" id="user-count">{{ utilisateurs|length }} utilisateur(s) trouvé(s)</small>
                        </div>
                        <div>
                            <button class="btn btn-outline-secondary btn-sm me-2" id="reset-filters" title="Réinitialiser les filtres">
                                <i class="fas fa-undo me-1"></i> Réinitialiser
                            </button>
                            <a href="{{ path('admin_user_new') }}" class="btn btn-primary btn-sm">
                                <i class="fas fa-user-plus me-2"></i>Nouvel utilisateur
                            </a>
                        </div>
                    </div>

                    <div class="card-body">
                        <!-- Search Bar -->
                        <div class="search-box">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" 
                                       id="searchInput" 
                                       class="form-control border-start-0 ps-0" 
                                       placeholder="Rechercher par nom, prénom ou email..."
                                       value="{{ searchQuery ?? '' }}"
                                       autofocus>
                                <button class="btn btn-primary" type="button" id="searchButton">
                                    <i class="fas fa-search me-1"></i> Rechercher
                                </button>
                            </div>
                        </div>

                        <!-- Loading Spinner (hidden by default) -->
                        <div id="loading-spinner" class="text-center py-5 d-none">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Chargement...</span>
                            </div>
                            <p class="mt-2 text-muted">Recherche en cours...</p>
                        </div>

                        <!-- Users Table -->
                        <div id="table-container">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Nom & Prénom</th>
                                            <th>Email / Téléphone</th>
                                            <th>Rôle</th>
                                            <th>Statut</th>
                                            <th>Créé le</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="user-table-body">
                                        {% include 'admin/_user_table_rows.html.twig' %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Éléments DOM
            const searchInput = document.getElementById('searchInput');
            const searchButton = document.getElementById('searchButton');
            const resetButton = document.getElementById('reset-filters');
            const filterLinks = document.querySelectorAll('.filter-role-link');
            const tbody = document.getElementById('user-table-body');
            const spinner = document.getElementById('loading-spinner');
            const tableContainer = document.getElementById('table-container');
            const userCount = document.getElementById('user-count');
            
            let searchTimeout = null;
            
            // Fonction de recherche AJAX
            function performSearch() {
                const search = searchInput.value.trim();
                const urlParams = new URLSearchParams(window.location.search);
                const role = urlParams.get('role') || '';
                
                // Afficher le spinner
                spinner.classList.remove('d-none');
                tableContainer.style.opacity = '0.5';
                
                // Construire l'URL
                let url = '/admin/users/search?';
                if (search) url += 'search=' + encodeURIComponent(search) + '&';
                if (role) url += 'role=' + encodeURIComponent(role);
                
                // Requête AJAX
                fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    // Mettre à jour le tableau
                    tbody.innerHTML = html;
                    
                    // Mettre à jour le compteur
                    const rowCount = tbody.querySelectorAll('tr:not(.empty-state-row)').length;
                    if (userCount) {
                        userCount.textContent = rowCount + ' utilisateur(s) trouvé(s)';
                    }
                    
                    // Mettre à jour l'URL sans recharger la page
                    let newUrl = '/admin/users';
                    let params = [];
                    if (search) params.push('search=' + encodeURIComponent(search));
                    if (role) params.push('role=' + encodeURIComponent(role));
                    if (params.length > 0) newUrl += '?' + params.join('&');
                    window.history.pushState({ path: newUrl }, '', newUrl);
                })
                .catch(error => {
                    console.error('Erreur AJAX:', error);
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="7" class="text-center py-4 text-danger">
                                <i class="fas fa-exclamation-circle fa-2x mb-2"></i>
                                <p>Une erreur est survenue lors de la recherche.</p>
                            </td>
                        </tr>
                    `;
                })
                .finally(() => {
                    // Cacher le spinner
                    spinner.classList.add('d-none');
                    tableContainer.style.opacity = '1';
                });
            }
            
            // Recherche en temps réel (debounce)
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(performSearch, 400);
                });
                
                // Recherche avec la touche Entrée
                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        clearTimeout(searchTimeout);
                        performSearch();
                    }
                });
            }
            
            // Recherche au clic sur le bouton
            if (searchButton) {
                searchButton.addEventListener('click', function(e) {
                    e.preventDefault();
                    clearTimeout(searchTimeout);
                    performSearch();
                });
            }
            
            // Gestion des clics sur les filtres de rôle
            filterLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    const href = this.getAttribute('href');
                    const url = new URL(href, window.location.origin);
                    const role = url.searchParams.get('role');
                    
                    // Mettre à jour l'URL
                    let newUrl = '/admin/users';
                    let params = [];
                    if (role) params.push('role=' + encodeURIComponent(role));
                    if (searchInput.value.trim()) {
                        params.push('search=' + encodeURIComponent(searchInput.value.trim()));
                    }
                    if (params.length > 0) newUrl += '?' + params.join('&');
                    window.history.pushState({ path: newUrl }, '', newUrl);
                    
                    // Mettre à jour les classes des boutons
                    filterLinks.forEach(l => {
                        const lHref = l.getAttribute('href');
                        const lUrl = new URL(lHref, window.location.origin);
                        const lRole = lUrl.searchParams.get('role');
                        
                        // Réinitialiser les classes
                        l.className = 'btn btn-sm filter-role-link';
                        
                        // Appliquer les classes appropriées
                        if (lRole === role) {
                            if (role === 'admin') {
                                l.classList.add('btn-dark');
                            } else if (role === 'medecin') {
                                l.classList.add('btn-success');
                            } else if (role === 'patient') {
                                l.classList.add('btn-info');
                            } else if (role === 'responsable_labo') {
                                l.style.backgroundColor = '#8B5CF6';
                                l.style.color = 'white';
                                l.style.borderColor = '#8B5CF6';
                            } else if (role === 'responsable_para') {
                                l.style.backgroundColor = '#F59E0B';
                                l.style.color = 'white';
                                l.style.borderColor = '#F59E0B';
                            } else {
                                l.classList.add('btn-primary');
                            }
                        } else {
                            if (role === 'responsable_labo' || lRole === 'responsable_labo') {
                                l.style.backgroundColor = '';
                                l.style.color = '#8B5CF6';
                                l.style.borderColor = '#8B5CF6';
                                l.classList.add('btn-outline-primary');
                            } else if (role === 'responsable_para' || lRole === 'responsable_para') {
                                l.style.backgroundColor = '';
                                l.style.color = '#F59E0B';
                                l.style.borderColor = '#F59E0B';
                                l.classList.add('btn-outline-primary');
                            } else {
                                l.classList.add('btn-outline-primary');
                            }
                        }
                    });
                    
                    // Recharger les résultats
                    performSearch();
                });
            });
            
            // Réinitialiser les filtres
            if (resetButton) {
                resetButton.addEventListener('click', function() {
                    // Vider le champ de recherche
                    if (searchInput) {
                        searchInput.value = '';
                    }
                    
                    // Remettre le filtre "Tous" actif
                    window.history.pushState({ path: '/admin/users' }, '', '/admin/users');
                    
                    // Réinitialiser les classes des boutons
                    filterLinks.forEach(l => {
                        const href = l.getAttribute('href');
                        const url = new URL(href, window.location.origin);
                        const role = url.searchParams.get('role');
                        
                        l.className = 'btn btn-sm filter-role-link';
                        l.style.backgroundColor = '';
                        l.style.color = '';
                        l.style.borderColor = '';
                        
                        if (!role) {
                            l.classList.add('btn-primary');
                        } else if (role === 'responsable_labo') {
                            l.style.color = '#8B5CF6';
                            l.style.borderColor = '#8B5CF6';
                            l.classList.add('btn-outline-primary');
                        } else if (role === 'responsable_para') {
                            l.style.color = '#F59E0B';
                            l.style.borderColor = '#F59E0B';
                            l.classList.add('btn-outline-primary');
                        } else {
                            l.classList.add('btn-outline-' + 
                                (role === 'admin' ? 'dark' : 
                                 role === 'medecin' ? 'success' : 
                                 role === 'patient' ? 'info' : 'primary'));
                        }
                    });
                    
                    // Recharger tous les utilisateurs
                    performSearch();
                });
            }
            
            // Gérer le bouton retour du navigateur
            window.addEventListener('popstate', function() {
                const urlParams = new URLSearchParams(window.location.search);
                const search = urlParams.get('search') || '';
                if (searchInput) {
                    searchInput.value = search;
                }
                performSearch();
            });
        });
    </script>
</body>
</html>