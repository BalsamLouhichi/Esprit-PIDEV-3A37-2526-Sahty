{% extends 'base.html.twig' %}

{% block title %}Rapports Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="h3 mb-3">Rapports Admin</h1>
            <p class="text-muted">
                Generez un rapport mensuel PDF. Le rapport inclut les KPI admin principaux.
            </p>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="get" action="{{ path('admin_reports_monthly') }}" class="row g-3 align-items-end">
                        <div class="col-md-6">
                            <label for="month" class="form-label">Mois</label>
                            <input type="month" id="month" name="month" class="form-control" placeholder="YYYY-MM">
                        </div>
                        <div class="col-md-6 d-flex gap-2">
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-file-pdf me-2"></i>Telecharger le PDF
                            </button>
                            <a class="btn btn-outline-secondary" href="{{ path('admin_reports_monthly') }}">
                                Mois en cours
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                Pour un envoi automatique, utilisez la commande:
                <code>php bin/console app:report:monthly --send</code>
            </div>
        </div>
    </div>
</div>
{% endblock %}
